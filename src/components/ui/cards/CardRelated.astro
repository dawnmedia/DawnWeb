---
// Import necessary modules and utilities
import { Image } from "astro:assets";
import { formatDate } from "@utils/utils";
import type { CollectionEntry } from "astro:content";
import {
  DEFAULT_LOCALE,
  getContentSlug,
  localizePath,
  stripLocaleFromSlug,
  type Locale,
} from "@utils/locale";

const { blogEntry, recentBlogLocale = DEFAULT_LOCALE } = Astro.props;
const slug = stripLocaleFromSlug(getContentSlug(blogEntry), recentBlogLocale);

interface Props {
  blogEntry: CollectionEntry<"blog">;
  recentBlogLocale?: Locale;
}
---

<a
  class="group block rounded-xl outline-none ring-zinc-500 transition duration-300 focus-visible:ring dark:ring-zinc-200 dark:focus:outline-none"
  href={localizePath(`/blog/${slug}/`, recentBlogLocale)}
  data-astro-prefetch
>
  <div>
    <Image
      class="aspect-video rounded-xl"
      src={blogEntry.data.cardImage}
      alt={blogEntry.data.cardImageAlt}
      draggable={"false"}
      format={"avif"}
      width={520}
      sizes="(min-width: 768px) 50vw, 100vw"
      loading="lazy"
    />
    <!-- The title of the blog post -->
    <h3
      class="mt-2 text-balance text-lg font-medium text-neutral-800 group-hover:text-blue-400 dark:text-neutral-300 dark:group-hover:text-neutral-50"
    >
      {blogEntry.data.title}
    </h3>
    <!-- The formatted publication date of the blog post -->
    <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">
      {formatDate(blogEntry.data.pubDate)}
    </p>
  </div></a
>
