---
// Import all required components and utilities
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import AvatarBlogLarge from "@components/ui/avatars/AvatarBlogLarge.astro";
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import {
  DEFAULT_LOCALE,
  getContentSlug,
  localizePath,
  stripLocaleFromSlug,
  type Locale,
} from "@utils/locale";

const { blogEntry, recentBlogLocale = DEFAULT_LOCALE } = Astro.props;
const href = localizePath(
  `/blog/${stripLocaleFromSlug(getContentSlug(blogEntry), recentBlogLocale)}/`,
  recentBlogLocale,
);
const readMoreLabel = {
  en: "Read More",
  fr: "Lire la suite",
  br: "Ler mais",
  ko: "자세히 보기",
  ja: "続きを読む",
  es: "Leer más",
}[recentBlogLocale];

interface Props {
  blogEntry: CollectionEntry<"blog">;
  recentBlogLocale?: Locale;
}
---

<!-- Root container with glassmorphic styling, divided into 2 grid column layout for larger screens -->
<div class="group relative rounded-3xl border border-neutral-200 bg-white/40 p-6 backdrop-blur-sm transition-all duration-300 hover:border-blue-400 hover:shadow-xl hover:shadow-blue-900/5 dark:border-neutral-800 dark:bg-neutral-900/40 dark:hover:border-blue-500/50 dark:hover:shadow-blue-900/20 md:p-10">
  <div class="grid gap-8 sm:grid-cols-2 sm:items-center">
    <!-- Container for the blog post's cover image -->
    <div class="sm:order-2">
      <div class="relative overflow-hidden rounded-2xl bg-neutral-200 pt-[50%] dark:bg-neutral-900 sm:pt-[100%]">
        <Image
          class="absolute start-0 top-0 size-full object-cover transition duration-700 group-hover:scale-105"
          src={blogEntry.data.cardImage}
          alt={blogEntry.data.cardImageAlt}
          draggable={"false"}
          loading={"eager"}
          format={"avif"}
          width={760}
          sizes="(min-width: 1024px) 50vw, 100vw"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/80 via-neutral-900/20 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
      </div>
    </div>
    <!-- Container for the blog post heading, author avatar, role, and CTA -->
    <div class="sm:order-1">
      <!-- Blog title which is also a hyperlink to the blog detail page  -->
      <h2
        class="text-balance text-2xl font-bold tracking-tight text-neutral-900 transition-colors group-hover:text-blue-600 dark:text-neutral-50 dark:group-hover:text-blue-400 md:text-3xl lg:text-4xl lg:leading-tight xl:text-5xl xl:leading-tight"
      >
        <a
          class="outline-none focus-visible:ring-2 focus-visible:ring-blue-500 rounded"
          href={href}
        >
          {blogEntry.data.description}
        </a>
      </h2>
      <!-- Container for the author's avatar and metadata -->
      <div class="mt-6 flex items-center sm:mt-10">
        <AvatarBlogLarge blogEntry={blogEntry} />

        <div class="ms-3 sm:ms-4">
          <p class="font-bold text-neutral-900 dark:text-neutral-100 sm:mb-1">
            {blogEntry.data.author}
          </p>
          <p class="text-xs text-neutral-600 dark:text-neutral-400">
            {blogEntry.data.role}
          </p>
        </div>
      </div>
      <!-- CTA linking to the full blog post -->
      <div class="mt-8">
        <PrimaryCTA
          url={href}
          title={readMoreLabel}
          data-astro-prefetch
        />
      </div>
    </div>
  </div>
</div>
