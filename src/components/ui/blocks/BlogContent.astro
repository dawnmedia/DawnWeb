---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

const { contents, cardImage, cardImageAlt } = Astro.props;

interface Props {
  contents: string[];
  cardImage: ImageMetadata;
  cardImageAlt: string;
}

function splitNumberedSection(content: string) {
  if (!/^\d+\.\s/.test(content)) {
    return null;
  }

  const newlineIndex = content.indexOf("\n");
  if (newlineIndex > -1) {
    return {
      heading: content.slice(0, newlineIndex).trim().replace(/\.$/, ""),
      body: content.slice(newlineIndex).trim(),
    };
  }

  const firstSentenceEnd = content.indexOf(". ");
  if (firstSentenceEnd > -1) {
    return {
      heading: content.slice(0, firstSentenceEnd).trim().replace(/\.$/, ""),
      body: content.slice(firstSentenceEnd + 2).trim(),
    };
  }

  return null;
}
---

<div class="mb-5 space-y-5 md:mb-8 md:space-y-8">
  {
    contents.map((content: string, index: number) => {
      const numberedSection = splitNumberedSection(content);
      const contentBlock = numberedSection ? (
        <section class="space-y-3">
          <h2 class="text-xl font-bold text-neutral-800 dark:text-neutral-200">
            {numberedSection.heading}
          </h2>
          <p class="text-pretty text-lg text-neutral-700 dark:text-neutral-300">
            {numberedSection.body}
          </p>
        </section>
      ) : (
        <p class="text-pretty text-lg text-neutral-700 dark:text-neutral-300">
          {content}
        </p>
      );

      return index === 1 ? (
        <>
          {contentBlock}
          <Image
            class="w-full rounded-xl object-cover"
            src={cardImage}
            alt={cardImageAlt}
            draggable={"false"}
            format={"avif"}
            width={900}
            sizes="(min-width: 768px) 768px, 100vw"
          />
        </>
      ) : (
        contentBlock
      );
    })
  }
</div>
