---
import Icon from "@components/ui/icons/Icon.astro";
import { getLocaleFromPath } from "@utils/locale";

const locale = getLocaleFromPath(Astro.url.pathname);
const labels = {
  en: {
    share: "Share",
    shareOn: "Share on",
    copyLink: "Copy link",
    copied: "Copied",
  },
  fr: {
    share: "Partager",
    shareOn: "Partager sur",
    copyLink: "Copier le lien",
    copied: "Copié",
  },
  br: {
    share: "Compartilhar",
    shareOn: "Compartilhar no",
    copyLink: "Copiar link",
    copied: "Copiado",
  },
};

// Destructure the properties from Astro.props
const {
  pageTitle,
  title = labels[locale].share,
} = Astro.props;

// Define TypeScript interface for the properties
interface Props {
  pageTitle: string;
  title?: string;
}

type SocialPlatform = {
  name: string;
  url: string;
  svg: string;
};

const socialPlatforms: SocialPlatform[] = [
  {
    name: "Facebook",
    url: `https://www.facebook.com/share.php?u=${Astro.url}&title=${pageTitle}`,
    svg: "facebook",
  },
  {
    name: "X",
    url: `https://twitter.com/home/?status=${pageTitle}${Astro.url}`,
    svg: "x",
  },
  {
    name: "LinkedIn",
    url: `https://www.linkedin.com/shareArticle?mini=true&url=${Astro.url}&title=${pageTitle}`,
    svg: "linkedIn",
  },
];
---

<div class="relative inline-flex" data-share-menu>
  <button
    id="share-menu-toggle"
    type="button"
    aria-expanded="false"
    aria-controls="share-menu-panel"
    class="inline-flex items-center gap-x-2 rounded-lg px-4 py-3 text-sm font-medium text-neutral-600 outline-none ring-zinc-500 transition duration-300 hover:bg-neutral-100 hover:text-neutral-700 focus-visible:ring dark:text-neutral-400 dark:ring-zinc-200 dark:hover:bg-neutral-700 dark:hover:text-neutral-300 dark:focus:outline-none"
    data-share-toggle
  >
    <Icon name="share" />

    {title}
  </button>

  <div
    id="share-menu-panel"
    class="absolute bottom-full right-0 z-10 mb-2 hidden w-72 divide-y divide-neutral-200 rounded-lg bg-neutral-50 p-2 opacity-0 shadow-md transition-opacity dark:divide-neutral-700 dark:border dark:border-neutral-700 dark:bg-neutral-800"
    aria-labelledby="share-menu-toggle"
    data-share-panel
  >
    <div class="py-2 first:pt-0 last:pb-0">
      {
        socialPlatforms.map((platform) => (
          <a
            class="flex items-center gap-x-3.5 rounded-lg px-3 py-2 text-sm text-neutral-700 hover:bg-neutral-200 focus:bg-neutral-100  focus:outline-none dark:text-neutral-300 dark:hover:bg-neutral-700 dark:hover:text-neutral-300 dark:focus:bg-neutral-700 "
            href={platform.url}
          >
            <Icon name={platform.svg} />
            {labels[locale].shareOn} {platform.name}
          </a>
        ))
      }
    </div>
    <div class="py-2 first:pt-0 last:pb-0">
      <button
        type="button"
        class="js-clipboard hover:text-dark focus-visible:ring-secondary group inline-flex w-full items-center gap-x-3.5 rounded-lg px-3 py-2 text-sm text-neutral-700 hover:bg-neutral-200 focus:bg-neutral-100 focus:outline-none focus-visible:outline-none focus-visible:ring-1 dark:text-neutral-300 dark:hover:bg-neutral-700 dark:hover:text-neutral-300 dark:focus:bg-neutral-700"
        data-clipboard-success-text={labels[locale].copied}
        data-copy-link
      >
        <svg
          class="js-clipboard-default h-4 w-4 transition group-hover:rotate-6"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect width="8" height="4" x="8" y="2" rx="1" ry="1"></rect>
          <path
            d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"
          ></path>
        </svg>

        <svg
          class="js-clipboard-success hidden h-4 w-4 text-neutral-700 dark:text-neutral-300"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        <span class="js-clipboard-success-text">{labels[locale].copyLink}</span>
      </button>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll("[data-share-menu]").forEach((menuRoot) => {
      const toggle = menuRoot.querySelector("[data-share-toggle]");
      const panel = menuRoot.querySelector("[data-share-panel]");
      const setOpen = (open) => {
        toggle?.setAttribute("aria-expanded", String(open));
        panel?.classList.toggle("hidden", !open);
        panel?.classList.toggle("opacity-0", !open);
        panel?.classList.toggle("opacity-100", open);
      };

      toggle?.addEventListener("click", (event) => {
        event.stopPropagation();
        setOpen(toggle.getAttribute("aria-expanded") !== "true");
      });

      document.addEventListener("click", (event) => {
        if (!menuRoot.contains(event.target)) setOpen(false);
      });

      menuRoot.querySelectorAll("[data-copy-link]").forEach((button) => {
        button.addEventListener("click", async () => {
          if (!navigator.clipboard) {
            return;
          }
          await navigator.clipboard.writeText(window.location.href);
          const defaultElement = button.querySelector(".js-clipboard-default");
          const successElement = button.querySelector(".js-clipboard-success");
          const successTextElement = button.querySelector(
            ".js-clipboard-success-text",
          );
          const oldText = successTextElement?.textContent || "";

          if (successTextElement) {
            successTextElement.textContent =
              button.getAttribute("data-clipboard-success-text") || oldText;
          }
          defaultElement?.classList.add("hidden");
          successElement?.classList.remove("hidden");

          setTimeout(() => {
            if (successTextElement) successTextElement.textContent = oldText;
            defaultElement?.classList.remove("hidden");
            successElement?.classList.add("hidden");
          }, 900);
        });
      });
    });
  });
</script>
