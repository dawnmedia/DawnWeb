---
import Icon from "./icons/Icon.astro";
import {
  LOCALE_LABELS,
  getAvailableLocalesForPath,
  getLocaleFromPath,
  localizePath,
  type Locale,
} from "@utils/locale";

const currentLocale = getLocaleFromPath(Astro.url.pathname);
const availableLocales = getAvailableLocalesForPath(Astro.url.pathname);
const visibleLocales = availableLocales.length > 0 ? availableLocales : [currentLocale];
const shortLabels: Record<Locale, string> = {
  en: "EN",
  fr: "FR",
  br: "PT",
  ko: "KO",
  ja: "JA",
};
const currentLanguageLabel = LOCALE_LABELS[currentLocale];
const currentShortLabel = shortLabels[currentLocale];
const changeLanguageLabel =
  currentLocale === "ko"
    ? "언어 변경"
    : currentLocale === "ja"
      ? "言語を変更"
      : currentLocale === "fr"
        ? "Changer de langue"
        : currentLocale === "br"
          ? "Alterar idioma"
          : "Change language";
const languageOptions = visibleLocales.map((locale) => ({
  locale,
  label: LOCALE_LABELS[locale],
  shortLabel: shortLabels[locale],
  href: localizePath(Astro.url.pathname, locale),
  current: locale === currentLocale,
}));
---

<div class="relative inline-flex" data-language-picker>
  <button
    id="language-picker-toggle"
    type="button"
    aria-label={`${changeLanguageLabel}: ${currentLanguageLabel}`}
    aria-expanded="false"
    aria-controls="language-picker-menu"
    class="inline-flex min-w-16 items-center justify-center gap-x-2 rounded-lg px-2.5 py-1.5 text-sm font-bold text-neutral-700 outline-none ring-zinc-500 transition duration-300 hover:bg-neutral-200 hover:text-blue-500 dark:border-neutral-700 dark:text-neutral-200 dark:ring-zinc-200 dark:hover:bg-neutral-700 dark:hover:text-blue-300 dark:focus:outline-none"
    data-language-toggle
  >
    <Icon name="earth" class="size-4 shrink-0" />
    <span class="leading-none">{currentShortLabel}</span>
    <svg
      class="size-4 shrink-0 transition-transform"
      data-language-chevron
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg
    >
  </button>

  <div
    id="language-picker-menu"
    class="absolute left-0 top-full z-50 mt-2 hidden min-w-48 rounded-lg border border-neutral-200 bg-neutral-50 p-2 opacity-0 shadow-md transition-opacity dark:divide-neutral-700 dark:border-neutral-700 dark:bg-neutral-800 md:left-auto md:right-0"
    aria-labelledby="language-picker-toggle"
    data-language-menu
  >
    {
      languageOptions.map(({ label, shortLabel, href, current }) => (
        <a
          class:list={[
            "flex items-center gap-x-3 rounded-lg px-3 py-2 text-sm focus:bg-neutral-100 focus:outline-none dark:focus:bg-neutral-700",
            current
              ? "bg-blue-50 font-bold text-blue-700 dark:bg-blue-900/30 dark:text-blue-200"
              : "text-neutral-800 hover:bg-neutral-100 dark:text-neutral-300 dark:hover:bg-neutral-700 dark:hover:text-neutral-100",
          ]}
          href={href}
          aria-current={current ? "page" : undefined}
        >
          <span class="w-7 shrink-0 text-xs font-bold uppercase text-neutral-500 dark:text-neutral-400">
            {shortLabel}
          </span>
          <span>{label}</span>
        </a>
      ))
    }
  </div>
</div>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll("[data-language-picker]").forEach((picker) => {
      const toggle = picker.querySelector("[data-language-toggle]");
      const menu = picker.querySelector("[data-language-menu]");
      const chevron = picker.querySelector("[data-language-chevron]");

      const setOpen = (open) => {
        toggle?.setAttribute("aria-expanded", String(open));
        menu?.classList.toggle("hidden", !open);
        menu?.classList.toggle("opacity-0", !open);
        menu?.classList.toggle("opacity-100", open);
        chevron?.classList.toggle("rotate-180", open);
      };

      toggle?.addEventListener("click", (event) => {
        event.stopPropagation();
        setOpen(toggle.getAttribute("aria-expanded") !== "true");
      });

      document.addEventListener("click", (event) => {
        if (!picker.contains(event.target)) setOpen(false);
      });

      picker.addEventListener("keydown", (event) => {
        if (event.key === "Escape") setOpen(false);
      });
    });
  });
</script>
