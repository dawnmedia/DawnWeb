---
import { getImage } from "astro:assets";
import { OG, SITE } from "@data/constants";
import faviconSvgSrc from "@images/icon.svg";
import faviconSrc from "@images/icon.png";
import {
  createAlternateLinks,
  getLocaleFromPath,
  localizePath,
  OPEN_GRAPH_LOCALES,
} from "@utils/locale";
import {
  absoluteUrl,
  buildOrganizationSchema,
  buildWebPageSchema,
  normalizePath,
} from "@utils/seo";
import type { ImageMetadata } from "astro";

// Default properties for the Meta component. These values are used if props are not provided.
// 'meta' sets a default description meta tag to describe the page content.
// 'structuredData' defines optional JSON-LD data to enhance search engine understanding of the page.
const defaultProps = {
  meta: SITE.description,
};

// Extract props with default values assigned from defaultProps. Values can be overridden when the component is used.
// For example:
// <MainLayout title="Custom Title" meta="Custom description." />
const {
  title,
  meta = defaultProps.meta,
  structuredData: structuredDataProp,
  socialImage: socialImageProp = OG.image,
  canonicalPath,
  ogType = "website",
  noindex = false,
} = Astro.props;

interface Props {
  title?: string;
  meta?: string;
  structuredData?: object | object[];
  socialImage?: ImageMetadata | string;
  canonicalPath?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
}

// Define the metadata for your website and individual pages
const siteUrl = `${Astro.site ?? SITE.url}`.replace(/\/$/, ""); // Set the website URL in astro.config.mjs
const author = SITE.author;
const fullPath: string = normalizePath(canonicalPath ?? Astro.url.pathname);
const currentLocale = getLocaleFromPath(fullPath);
const canonical = absoluteUrl(fullPath, siteUrl);
const ogTitle = title ?? OG.title;
const ogDescription = meta ?? OG.description;
const socialImage =
  typeof socialImageProp === "string"
    ? new globalThis.URL(socialImageProp, siteUrl).toString()
    : `${siteUrl}${
        (
          await getImage({
            src: socialImageProp,
            width: 1200,
            height: 600,
          })
        ).src
      }`;
const socialImageType = socialImage.endsWith(".avif")
  ? "image/avif"
  : socialImage.endsWith(".webp")
    ? "image/webp"
    : socialImage.endsWith(".svg")
      ? "image/svg+xml"
      : socialImage.endsWith(".jpg") || socialImage.endsWith(".jpeg")
        ? "image/jpeg"
        : "image/png";
const twitterDomain = new globalThis.URL(siteUrl).hostname;
const defaultStructuredData = buildWebPageSchema({
  title: ogTitle,
  description: ogDescription,
  pathname: fullPath,
  locale: currentLocale,
  siteUrl,
});
const pageStructuredData = structuredDataProp
  ? Array.isArray(structuredDataProp)
    ? structuredDataProp
    : [structuredDataProp]
  : [defaultStructuredData];
const structuredData = [
  buildOrganizationSchema(siteUrl),
  ...pageStructuredData,
];

const alternateLanguageLinks: string = [
  ...createAlternateLinks(fullPath, siteUrl).map(
    ({ hreflang, href }) =>
      `<link rel="alternate" hreflang="${hreflang}" href="${href}" />`,
  ),
  `<link rel="alternate" hreflang="x-default" href="${absoluteUrl(localizePath(fullPath, "en"), siteUrl)}" />`,
].join("\n");

// Generate and optimize the favicon images
const faviconSvg = await getImage({
  src: faviconSvgSrc,
  format: "svg",
});

const appleTouchIcon = await getImage({
  src: faviconSrc,
  width: 180,
  height: 180,
  format: "png",
});
---

<!-- Inject structured data into the page if provided. This data is formatted as JSON-LD, a method recommended by Google for structured data pass:
     https://developers.google.com/search/docs/advanced/structured-data/intro-structured-data -->{
  structuredData.map((schema) => (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(schema)}
    />
  ))
}
<!-- Define the character set, description, author, and viewport settings -->
<meta charset="utf-8" />
<meta content={meta} name="description" />
{noindex && <meta name="robots" content="noindex,follow" />}
<meta name="web_author" content={author} />
<meta
  name="viewport"
  content="width=device-width, initial-scale=1.0, maximum-scale=5.0, minimum-scale=1.0"
/>
<meta http-equiv="X-UA-Compatible" content="ie=edge" />
<link rel="canonical" href={canonical} />
<Fragment set:html={alternateLanguageLinks} />

<!-- Facebook Meta Tags -->
<meta property="og:locale" content={OPEN_GRAPH_LOCALES[currentLocale]} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content={ogType} />
<meta property="og:title" content={ogTitle} />
<meta property="og:site_name" content={SITE.title} />
<meta property="og:description" content={ogDescription} />
<meta property="og:image" content={socialImage} />
<meta content="1200" property="og:image:width" />
<meta content="600" property="og:image:height" />
<meta content={socialImageType} property="og:image:type" />

<!-- Twitter Meta Tags -->
<meta name="twitter:card" content="summary_large_image" />
<meta property="twitter:domain" content={twitterDomain} />
<meta property="twitter:url" content={canonical} />
<meta name="twitter:title" content={ogTitle} />
<meta name="twitter:description" content={ogDescription} />
<meta name="twitter:image" content={socialImage} />

<!-- Links to the webmanifest and sitemap -->
<link rel="manifest" href="/manifest.json" />
<!-- https://docs.astro.build/en/guides/integrations-guide/sitemap/ -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Links for favicons -->
<link href="/favicon.ico" rel="icon" sizes="any" type="image/x-icon" />
<link href={faviconSvg.src} rel="icon" type="image/svg+xml" sizes="any" />
<meta name="mobile-web-app-capable" content="yes" />
<link href={appleTouchIcon.src} rel="apple-touch-icon" />
<link href={appleTouchIcon.src} rel="shortcut icon" />
<!-- Set theme color -->
<meta name="theme-color" content="#facc15" />
