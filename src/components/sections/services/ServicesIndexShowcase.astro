---
import { Image } from "astro:assets";
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import SecondaryCTA from "@components/ui/buttons/SecondaryCTA.astro";
import type { ImageMetadata } from "astro";

const {
  eyebrow,
  title,
  subTitle,
  primaryCta,
  primaryCtaUrl,
  secondaryCta,
  secondaryCtaUrl,
  proofPoints,
  services,
  processEyebrow = "Process",
  processTitle,
  processSubTitle,
  processSteps,
  portfolioEyebrow = "Proof",
  portfolioTitle,
  portfolioSubTitle,
  portfolioItems,
  faqTitle,
  faqs,
  finalTitle,
  finalText,
  finalCta,
  finalCtaUrl,
} = Astro.props;

interface ServiceItem {
  title: string;
  href: string;
  description: string;
  outcome: string;
  bestFor: string;
  deliverables: string[];
  image: ImageMetadata;
  imageAlt: string;
}

interface ProcessStep {
  title: string;
  description: string;
}

interface PortfolioItem {
  title: string;
  href: string;
  description: string;
  image: ImageMetadata;
  imageAlt: string;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  eyebrow: string;
  title: string;
  subTitle: string;
  primaryCta: string;
  primaryCtaUrl: string;
  secondaryCta: string;
  secondaryCtaUrl: string;
  proofPoints: string[];
  services: ServiceItem[];
  processEyebrow?: string;
  processTitle: string;
  processSubTitle: string;
  processSteps: ProcessStep[];
  portfolioEyebrow?: string;
  portfolioTitle: string;
  portfolioSubTitle: string;
  portfolioItems: PortfolioItem[];
  faqTitle: string;
  faqs: FaqItem[];
  finalTitle: string;
  finalText: string;
  finalCta: string;
  finalCtaUrl: string;
}
---

<section
  class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
>
  <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_24rem] lg:items-end">
    <div class="max-w-4xl">
      <p class="text-sm font-bold uppercase tracking-normal text-blue-600 dark:text-blue-300">
        {eyebrow}
      </p>
      <h1
        class="mt-3 text-balance text-4xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-6xl"
      >
        {title}
      </h1>
      <p class="mt-4 max-w-3xl text-pretty text-lg leading-8 text-neutral-700 dark:text-neutral-300">
        {subTitle}
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <PrimaryCTA title={primaryCta} url={primaryCtaUrl} />
        <SecondaryCTA title={secondaryCta} url={secondaryCtaUrl} />
      </div>
    </div>

    <div class="grid gap-3">
      {
        proofPoints.map((point) => (
          <div class="rounded-lg border border-neutral-300 bg-neutral-100 px-4 py-3 text-sm font-bold text-neutral-800 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-200">
            {point}
          </div>
        ))
      }
    </div>
  </div>
</section>

<section
  class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
>
  <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
    {
      services.map((service) => (
        <a
          href={service.href}
          class="group flex h-full flex-col overflow-hidden rounded-lg border border-neutral-300 bg-neutral-100 outline-none ring-zinc-500 transition duration-300 hover:border-blue-400 hover:bg-neutral-50 focus-visible:ring dark:border-neutral-700 dark:bg-neutral-800 dark:ring-zinc-200 dark:hover:border-blue-400 dark:hover:bg-neutral-800/70"
        >
          <div class="aspect-[4/3] overflow-hidden bg-neutral-300 dark:bg-neutral-900">
            <Image
              src={service.image}
              alt={service.imageAlt}
              class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
              format="avif"
              loading="lazy"
            />
          </div>
          <div class="flex flex-1 flex-col p-5">
            <h2 class="text-xl font-bold text-neutral-800 dark:text-neutral-200">
              {service.title}
            </h2>
            <p class="mt-3 text-sm font-bold leading-6 text-blue-600 dark:text-blue-300">
              {service.outcome}
            </p>
            <p class="mt-3 text-sm leading-6 text-neutral-700 dark:text-neutral-400">
              {service.description}
            </p>
            <div class="mt-5 border-t border-neutral-300 pt-4 dark:border-neutral-700">
              <p class="text-xs font-bold uppercase tracking-normal text-neutral-500 dark:text-neutral-400">
                {service.bestFor}
              </p>
              <ul class="mt-3 space-y-2">
                {
                  service.deliverables.slice(0, 3).map((deliverable) => (
                    <li class="text-sm leading-6 text-neutral-700 dark:text-neutral-300">
                      {deliverable}
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </a>
      ))
    }
  </div>
</section>

<section
  class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
>
  <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
    <div>
      <p class="text-sm font-bold uppercase tracking-normal text-blue-600 dark:text-blue-300">
        {processEyebrow}
      </p>
      <h2 class="mt-3 text-balance text-3xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl">
        {processTitle}
      </h2>
      <p class="mt-4 text-pretty leading-7 text-neutral-700 dark:text-neutral-400">
        {processSubTitle}
      </p>
    </div>
    <div class="grid gap-4 md:grid-cols-2">
      {
        processSteps.map((step, index) => (
          <div class="rounded-lg border border-neutral-300 bg-neutral-100 p-5 dark:border-neutral-700 dark:bg-neutral-800">
            <p class="text-sm font-bold text-blue-600 dark:text-blue-300">
              0{index + 1}
            </p>
            <h3 class="mt-3 text-lg font-bold text-neutral-800 dark:text-neutral-200">
              {step.title}
            </h3>
            <p class="mt-3 text-sm leading-6 text-neutral-700 dark:text-neutral-400">
              {step.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<section
  class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
>
  <div class="max-w-3xl">
    <p class="text-sm font-bold uppercase tracking-normal text-blue-600 dark:text-blue-300">
      {portfolioEyebrow}
    </p>
    <h2 class="mt-3 text-balance text-3xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl">
      {portfolioTitle}
    </h2>
    <p class="mt-4 text-pretty leading-7 text-neutral-700 dark:text-neutral-400">
      {portfolioSubTitle}
    </p>
  </div>

  <div class="mt-8 grid gap-5 md:grid-cols-3">
    {
      portfolioItems.map((item) => (
        <a
          href={item.href}
          class="group overflow-hidden rounded-lg border border-neutral-300 bg-neutral-100 outline-none ring-zinc-500 transition duration-300 hover:border-blue-400 hover:bg-neutral-50 focus-visible:ring dark:border-neutral-700 dark:bg-neutral-800 dark:ring-zinc-200 dark:hover:border-blue-400 dark:hover:bg-neutral-800/70"
        >
          <div class="aspect-[16/10] overflow-hidden bg-neutral-300 dark:bg-neutral-900">
            <Image
              src={item.image}
              alt={item.imageAlt}
              class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
              format="avif"
              loading="lazy"
            />
          </div>
          <div class="p-5">
            <h3 class="text-xl font-bold text-neutral-800 dark:text-neutral-200">
              {item.title}
            </h3>
            <p class="mt-3 text-sm leading-6 text-neutral-700 dark:text-neutral-400">
              {item.description}
            </p>
          </div>
        </a>
      ))
    }
  </div>
</section>

<section
  class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
>
  <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
    <h2 class="text-balance text-3xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl">
      {faqTitle}
    </h2>
    <div class="divide-y divide-neutral-300 border-y border-neutral-300 dark:divide-neutral-700 dark:border-neutral-700">
      {
        faqs.map((faq) => (
          <section class="py-5">
            <h3 class="text-lg font-bold text-neutral-800 dark:text-neutral-200">
              {faq.question}
            </h3>
            <p class="mt-2 leading-7 text-neutral-700 dark:text-neutral-400">
              {faq.answer}
            </p>
          </section>
        ))
      }
    </div>
  </div>
</section>

<section
  class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
>
  <div class="rounded-lg bg-neutral-900 p-6 text-neutral-50 dark:bg-neutral-950 md:p-10">
    <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
      <div>
        <h2 class="text-balance text-3xl font-bold md:text-4xl">
          {finalTitle}
        </h2>
        <p class="mt-3 max-w-3xl text-pretty text-neutral-300">
          {finalText}
        </p>
      </div>
      <PrimaryCTA title={finalCta} url={finalCtaUrl} />
    </div>
  </div>
</section>
