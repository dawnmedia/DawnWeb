---
import { Image } from "astro:assets";
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import SecondaryCTA from "@components/ui/buttons/SecondaryCTA.astro";
import type { ImageMetadata } from "astro";

const {
  eyebrow,
  title,
  subTitle,
  primaryCta,
  primaryCtaUrl,
  secondaryCta,
  secondaryCtaUrl,
  proofPoints,
  services,
  processEyebrow = "Process",
  processTitle,
  processSubTitle,
  processSteps,
  portfolioEyebrow = "Proof",
  portfolioTitle,
  portfolioSubTitle,
  portfolioItems,
  faqTitle,
  faqs,
  finalTitle,
  finalText,
  finalCta,
  finalCtaUrl,
} = Astro.props;

interface ServiceItem {
  title: string;
  href: string;
  description: string;
  outcome: string;
  bestFor: string;
  deliverables: string[];
  image: ImageMetadata;
  imageAlt: string;
}

interface ProcessStep {
  title: string;
  description: string;
}

interface PortfolioItem {
  title: string;
  href: string;
  description: string;
  image: ImageMetadata;
  imageAlt: string;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  eyebrow: string;
  title: string;
  subTitle: string;
  primaryCta: string;
  primaryCtaUrl: string;
  secondaryCta: string;
  secondaryCtaUrl: string;
  proofPoints: string[];
  services: ServiceItem[];
  processEyebrow?: string;
  processTitle: string;
  processSubTitle: string;
  processSteps: ProcessStep[];
  portfolioEyebrow?: string;
  portfolioTitle: string;
  portfolioSubTitle: string;
  portfolioItems: PortfolioItem[];
  faqTitle: string;
  faqs: FaqItem[];
  finalTitle: string;
  finalText: string;
  finalCta: string;
  finalCtaUrl: string;
}
---

<div class="relative isolate -mt-28 flex min-h-[calc(100vh+3rem)] flex-col overflow-hidden bg-neutral-50 pt-28 text-neutral-900 dark:bg-neutral-950 dark:text-white sm:-mt-32 sm:pt-32">
  <div class="absolute inset-0 -z-10 bg-[linear-gradient(135deg,#f8fafc_0%,#f1f5f9_54%,#e2e8f0_100%)] dark:bg-[linear-gradient(135deg,#0f172a_0%,#111111_54%,#050505_100%)]"></div>

  <!-- Hero Section -->
  <section class="mx-auto w-full max-w-[85rem] px-4 py-12 sm:px-6 lg:px-8 lg:py-16 mt-8">
    <div class="grid min-w-0 gap-8 lg:grid-cols-[minmax(0,1fr)_20rem] lg:items-end">
      <div class="min-w-0 max-w-4xl">
        <p class="text-sm font-bold uppercase tracking-normal text-blue-600 dark:text-blue-300">
          {eyebrow}
        </p>
        <h1 class="mt-3 break-words text-balance text-4xl font-bold tracking-tight text-neutral-900 dark:text-neutral-50 md:text-6xl">
          {title}
        </h1>
        <p class="mt-5 max-w-3xl break-words text-pretty text-lg leading-8 text-neutral-600 dark:text-neutral-300">
          {subTitle}
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <PrimaryCTA title={primaryCta} url={primaryCtaUrl} />
          <SecondaryCTA title={secondaryCta} url={secondaryCtaUrl} />
        </div>
      </div>

      <div class="grid gap-3 min-w-0 shrink-0 lg:justify-self-end w-full">
        {
          proofPoints.map((point) => (
            <div class="flex items-center gap-3 rounded-xl border border-neutral-200 bg-white/50 px-4 py-3 text-sm font-bold text-neutral-800 backdrop-blur-sm transition hover:bg-white/80 dark:border-neutral-800 dark:bg-neutral-900/50 dark:text-neutral-200 dark:hover:bg-neutral-900/80">
              <svg class="h-5 w-5 shrink-0 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
              {point}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="mx-auto w-full max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {
        services.map((service) => (
          <a
            href={service.href}
            class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-neutral-200 bg-white/40 outline-none backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-blue-400 hover:shadow-xl hover:shadow-blue-900/10 focus-visible:ring dark:border-neutral-800 dark:bg-neutral-900/40 dark:hover:border-blue-500/50 dark:hover:shadow-blue-900/20"
          >
            <div class="relative aspect-[4/3] overflow-hidden bg-neutral-200 dark:bg-neutral-900">
              <Image
                src={service.image}
                alt={service.imageAlt}
                class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
                format="avif"
                loading="lazy"
                width={520}
                sizes="(min-width: 1280px) 25vw, (min-width: 768px) 50vw, 100vw"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/80 via-neutral-900/20 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
            </div>
            <div class="flex flex-1 flex-col p-6">
              <h2 class="text-xl font-bold text-neutral-900 transition-colors group-hover:text-blue-600 dark:text-neutral-100 dark:group-hover:text-blue-400">
                {service.title}
              </h2>
              <p class="mt-2 text-sm font-bold leading-6 text-blue-600 dark:text-blue-400">
                {service.outcome}
              </p>
              <p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">
                {service.description}
              </p>
              <div class="mt-auto pt-6">
                <div class="border-t border-neutral-200 pt-4 dark:border-neutral-800">
                  <p class="text-xs font-bold uppercase tracking-normal text-neutral-500 dark:text-neutral-500">
                    {service.bestFor}
                  </p>
                  <ul class="mt-3 flex flex-col gap-2">
                    {
                      service.deliverables.slice(0, 3).map((deliverable) => (
                        <li class="flex items-start gap-2 text-sm text-neutral-600 dark:text-neutral-400">
                          <svg class="mt-0.5 h-4 w-4 shrink-0 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                          </svg>
                          {deliverable}
                        </li>
                      ))
                    }
                  </ul>
                </div>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Process -->
  <section class="mx-auto w-full max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="text-sm font-bold uppercase tracking-normal text-blue-600 dark:text-blue-400">
          {processEyebrow}
        </p>
        <h2 class="mt-3 text-balance text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-50 md:text-4xl">
          {processTitle}
        </h2>
        <p class="mt-4 text-pretty leading-7 text-neutral-600 dark:text-neutral-400">
          {processSubTitle}
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {
          processSteps.map((step, index) => (
            <div class="relative flex flex-col overflow-hidden rounded-2xl border border-neutral-200 bg-white/40 p-6 backdrop-blur-sm transition-all hover:-translate-y-1 hover:shadow-lg hover:shadow-blue-900/5 dark:border-neutral-800 dark:bg-neutral-900/40 dark:hover:shadow-blue-900/20">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-blue-100 text-lg font-bold text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
                0{index + 1}
              </div>
              <h3 class="text-lg font-bold text-neutral-900 dark:text-neutral-100">
                {step.title}
              </h3>
              <p class="mt-2 text-sm leading-6 text-neutral-600 dark:text-neutral-400">
                {step.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Portfolio -->
  <section class="mx-auto w-full max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <div class="max-w-3xl">
      <p class="text-sm font-bold uppercase tracking-normal text-blue-600 dark:text-blue-400">
        {portfolioEyebrow}
      </p>
      <h2 class="mt-3 text-balance text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-50 md:text-4xl">
        {portfolioTitle}
      </h2>
      <p class="mt-4 text-pretty leading-7 text-neutral-600 dark:text-neutral-400">
        {portfolioSubTitle}
      </p>
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-3">
      {
        portfolioItems.map((item) => (
          <a
            href={item.href}
            class="group relative overflow-hidden rounded-2xl border border-neutral-200 bg-white/40 outline-none backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-blue-400 hover:shadow-xl hover:shadow-blue-900/10 focus-visible:ring dark:border-neutral-800 dark:bg-neutral-900/40 dark:hover:border-blue-500/50 dark:hover:shadow-blue-900/20"
          >
            <div class="aspect-[16/10] overflow-hidden bg-neutral-200 dark:bg-neutral-900">
              <Image
                src={item.image}
                alt={item.imageAlt}
                class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
                format="avif"
                loading="lazy"
                width={640}
                sizes="(min-width: 768px) 33vw, 100vw"
              />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-neutral-900 transition-colors group-hover:text-blue-600 dark:text-neutral-100 dark:group-hover:text-blue-400">
                {item.title}
              </h3>
              <p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">
                {item.description}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- FAQs -->
  <section class="mx-auto w-full max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
      <h2 class="text-balance text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-50 md:text-4xl">
        {faqTitle}
      </h2>
      <div class="flex flex-col gap-4">
        {
          faqs.map((faq) => (
            <div class="rounded-2xl border border-neutral-200 bg-white/40 p-6 backdrop-blur-sm dark:border-neutral-800 dark:bg-neutral-900/40">
              <h3 class="text-lg font-bold text-neutral-900 dark:text-neutral-100">
                {faq.question}
              </h3>
              <p class="mt-2 leading-7 text-neutral-600 dark:text-neutral-400">
                {faq.answer}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="mx-auto w-full max-w-[85rem] px-4 py-10 pb-24 sm:px-6 lg:px-8 lg:py-14 lg:pb-32">
    <div class="relative overflow-hidden rounded-3xl bg-neutral-900 p-8 text-neutral-50 shadow-2xl border border-neutral-800 dark:bg-neutral-950 md:p-12">
      <div class="absolute inset-0 opacity-40">
        <div class="absolute -left-1/4 -top-1/4 h-full w-full rounded-full bg-blue-600/30 blur-[120px]"></div>
        <div class="absolute -bottom-1/4 -right-1/4 h-full w-full rounded-full bg-yellow-400/20 blur-[120px]"></div>
      </div>
      <div class="relative z-10 grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
        <div>
          <h2 class="text-balance text-3xl font-bold md:text-4xl">
            {finalTitle}
          </h2>
          <p class="mt-4 max-w-2xl text-pretty text-lg text-neutral-300">
            {finalText}
          </p>
        </div>
        <div class="shrink-0">
          <PrimaryCTA title={finalCta} url={finalCtaUrl} />
        </div>
      </div>
    </div>
  </section>
</div>
