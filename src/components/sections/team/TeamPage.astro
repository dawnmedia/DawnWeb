---
import { Image } from "astro:assets";
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import SecondaryCTA from "@components/ui/buttons/SecondaryCTA.astro";
import Icon from "@components/ui/icons/Icon.astro";
import heroVisual from "@images/services/web-design.jpg";
import type { Locale } from "@utils/locale";
import type { TeamMember, TeamPageContent } from "@data/team";

const { locale, content, members } = Astro.props;

interface Props {
  locale: Locale;
  content: TeamPageContent;
  members: TeamMember[];
}

const proofIcons = ["guides", "sparks", "hammer", "rocket"];
const processIcons = ["question", "chatBubble", "checkCircle"];

const socialLabels: Record<
  Locale,
  { portfolio: string; instagram: string; github: string; photo: string }
> = {
  en: {
    portfolio: "Portfolio",
    instagram: "Instagram",
    github: "GitHub",
    photo: "Photo of",
  },
  fr: {
    portfolio: "Portfolio",
    instagram: "Instagram",
    github: "GitHub",
    photo: "Photo de",
  },
  br: {
    portfolio: "Portfólio",
    instagram: "Instagram",
    github: "GitHub",
    photo: "Foto de",
  },
  ko: {
    portfolio: "포트폴리오",
    instagram: "Instagram",
    github: "GitHub",
    photo: "사진:",
  },
  ja: {
    portfolio: "ポートフォリオ",
    instagram: "Instagram",
    github: "GitHub",
    photo: "写真:",
  },
  es: {
    portfolio: "Portafolio",
    instagram: "Instagram",
    github: "GitHub",
    photo: "Foto de",
  },
};

const labels = socialLabels[locale];
---

<div class="relative isolate -mt-28 flex min-h-[calc(100vh+3rem)] flex-col overflow-hidden bg-neutral-50 pt-28 text-neutral-900 dark:bg-neutral-950 dark:text-white sm:-mt-32 sm:pt-32">
  <div class="absolute inset-0 -z-10 bg-[linear-gradient(135deg,#f8fafc_0%,#f1f5f9_54%,#e2e8f0_100%)] dark:bg-[linear-gradient(135deg,#0f172a_0%,#111111_54%,#050505_100%)]"></div>

  <section class="mx-auto grid w-full max-w-[85rem] gap-10 px-4 py-14 sm:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:px-8 lg:py-20 mt-8">
    <div>
      <p class="text-sm font-bold uppercase tracking-normal text-blue-600 dark:text-blue-300">
        {content.eyebrow}
      </p>
      <h1 class="mt-4 max-w-4xl text-balance text-4xl font-extrabold leading-tight tracking-normal text-neutral-900 dark:text-neutral-50 sm:text-5xl lg:text-6xl">
        {content.title}
      </h1>
      <p class="mt-5 max-w-2xl text-pretty text-lg leading-8 text-neutral-600 dark:text-neutral-300">
        {content.description}
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <PrimaryCTA title={content.primaryCta} url={content.primaryCtaUrl} />
        <SecondaryCTA title={content.secondaryCta} url={content.secondaryCtaUrl} />
      </div>

      <dl class="mt-10 grid gap-3 sm:grid-cols-3">
        {
          content.stats.map((stat) => (
            <div class="border-l-2 border-blue-400 pl-4 dark:border-blue-400">
              <dt class="text-2xl font-extrabold text-neutral-900 dark:text-neutral-50">
                {stat.value}
              </dt>
              <dd class="mt-1 text-sm leading-5 text-neutral-600 dark:text-neutral-400">
                {stat.label}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white/40 backdrop-blur-sm dark:border-neutral-800 dark:bg-neutral-900/40">
      <Image
        src={heroVisual}
        alt={content.heroImageAlt}
        class="aspect-[4/3] w-full object-cover object-center"
        loading="eager"
        format="avif"
        width={900}
        sizes="(min-width: 1024px) 46vw, 100vw"
        fetchpriority="high"
      />
      <div class="border-t border-neutral-200 p-6 dark:border-neutral-800">
        <p class="text-sm font-semibold uppercase tracking-normal text-neutral-500 dark:text-neutral-400">
          {content.proofTitle}
        </p>
        <p class="mt-2 text-pretty text-sm leading-6 text-neutral-700 dark:text-neutral-300">
          {content.proofDescription}
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-[85rem] px-4 pb-14 sm:px-6 lg:px-8">
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {
        content.proofPoints.map((point, index) => (
          <article class="group rounded-2xl border border-neutral-200 bg-white/40 p-6 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-blue-400 hover:shadow-xl hover:shadow-blue-900/5 dark:border-neutral-800 dark:bg-neutral-900/40 dark:hover:border-blue-500/50 dark:hover:shadow-blue-900/20">
            <div class="mb-5 flex size-12 items-center justify-center rounded-xl bg-blue-100 text-blue-600 transition-colors group-hover:bg-blue-600 group-hover:text-white dark:bg-blue-900/30 dark:text-blue-400 dark:group-hover:bg-blue-500 dark:group-hover:text-white">
              <Icon name={proofIcons[index] ?? "checkCircle"} class="size-6" />
            </div>
            <h2 class="text-lg font-bold text-neutral-900 dark:text-neutral-100">
              {point.title}
            </h2>
            <p class="mt-2 text-pretty text-sm leading-6 text-neutral-600 dark:text-neutral-400">
              {point.description}
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mx-auto w-full max-w-[85rem] px-4 py-14 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <p class="text-sm font-bold uppercase tracking-normal text-blue-600 dark:text-blue-300">
        {content.teamEyebrow}
      </p>
      <h2 class="mt-3 text-balance text-3xl font-extrabold text-neutral-900 dark:text-neutral-50 md:text-4xl">
        {content.teamTitle}
      </h2>
      <p class="mt-4 text-pretty text-lg leading-8 text-neutral-600 dark:text-neutral-300">
        {content.teamDescription}
      </p>
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {
        members.map((member) => (
          <article class="group overflow-hidden rounded-2xl border border-neutral-200 bg-white/40 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-blue-400 hover:shadow-xl hover:shadow-blue-900/5 dark:border-neutral-800 dark:bg-neutral-900/40 dark:hover:border-blue-500/50 dark:hover:shadow-blue-900/20">
            <div class="relative overflow-hidden bg-neutral-200 dark:bg-neutral-900">
              <Image
                src={member.image}
                alt={`${labels.photo} ${member.name}`}
                class="aspect-[5/4] w-full object-cover object-center transition duration-700 group-hover:scale-105"
                loading="lazy"
                format="avif"
                width={640}
                sizes="(min-width: 1024px) 33vw, 100vw"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-neutral-900/80 via-neutral-900/20 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-extrabold text-neutral-900 transition-colors group-hover:text-blue-600 dark:text-neutral-100 dark:group-hover:text-blue-400">
                <a
                  href={member.portfolio}
                  rel="noopener noreferrer"
                  target="_blank"
                  class="outline-none focus-visible:ring-2 focus-visible:ring-blue-500 rounded"
                >
                  {member.name}
                </a>
              </h3>
              <p class="mt-1 text-sm font-semibold text-blue-600 dark:text-blue-400">
                {member.role}
              </p>
              <p class="mt-4 text-pretty text-sm leading-6 text-neutral-600 dark:text-neutral-400">
                {member.bio}
              </p>
              <div class="mt-6 flex gap-3 border-t border-neutral-200 pt-5 dark:border-neutral-800">
                <a
                  href={member.portfolio}
                  rel="noopener noreferrer"
                  target="_blank"
                  aria-label={`${member.name} ${labels.portfolio}`}
                  class="inline-flex size-10 items-center justify-center rounded-xl bg-neutral-100/50 text-neutral-600 transition hover:bg-blue-100 hover:text-blue-600 dark:bg-neutral-800/50 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-blue-400"
                >
                  <Icon name="openInNew" class="size-4" />
                </a>
                <a
                  href={member.instagram}
                  rel="noopener noreferrer"
                  target="_blank"
                  aria-label={`${member.name} ${labels.instagram}`}
                  class="inline-flex size-10 items-center justify-center rounded-xl bg-neutral-100/50 text-neutral-600 transition hover:bg-blue-100 hover:text-blue-600 dark:bg-neutral-800/50 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-blue-400"
                >
                  <Icon name="instagram" class="size-4" />
                </a>
                <a
                  href={member.github}
                  rel="noopener noreferrer"
                  target="_blank"
                  aria-label={`${member.name} ${labels.github}`}
                  class="inline-flex size-10 items-center justify-center rounded-xl bg-neutral-100/50 text-neutral-600 transition hover:bg-blue-100 hover:text-blue-600 dark:bg-neutral-800/50 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-blue-400"
                >
                  <Icon name="github" class="size-4" />
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mx-auto w-full max-w-[85rem] px-4 py-14 sm:px-6 lg:px-8">
    <div class="grid gap-10 border-y border-neutral-200 py-12 dark:border-neutral-800 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div>
        <p class="text-sm font-bold uppercase tracking-normal text-blue-600 dark:text-blue-300">
          {content.processEyebrow}
        </p>
        <h2 class="mt-3 text-balance text-3xl font-extrabold text-neutral-900 dark:text-neutral-50 md:text-4xl">
          {content.processTitle}
        </h2>
        <p class="mt-4 text-pretty text-lg leading-8 text-neutral-600 dark:text-neutral-300">
          {content.processDescription}
        </p>
      </div>

      <div class="grid gap-4">
        {
          content.processItems.map((item, index) => (
            <article class="flex gap-5 rounded-2xl border border-neutral-200 bg-white/40 p-6 backdrop-blur-sm transition hover:bg-white/80 dark:border-neutral-800 dark:bg-neutral-900/40 dark:hover:bg-neutral-900/80">
              <div class="flex size-12 shrink-0 items-center justify-center rounded-xl bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
                <Icon
                  name={processIcons[index] ?? "checkCircle"}
                  class="size-6"
                />
              </div>
              <div>
                <h3 class="text-lg font-bold text-neutral-900 dark:text-neutral-100">
                  {item.title}
                </h3>
                <p class="mt-2 text-pretty text-sm leading-6 text-neutral-600 dark:text-neutral-400">
                  {item.description}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-[85rem] px-4 pb-24 pt-8 sm:px-6 lg:px-8 lg:pb-32">
    <div class="relative overflow-hidden rounded-3xl bg-neutral-900 p-8 text-neutral-50 shadow-2xl border border-neutral-800 dark:bg-neutral-950 md:p-12">
      <div class="absolute inset-0 opacity-40">
        <div class="absolute -left-1/4 -top-1/4 h-full w-full rounded-full bg-blue-600/30 blur-[120px]"></div>
        <div class="absolute -bottom-1/4 -right-1/4 h-full w-full rounded-full bg-yellow-400/20 blur-[120px]"></div>
      </div>
      <div class="relative z-10 flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
        <div class="max-w-2xl">
          <h2 class="text-balance text-3xl font-extrabold md:text-4xl">
            {content.ctaTitle}
          </h2>
          <p class="mt-4 text-pretty leading-7 text-neutral-300">
            {content.ctaDescription}
          </p>
        </div>
        <div class="shrink-0">
          <PrimaryCTA title={content.ctaLabel} url={content.ctaUrl} />
        </div>
      </div>
    </div>
  </section>
</div>
