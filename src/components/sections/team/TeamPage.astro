---
import { Image } from "astro:assets";
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import SecondaryCTA from "@components/ui/buttons/SecondaryCTA.astro";
import Icon from "@components/ui/icons/Icon.astro";
import heroVisual from "@images/web-design.jpg";
import type { Locale } from "@utils/locale";
import type { TeamMember, TeamPageContent } from "@data/team";

const { locale, content, members } = Astro.props;

interface Props {
  locale: Locale;
  content: TeamPageContent;
  members: TeamMember[];
}

const proofIcons = ["guides", "sparks", "hammer", "rocket"];
const processIcons = ["question", "chatBubble", "checkCircle"];

const socialLabels: Record<
  Locale,
  { portfolio: string; instagram: string; github: string; photo: string }
> = {
  en: {
    portfolio: "Portfolio",
    instagram: "Instagram",
    github: "GitHub",
    photo: "Photo of",
  },
  fr: {
    portfolio: "Portfolio",
    instagram: "Instagram",
    github: "GitHub",
    photo: "Photo de",
  },
  br: {
    portfolio: "Portfólio",
    instagram: "Instagram",
    github: "GitHub",
    photo: "Foto de",
  },
};

const labels = socialLabels[locale];
---

<section
  class="mx-auto grid max-w-[85rem] gap-10 px-4 py-14 sm:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:px-8 lg:py-20 2xl:max-w-full"
>
  <div>
    <p
      class="text-sm font-bold uppercase tracking-normal text-blue-500 dark:text-blue-300"
    >
      {content.eyebrow}
    </p>
    <h1
      class="mt-4 max-w-4xl text-balance text-4xl font-extrabold leading-tight tracking-normal text-neutral-800 dark:text-neutral-200 sm:text-5xl lg:text-6xl"
    >
      {content.title}
    </h1>
    <p
      class="mt-5 max-w-2xl text-pretty text-lg leading-8 text-neutral-600 dark:text-neutral-400"
    >
      {content.description}
    </p>

    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <PrimaryCTA title={content.primaryCta} url={content.primaryCtaUrl} />
      <SecondaryCTA
        title={content.secondaryCta}
        url={content.secondaryCtaUrl}
      />
    </div>

    <dl class="mt-10 grid gap-3 sm:grid-cols-3">
      {
        content.stats.map((stat) => (
          <div class="border-l-2 border-blue-400 pl-4 dark:border-blue-300">
            <dt class="text-2xl font-extrabold text-neutral-800 dark:text-neutral-200">
              {stat.value}
            </dt>
            <dd class="mt-1 text-sm leading-5 text-neutral-600 dark:text-neutral-400">
              {stat.label}
            </dd>
          </div>
        ))
      }
    </dl>
  </div>

  <div
    class="overflow-hidden rounded-lg border border-neutral-300 bg-neutral-100 dark:border-neutral-700 dark:bg-neutral-800"
  >
    <Image
      src={heroVisual}
      alt={content.heroImageAlt}
      class="aspect-[4/3] w-full object-cover object-center"
      loading="eager"
      format="avif"
      width={900}
      sizes="(min-width: 1024px) 46vw, 100vw"
      fetchpriority="high"
    />
    <div class="border-t border-neutral-300 p-5 dark:border-neutral-700">
      <p
        class="text-sm font-semibold uppercase tracking-normal text-neutral-500 dark:text-neutral-400"
      >
        {content.proofTitle}
      </p>
      <p
        class="mt-2 text-pretty text-sm leading-6 text-neutral-700 dark:text-neutral-300"
      >
        {content.proofDescription}
      </p>
    </div>
  </div>
</section>

<section
  class="mx-auto max-w-[85rem] px-4 pb-14 sm:px-6 lg:px-8 2xl:max-w-full"
>
  <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-4">
    {
      content.proofPoints.map((point, index) => (
        <article class="rounded-lg border border-neutral-300 bg-neutral-100 p-5 transition hover:border-blue-400 hover:bg-neutral-50 dark:border-neutral-700 dark:bg-neutral-800 dark:hover:border-blue-300 dark:hover:bg-neutral-800/70">
          <div class="mb-5 flex size-10 items-center justify-center rounded-lg bg-blue-400 text-white dark:bg-blue-300 dark:text-blue-900">
            <Icon name={proofIcons[index] ?? "checkCircle"} class="size-5" />
          </div>
          <h2 class="text-lg font-bold text-neutral-800 dark:text-neutral-200">
            {point.title}
          </h2>
          <p class="mt-2 text-pretty text-sm leading-6 text-neutral-600 dark:text-neutral-400">
            {point.description}
          </p>
        </article>
      ))
    }
  </div>
</section>

<section
  class="mx-auto max-w-[85rem] px-4 py-14 sm:px-6 lg:px-8 2xl:max-w-full"
>
  <div class="max-w-3xl">
    <p
      class="text-sm font-bold uppercase tracking-normal text-blue-500 dark:text-blue-300"
    >
      {content.teamEyebrow}
    </p>
    <h2
      class="mt-3 text-balance text-3xl font-extrabold text-neutral-800 dark:text-neutral-200 md:text-4xl"
    >
      {content.teamTitle}
    </h2>
    <p
      class="mt-4 text-pretty text-lg leading-8 text-neutral-600 dark:text-neutral-400"
    >
      {content.teamDescription}
    </p>
  </div>

  <div class="mt-10 grid gap-4 lg:grid-cols-3">
    {
      members.map((member) => (
        <article class="overflow-hidden rounded-lg border border-neutral-300 bg-neutral-100 dark:border-neutral-700 dark:bg-neutral-800">
          <img
            src={member.image}
            alt={`${labels.photo} ${member.name}`}
            class="aspect-[5/4] w-full object-cover object-center"
            loading="lazy"
          />
          <div class="p-5">
            <h3 class="text-xl font-extrabold text-neutral-800 dark:text-neutral-200">
              <a
                href={member.portfolio}
                rel="noopener noreferrer"
                target="_blank"
                class="transition hover:text-blue-500 dark:hover:text-blue-300"
              >
                {member.name}
              </a>
            </h3>
            <p class="mt-1 text-sm font-semibold text-blue-500 dark:text-blue-300">
              {member.role}
            </p>
            <p class="mt-4 text-pretty text-sm leading-6 text-neutral-600 dark:text-neutral-400">
              {member.bio}
            </p>
            <div class="mt-5 flex gap-2">
              <a
                href={member.portfolio}
                rel="noopener noreferrer"
                target="_blank"
                aria-label={`${member.name} ${labels.portfolio}`}
                class="inline-flex size-10 items-center justify-center rounded-lg border border-neutral-300 text-neutral-600 transition hover:border-blue-400 hover:text-blue-500 dark:border-neutral-700 dark:text-neutral-300 dark:hover:border-blue-300 dark:hover:text-blue-300"
              >
                <Icon name="openInNew" class="size-4" />
              </a>
              <a
                href={member.instagram}
                rel="noopener noreferrer"
                target="_blank"
                aria-label={`${member.name} ${labels.instagram}`}
                class="inline-flex size-10 items-center justify-center rounded-lg border border-neutral-300 text-neutral-600 transition hover:border-blue-400 hover:text-blue-500 dark:border-neutral-700 dark:text-neutral-300 dark:hover:border-blue-300 dark:hover:text-blue-300"
              >
                <Icon name="instagram" class="size-4" />
              </a>
              <a
                href={member.github}
                rel="noopener noreferrer"
                target="_blank"
                aria-label={`${member.name} ${labels.github}`}
                class="inline-flex size-10 items-center justify-center rounded-lg border border-neutral-300 text-neutral-600 transition hover:border-blue-400 hover:text-blue-500 dark:border-neutral-700 dark:text-neutral-300 dark:hover:border-blue-300 dark:hover:text-blue-300"
              >
                <Icon name="github" class="size-4" />
              </a>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>

<section
  class="mx-auto max-w-[85rem] px-4 py-14 sm:px-6 lg:px-8 2xl:max-w-full"
>
  <div
    class="grid gap-10 border-y border-neutral-300 py-12 dark:border-neutral-700 lg:grid-cols-[0.9fr_1.1fr] lg:items-start"
  >
    <div>
      <p
        class="text-sm font-bold uppercase tracking-normal text-blue-500 dark:text-blue-300"
      >
        {content.processEyebrow}
      </p>
      <h2
        class="mt-3 text-balance text-3xl font-extrabold text-neutral-800 dark:text-neutral-200 md:text-4xl"
      >
        {content.processTitle}
      </h2>
      <p
        class="mt-4 text-pretty text-lg leading-8 text-neutral-600 dark:text-neutral-400"
      >
        {content.processDescription}
      </p>
    </div>

    <div class="grid gap-4">
      {
        content.processItems.map((item, index) => (
          <article class="flex gap-4 rounded-lg border border-neutral-300 bg-neutral-100 p-5 dark:border-neutral-700 dark:bg-neutral-800">
            <div class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-neutral-200 text-blue-500 dark:bg-neutral-700 dark:text-blue-300">
              <Icon
                name={processIcons[index] ?? "checkCircle"}
                class="size-5"
              />
            </div>
            <div>
              <h3 class="font-bold text-neutral-800 dark:text-neutral-200">
                {item.title}
              </h3>
              <p class="mt-2 text-pretty text-sm leading-6 text-neutral-600 dark:text-neutral-400">
                {item.description}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<section
  class="mx-auto max-w-[85rem] px-4 pb-24 pt-8 sm:px-6 lg:px-8 2xl:max-w-full"
>
  <div
    class="flex flex-col items-start justify-between gap-6 border-t border-neutral-300 pt-10 dark:border-neutral-700 md:flex-row md:items-center"
  >
    <div class="max-w-2xl">
      <h2
        class="text-balance text-3xl font-extrabold text-neutral-800 dark:text-neutral-200 md:text-4xl"
      >
        {content.ctaTitle}
      </h2>
      <p
        class="mt-4 text-pretty leading-7 text-neutral-600 dark:text-neutral-400"
      >
        {content.ctaDescription}
      </p>
    </div>
    <PrimaryCTA title={content.ctaLabel} url={content.ctaUrl} />
  </div>
</section>
