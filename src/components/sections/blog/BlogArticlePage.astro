---
import MainLayout from "@/layouts/MainLayout.astro";
import AvatarBlogLarge from "@components/ui/avatars/AvatarBlogLarge.astro";
import BlogContent from "@components/ui/blocks/BlogContent.astro";
import CardRelated from "@components/ui/cards/CardRelated.astro";
import Bookmark from "@components/ui/buttons/Bookmark.astro";
import SocialShare from "@components/ui/buttons/SocialShare.astro";
import PostFeedback from "@components/ui/feedback/PostFeedback.astro";
import { getImage } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { SITE } from "@data/constants";
import { BLOG_LOCALE_COPY } from "@data/blog";
import { LOCALE_LANGUAGE_TAGS, type Locale } from "@utils/locale";
import { buildArticleSchema } from "@utils/seo";
import { capitalize, formatDate } from "@utils/utils";

interface Props {
  locale: Locale;
  post: CollectionEntry<"blog">;
  relatedPosts: CollectionEntry<"blog">[];
}

const { locale, post, relatedPosts } = Astro.props;
const copy = BLOG_LOCALE_COPY[locale];
const pageTitle = `${post.data.title} | ${SITE.title}`;
const articleImage = `${SITE.url}${
  (
    await getImage({
      src: post.data.cardImage,
      width: 1200,
      height: 630,
    })
  ).src
}`;
---

<MainLayout
  title={pageTitle}
  lang={copy.htmlLang}
  meta={post.data.description}
  socialImage={post.data.cardImage}
  ogType="article"
  structuredData={buildArticleSchema({
    title: post.data.title,
    description: post.data.description,
    pathname: Astro.url.pathname,
    image: articleImage,
    author: post.data.author,
    datePublished: post.data.pubDate,
    locale,
    siteUrl: SITE.url,
  })}
>
  <section class="mx-auto max-w-3xl px-4 pb-12 pt-6 sm:px-6 lg:px-8 lg:pt-10">
    <div class="max-w-2xl">
      <div class="mb-6 flex items-center justify-between">
        <div class="flex w-full gap-x-5 sm:items-center sm:gap-x-3">
          <AvatarBlogLarge blogEntry={post} />
          <div class="grow">
            <div class="flex items-center justify-between gap-x-2">
              <div>
                <span class="font-bold text-neutral-700 dark:text-neutral-300">
                  {post.data.author}
                </span>
                <ul class="text-xs text-neutral-500">
                  <li
                    class="relative inline-block pe-6 before:absolute before:end-2 before:top-1/2 before:size-1 before:-translate-y-1/2 before:rounded-full before:bg-neutral-300 last:pe-0 last-of-type:before:hidden dark:text-neutral-400 dark:before:bg-neutral-600"
                  >
                    {
                      formatDate(
                        post.data.pubDate,
                        LOCALE_LANGUAGE_TAGS[locale],
                      )
                    }
                  </li>
                  <li
                    class="relative inline-block pe-6 before:absolute before:end-2 before:top-1/2 before:size-1 before:-translate-y-1/2 before:rounded-full before:bg-neutral-300 last:pe-0 last-of-type:before:hidden dark:text-neutral-400 dark:before:bg-neutral-600"
                  >
                    {copy.article.readTimeLabel(post.data.readTime)}
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>

      <h1
        class="mb-3 text-2xl font-bold text-neutral-800 dark:text-neutral-200 md:text-3xl"
      >
        {post.data.title}
      </h1>

      <BlogContent
        contents={post.data.contents}
        cardImage={post.data.cardImage}
        cardImageAlt={post.data.cardImageAlt}
      />

      <p
        class="rounded-lg border border-neutral-300 bg-neutral-100 p-4 text-neutral-700 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-300"
      >
        {copy.article.cta.prefix}<a
          href={copy.article.cta.firstLinkHref}
          class="font-medium text-blue-500 underline-offset-4 hover:underline"
        >
          {copy.article.cta.firstLinkText}
        </a>{copy.article.cta.middle}<a
          href={copy.article.cta.secondLinkHref}
          class="font-medium text-blue-500 underline-offset-4 hover:underline"
        >
          {copy.article.cta.secondLinkText}
        </a>{copy.article.cta.suffix}
      </p>

      <div
        class="mx-auto grid max-w-screen-lg gap-y-5 sm:flex sm:items-center sm:justify-between sm:gap-y-0"
      >
        <div
          class="flex flex-wrap gap-x-2 gap-y-1 sm:flex-nowrap sm:items-center sm:gap-y-0"
        >
          {
            post.data.tags?.map((tag) => (
              <span class="inline-flex items-center gap-x-1.5 rounded-lg bg-neutral-400/30 px-3 py-1.5 text-xs font-medium text-neutral-700 outline-none focus:outline-none focus-visible:outline-none focus-visible:ring dark:bg-neutral-700/60 dark:text-neutral-300">
                {capitalize(tag)}
              </span>
            ))
          }
        </div>
        <div class="flex items-center justify-end gap-x-1.5">
          <Bookmark />
          <div
            class="mx-3 block h-4 border-e border-neutral-400 dark:border-neutral-500"
          >
          </div>
          <div class="inline-flex">
            <SocialShare pageTitle={post.data.title} />
          </div>
        </div>
      </div>
    </div>
    <PostFeedback
      title={copy.article.feedbackTitle}
      firstChoice={copy.article.feedbackYes}
      secondChoice={copy.article.feedbackNo}
    />
  </section>

  <section class="mx-auto max-w-3xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <div class="mb-10 max-w-2xl">
      <h2
        class="text-balance text-2xl font-bold text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight"
      >
        {copy.article.relatedTitle}
      </h2>
    </div>

    <div class="grid grid-cols-2 gap-6">
      {
        relatedPosts.map((entry) => (
          <CardRelated blogEntry={entry} recentBlogLocale={locale} />
        ))
      }
    </div>
  </section>
</MainLayout>
