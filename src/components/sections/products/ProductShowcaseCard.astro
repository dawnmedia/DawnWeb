---
import { Image } from "astro:assets";
import Icon from "@components/ui/icons/Icon.astro";
import type { CollectionEntry } from "astro:content";
import {
  DEFAULT_LOCALE,
  getContentSlug,
  localizePath,
  stripLocaleFromSlug,
  type Locale,
} from "@utils/locale";

const {
  product,
  productLocale = DEFAULT_LOCALE,
  viewLabel = "View product",
} = Astro.props;
const slug = stripLocaleFromSlug(getContentSlug(product), productLocale);
const href = localizePath(`/products/${slug}/`, productLocale);
const heroImage =
  product.data.showcase.screenshots[0]?.image ?? product.data.main.imgCard;
const heroAlt =
  product.data.showcase.screenshots[0]?.alt ?? product.data.main.imgAlt;

interface Props {
  product: CollectionEntry<"products">;
  productLocale?: Locale;
  viewLabel?: string;
}
---

<a
  href={href}
  data-astro-prefetch
  class="group relative flex aspect-[4/5] min-h-[360px] flex-col overflow-hidden rounded-3xl border border-white/10 outline-none transition-transform duration-300 hover:-translate-y-2 hover:shadow-2xl hover:shadow-blue-900/40 focus-visible:ring focus-visible:ring-blue-400"
>
  <div class="absolute inset-0 z-0">
    <Image
      src={heroImage}
      alt={heroAlt}
      class="h-full w-full object-cover opacity-60 transition-transform duration-700 group-hover:scale-110 group-hover:opacity-80"
      format="avif"
      loading="lazy"
      width={640}
      sizes="(min-width: 1024px) 50vw, 100vw"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-neutral-950 via-neutral-900/80 to-transparent"></div>
  </div>
  
  <div class="relative z-10 flex flex-1 flex-col p-8">
    <div class="flex flex-wrap items-center gap-2 text-xs font-bold">
      <span class="text-blue-300">
        {product.data.showcase.eyebrow}
      </span>
      <span
        class="rounded-full border border-white/20 bg-white/10 px-2.5 py-1 text-white backdrop-blur-md"
      >
        {product.data.showcase.status}
      </span>
    </div>

    <div class="mt-auto">
      <h2 class="text-3xl font-bold tracking-tight text-white">
        {product.data.title}
      </h2>
      <p class="mt-3 text-sm leading-6 text-neutral-300">
        {product.data.description}
      </p>

      <div class="mt-4 flex flex-wrap gap-2">
        {
          product.data.showcase.platforms.slice(0, 3).map((platform) => (
            <span class="rounded-full bg-neutral-800/80 px-3 py-1 text-xs font-bold text-neutral-300 border border-neutral-700">
              {platform}
            </span>
          ))
        }
      </div>

      <div
        class="mt-6 inline-flex items-center gap-x-2 text-sm font-bold text-blue-400 transition-colors group-hover:text-blue-300"
      >
        {viewLabel}
        <Icon name="arrowRight" />
      </div>
    </div>
  </div>
</a>
