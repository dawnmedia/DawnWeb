---
import { Image } from "astro:assets";
import Icon from "@components/ui/icons/Icon.astro";
import type { CollectionEntry } from "astro:content";
import { DEFAULT_LOCALE, localizePath, type Locale } from "@utils/locale";
import { getProductSlug } from "@utils/products";

const {
  product,
  productLocale = DEFAULT_LOCALE,
  builtByLabel = "Built by Dawn Web",
} = Astro.props;

const slug = getProductSlug(product, productLocale);
const href = localizePath(`/products/${slug}/`, productLocale);
const cardImage =
  product.data.showcase.screenshots[0]?.image ?? product.data.main.imgCard;
const cardAlt =
  product.data.showcase.screenshots[0]?.alt ?? product.data.main.imgAlt;

const accents: Record<
  string,
  { color: string; glow: string; badgeBackground: string; badgeColor: string }
> = {
  "dawn-web": {
    color: "#405991",
    glow: "rgba(64, 89, 145, 0.32)",
    badgeBackground: "#405991",
    badgeColor: "#ffffff",
  },
  "dawn-media": {
    color: "#a855f7",
    glow: "rgba(168, 85, 247, 0.28)",
    badgeBackground: "#a855f7",
    badgeColor: "#ffffff",
  },
  "dawn-studios": {
    color: "#ef4444",
    glow: "rgba(239, 68, 68, 0.28)",
    badgeBackground: "#ef4444",
    badgeColor: "#ffffff",
  },
  "dawn-town": {
    color: "#eab308",
    glow: "rgba(234, 179, 8, 0.26)",
    badgeBackground: "#eab308",
    badgeColor: "#171717",
  },
  "dawn-labs": {
    color: "#596f9e",
    glow: "rgba(148, 163, 184, 0.26)",
    badgeBackground: "#e5e5e5",
    badgeColor: "#171717",
  },
};

const accent = accents[slug] ?? accents["dawn-labs"];
const logoScale = slug === "dawn-town" ? 1.28 : 1.35;

interface Props {
  product: CollectionEntry<"products">;
  productLocale?: Locale;
  builtByLabel?: string;
}
---

<a
  href={href}
  data-astro-prefetch
  class="ecosystem-card group flex h-full flex-col overflow-hidden rounded-lg border border-neutral-300 bg-neutral-100 outline-none ring-zinc-500 transition duration-300 focus-visible:ring dark:border-neutral-700 dark:bg-neutral-900 dark:ring-zinc-200"
  style={`--ecosystem-accent: ${accent.color}; --ecosystem-glow: ${accent.glow}; --ecosystem-logo-scale: ${logoScale};`}
>
  <div class="relative aspect-[16/9] overflow-hidden bg-neutral-200 dark:bg-neutral-950">
    <Image
      src={cardImage}
      alt={cardAlt}
      class="ecosystem-logo h-full w-full object-cover transition duration-500"
      format="avif"
      loading="lazy"
      width={640}
      sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
    />
    <div
      class="absolute inset-x-0 bottom-0 h-1"
      style={`background: ${accent.color};`}
    >
    </div>
  </div>

  <div class="flex flex-1 flex-col p-5">
    <div class="flex flex-wrap items-center gap-2 text-xs font-bold">
      <span style={`color: ${accent.color};`}>
        {product.data.showcase.eyebrow}
      </span>
      <span
        class="rounded-full px-2.5 py-1"
        style={`background: ${accent.badgeBackground}; color: ${accent.badgeColor};`}
      >
        {product.data.showcase.status}
      </span>
    </div>

    <h2 class="mt-4 text-xl font-bold text-neutral-800 dark:text-neutral-200">
      {product.data.title}
    </h2>
    <p class="mt-1 text-xs font-bold uppercase tracking-normal text-neutral-500 dark:text-neutral-400">
      {product.data.showcase.audience}
    </p>
    <p class="mt-3 text-sm leading-6 text-neutral-700 dark:text-neutral-400">
      {product.data.description}
    </p>

    <div class="mt-4 flex flex-wrap gap-2">
      {
        product.data.showcase.platforms.slice(0, 3).map((platform) => (
          <span class="rounded-full bg-neutral-200 px-2.5 py-1 text-xs font-bold text-neutral-700 dark:bg-neutral-800 dark:text-neutral-200">
            {platform}
          </span>
        ))
      }
    </div>

    <div class="mt-auto pt-6">
      <p class="text-xs font-bold uppercase tracking-normal text-neutral-500 dark:text-neutral-400">
        {builtByLabel}
      </p>
      <p
        class="mt-2 inline-flex items-center gap-x-1 text-sm font-bold"
        style={`color: ${accent.color};`}
      >
        {product.data.showcase.primaryAction.label}
        <Icon name="arrowRight" />
      </p>
    </div>
  </div>
</a>

<style>
  .ecosystem-card:hover {
    border-color: var(--ecosystem-accent);
    box-shadow: 0 0 28px var(--ecosystem-glow);
  }

  .ecosystem-logo {
    transform: scale(var(--ecosystem-logo-scale));
  }

  .ecosystem-card:hover .ecosystem-logo {
    transform: scale(calc(var(--ecosystem-logo-scale) * 1.04));
  }
</style>
