---
import { Image } from "astro:assets";
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import SecondaryCTA from "@components/ui/buttons/SecondaryCTA.astro";
import type { CollectionEntry } from "astro:content";
import { DEFAULT_LOCALE, localizePath, type Locale } from "@utils/locale";

const { product, productLocale = DEFAULT_LOCALE } = Astro.props;
const showcase = product.data.showcase;
const primaryScreenshot = showcase.screenshots[0] ?? {
  image: product.data.main.imgMain,
  alt: product.data.main.imgAlt,
  label: product.data.title,
};
const specs = [
  ...product.data.specificationsLeft,
  ...(product.data.specificationsRight ?? []),
];

const labels = {
  en: {
    back: "Products",
    builtFor: "Built for",
    status: "Status",
    platforms: "Platforms",
    stack: "Stack",
    metrics: "Product signals",
    capabilities: "Core capabilities",
    gallery: "Product experience",
    snapshot: "Technical snapshot",
    finalTitle: "Ready to build a product this clear?",
    finalText:
      "Bring Dawn Web your product idea, existing platform, or rough workflow. We will help shape it into a focused software experience.",
    secondary: "Talk to Dawn Web",
  },
  fr: {
    back: "Produits",
    builtFor: "Concu pour",
    status: "Statut",
    platforms: "Plateformes",
    stack: "Stack",
    metrics: "Signaux produit",
    capabilities: "Fonctionnalites cles",
    gallery: "Experience produit",
    snapshot: "Apercu technique",
    finalTitle: "Pret a creer un produit aussi clair ?",
    finalText:
      "Apportez votre idee, votre plateforme existante ou votre flux de travail. Dawn Web vous aide a le transformer en experience logicielle ciblee.",
    secondary: "Parler a Dawn Web",
  },
  br: {
    back: "Produtos",
    builtFor: "Criado para",
    status: "Status",
    platforms: "Plataformas",
    stack: "Tecnologias",
    metrics: "Sinais do produto",
    capabilities: "Recursos principais",
    gallery: "Experiencia do produto",
    snapshot: "Resumo tecnico",
    finalTitle: "Pronto para criar um produto tao claro?",
    finalText:
      "Traga sua ideia, plataforma existente ou fluxo de trabalho. A Dawn Web ajuda a transformar isso em uma experiencia de software focada.",
    secondary: "Falar com a Dawn Web",
  },
  ko: {
    back: "제품",
    builtFor: "대상",
    status: "상태",
    platforms: "플랫폼",
    stack: "기술 스택",
    metrics: "제품 지표",
    capabilities: "핵심 기능",
    gallery: "제품 경험",
    snapshot: "기술 요약",
    finalTitle: "이렇게 명확한 제품을 만들 준비가 되셨나요?",
    finalText:
      "제품 아이디어, 기존 플랫폼, 아직 정리되지 않은 업무 흐름을 Dawn Web에 가져오세요. 집중도 높은 소프트웨어 경험으로 다듬어 드립니다.",
    secondary: "Dawn Web에 문의하기",
  },
  ja: {
    back: "プロダクト",
    builtFor: "対象",
    status: "ステータス",
    platforms: "プラットフォーム",
    stack: "技術スタック",
    metrics: "プロダクト指標",
    capabilities: "主な機能",
    gallery: "プロダクト体験",
    snapshot: "技術概要",
    finalTitle: "ここまで伝わりやすいプロダクトを作りませんか？",
    finalText:
      "プロダクトのアイデア、既存プラットフォーム、まだ整理できていない業務フローをお聞かせください。Dawn Webが使いやすいソフトウェア体験へ具体化します。",
    secondary: "Dawn Webに相談する",
  },
  es: {
    back: "Productos",
    builtFor: "Creado para",
    status: "Estado",
    platforms: "Plataformas",
    stack: "Tecnologías",
    metrics: "Indicadores del producto",
    capabilities: "Funciones principales",
    gallery: "Experiencia del producto",
    snapshot: "Resumen técnico",
    finalTitle: "¿Listo para crear un producto así de claro?",
    finalText:
      "Trae a Dawn Web tu idea de producto, plataforma actual o flujo de trabajo inicial. Te ayudaremos a convertirlo en una experiencia de software enfocada.",
    secondary: "Hablar con Dawn Web",
  },
}[productLocale];

interface Props {
  product: CollectionEntry<"products">;
  productLocale?: Locale;
}
---

<article class="overflow-hidden">
  <section
    class="relative isolate -mt-28 overflow-hidden bg-neutral-950 pt-28 text-white sm:-mt-32 sm:pt-32"
  >
    <div
      class="absolute inset-0 -z-10 bg-[linear-gradient(135deg,#0f172a_0%,#111111_52%,#050505_100%)]"
    >
    </div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-white/10"></div>

    <div
      class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-16 2xl:max-w-full"
    >
      <a
        href={localizePath("/products", productLocale)}
        class="inline-flex items-center rounded-lg text-sm font-bold text-blue-200 outline-none ring-zinc-500 transition hover:text-blue-100 focus-visible:ring dark:ring-zinc-200"
      >
        {labels.back}
      </a>

      <div
        class="mt-8 grid min-w-0 gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-center"
      >
        <div class="min-w-0">
          <p
            class="break-words text-sm font-bold uppercase tracking-normal text-blue-200"
          >
            {showcase.eyebrow}
          </p>
          <h1
            class="mt-3 break-words text-balance text-4xl font-bold tracking-tight text-white md:text-6xl"
          >
            {product.data.title}
          </h1>
          <p
            class="mt-4 break-words text-pretty text-xl leading-8 text-neutral-200"
          >
            {product.data.description}
          </p>
          <p class="mt-5 break-words text-pretty leading-7 text-neutral-300">
            {product.data.main.content}
          </p>

          <div class="mt-6 flex min-w-0 flex-wrap gap-2">
            <span
              class="min-w-0 max-w-full rounded-full border border-white/15 bg-white/5 px-3 py-1.5 text-sm font-bold leading-tight text-neutral-200"
            >
              {labels.builtFor}: {showcase.audience}
            </span>
            <span
              class="min-w-0 max-w-full rounded-full bg-blue-400 px-3 py-1.5 text-sm font-bold leading-tight text-neutral-950"
            >
              {labels.status}: {showcase.status}
            </span>
          </div>

          <div class="mt-7 flex flex-col gap-3 sm:flex-row">
            <PrimaryCTA
              title={showcase.primaryAction.label}
              url={showcase.primaryAction.url}
            />
            {
              showcase.secondaryAction && (
                <SecondaryCTA
                  title={showcase.secondaryAction.label}
                  url={showcase.secondaryAction.url}
                />
              )
            }
          </div>
        </div>

        <div
          class="min-w-0 overflow-hidden rounded-lg border border-white/10 bg-white/[0.06] p-2 shadow-2xl shadow-black/40"
        >
          <div class="flex gap-1.5 border-b border-white/10 px-2 py-2">
            <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-yellow-400"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-blue-400"></span>
          </div>
          <div class="aspect-[16/10] bg-neutral-950 p-2">
            <Image
              src={primaryScreenshot.image}
              alt={primaryScreenshot.alt}
              class="h-full w-full rounded-sm object-contain"
              format="avif"
              loading="eager"
              width={1000}
              sizes="(min-width: 1024px) 54vw, 100vw"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>

      <div
        class="mt-10 grid min-w-0 gap-5 rounded-lg border border-white/10 bg-white/[0.05] p-5 shadow-2xl shadow-black/20 md:grid-cols-3"
      >
        <div class="min-w-0">
          <p
            class="text-xs font-bold uppercase tracking-normal text-neutral-400"
          >
            {labels.platforms}
          </p>
          <div class="mt-3 flex min-w-0 flex-wrap gap-2">
            {
              showcase.platforms.map((platform) => (
                <span class="min-w-0 max-w-full rounded-full border border-white/10 bg-white/10 px-3 py-1 text-sm font-bold leading-tight text-neutral-100">
                  {platform}
                </span>
              ))
            }
          </div>
        </div>
        <div class="min-w-0">
          <p
            class="text-xs font-bold uppercase tracking-normal text-neutral-400"
          >
            {labels.stack}
          </p>
          <div class="mt-3 flex min-w-0 flex-wrap gap-2">
            {
              showcase.stack.map((item) => (
                <span class="min-w-0 max-w-full rounded-full border border-white/10 bg-white/10 px-3 py-1 text-sm font-bold leading-tight text-neutral-100">
                  {item}
                </span>
              ))
            }
          </div>
        </div>
        <div class="min-w-0">
          <p
            class="text-xs font-bold uppercase tracking-normal text-neutral-400"
          >
            {labels.metrics}
          </p>
          <div class="mt-3 grid grid-cols-2 gap-3">
            {
              showcase.metrics.slice(0, 2).map((metric) => (
                <div>
                  <p class="text-2xl font-bold text-white">{metric.value}</p>
                  <p class="text-sm text-neutral-300">{metric.label}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <section
    class="mx-auto max-w-[85rem] px-4 py-14 sm:px-6 lg:px-8 lg:py-20 2xl:max-w-full"
  >
    <div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr]">
      <div>
        <p
          class="text-sm font-bold uppercase tracking-normal text-blue-600 dark:text-blue-300"
        >
          {labels.capabilities}
        </p>
        <h2
          class="mt-3 text-balance text-3xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl"
        >
          {product.data.longDescription.title}
        </h2>
        <p
          class="mt-4 text-pretty leading-7 text-neutral-700 dark:text-neutral-400"
        >
          {product.data.longDescription.subTitle}
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {
          product.data.descriptionList.map((item) => (
            <div class="h-full rounded-lg border border-neutral-300 bg-neutral-100 p-5 shadow-sm shadow-neutral-300/20 transition hover:border-blue-400 dark:border-neutral-700 dark:bg-neutral-800 dark:shadow-neutral-950/20 dark:hover:border-blue-300">
              <h3 class="text-lg font-bold text-neutral-800 dark:text-neutral-200">
                {item.title}
              </h3>
              <p class="mt-3 text-sm leading-6 text-neutral-700 dark:text-neutral-400">
                {item.subTitle}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section
    class="bg-neutral-950 px-4 py-14 text-white sm:px-6 lg:px-8 lg:py-20"
  >
    <div class="mx-auto max-w-[85rem] 2xl:max-w-full">
      <div class="flex items-end justify-between gap-6">
        <div>
          <p class="text-sm font-bold uppercase tracking-normal text-blue-300">
            {labels.gallery}
          </p>
          <h2
            class="mt-3 text-balance text-3xl font-bold tracking-tight text-white md:text-4xl"
          >
            {primaryScreenshot.label}
          </h2>
        </div>
      </div>

      <div class="mt-8 grid gap-5 lg:grid-cols-2">
        {
          showcase.screenshots.map((screenshot) => (
            <figure class="overflow-hidden rounded-lg border border-white/10 bg-white/[0.04] shadow-2xl shadow-black/25">
              <div class="aspect-[16/10] bg-neutral-950 p-3">
                <Image
                  src={screenshot.image}
                  alt={screenshot.alt}
                  class="h-full w-full rounded-sm object-contain"
                  format="avif"
                  loading="eager"
                  width={760}
                  sizes="(min-width: 1024px) 50vw, 100vw"
                />
              </div>
              <figcaption class="border-t border-white/10 px-5 py-4 text-sm font-bold text-neutral-200">
                {screenshot.label}
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <section
    class="mx-auto max-w-[85rem] px-4 py-14 sm:px-6 lg:px-8 lg:py-20 2xl:max-w-full"
  >
    <p
      class="text-sm font-bold uppercase tracking-normal text-blue-600 dark:text-blue-300"
    >
      {labels.snapshot}
    </p>
    <div class="mt-6 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {
        specs.slice(0, 8).map((spec) => (
          <div class="rounded-lg border border-neutral-300 bg-neutral-100 p-5 dark:border-neutral-700 dark:bg-neutral-800">
            <h3 class="font-bold text-neutral-800 dark:text-neutral-200">
              {spec.title}
            </h3>
            <p class="mt-2 text-sm leading-6 text-neutral-700 dark:text-neutral-400">
              {spec.subTitle}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <section
    class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-16 2xl:max-w-full"
  >
    <div
      class="overflow-hidden rounded-lg border border-white/10 bg-neutral-950 bg-[linear-gradient(135deg,#111827_0%,#111111_58%,#050505_100%)] p-6 text-neutral-50 shadow-2xl shadow-neutral-400/20 dark:shadow-neutral-950/30 md:p-10"
    >
      <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
        <div>
          <h2 class="text-balance text-3xl font-bold md:text-4xl">
            {labels.finalTitle}
          </h2>
          <p class="mt-3 max-w-3xl text-pretty text-neutral-300">
            {labels.finalText}
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row md:justify-end">
          <PrimaryCTA
            title={showcase.primaryAction.label}
            url={showcase.primaryAction.url}
          />
          <SecondaryCTA
            title={labels.secondary}
            url={localizePath("/contact", productLocale)}
          />
        </div>
      </div>
    </div>
  </section>
</article>
