---
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import ProductShowcaseCard from "./ProductShowcaseCard.astro";
import type { CollectionEntry } from "astro:content";
import type { Locale } from "@utils/locale";

const {
  products,
  locale,
  eyebrow,
  title,
  subTitle,
  ctaLabel,
  ctaUrl,
  viewLabel,
} = Astro.props;

interface Props {
  products: CollectionEntry<"products">[];
  locale: Locale;
  eyebrow: string;
  title: string;
  subTitle: string;
  ctaLabel: string;
  ctaUrl: string;
  viewLabel: string;
}
---

<section class="relative">
  <div class="mx-auto max-w-[85rem] px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-end">
      <div class="max-w-4xl">
        <p class="text-sm font-bold uppercase tracking-widest text-blue-600 dark:text-blue-400">
          {eyebrow}
        </p>
        <h1 class="mt-3 text-balance text-4xl font-bold tracking-tight text-neutral-800 dark:text-white md:text-6xl">
          {title}
        </h1>
        <p class="mt-5 max-w-3xl text-pretty text-lg leading-8 text-neutral-600 dark:text-neutral-300">
          {subTitle}
        </p>
      </div>
      <div class="lg:justify-self-end shrink-0">
      <PrimaryCTA title={ctaLabel} url={ctaUrl} />
    </div>
  </div>

    <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 lg:gap-8">
      {
        products.map((product) => (
          <ProductShowcaseCard
            product={product}
            productLocale={locale}
            viewLabel={viewLabel}
          />
        ))
      }
    </div>
  </div>
</section>
