---
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import ProductShowcaseCard from "./ProductShowcaseCard.astro";
import type { CollectionEntry } from "astro:content";
import type { Locale } from "@utils/locale";

const {
  products,
  locale,
  eyebrow,
  title,
  subTitle,
  ctaLabel,
  ctaUrl,
  viewLabel,
} = Astro.props;

interface Props {
  products: CollectionEntry<"products">[];
  locale: Locale;
  eyebrow: string;
  title: string;
  subTitle: string;
  ctaLabel: string;
  ctaUrl: string;
  viewLabel: string;
}
---

<section
  class="relative isolate -mt-28 flex min-h-[calc(100vh+3rem)] overflow-hidden bg-neutral-50 pt-28 text-neutral-900 dark:bg-neutral-950 dark:text-white sm:-mt-32 sm:pt-32"
>
  <div
    class="absolute inset-0 -z-10 bg-[linear-gradient(135deg,#f8fafc_0%,#f1f5f9_54%,#e2e8f0_100%)] dark:bg-[linear-gradient(135deg,#0f172a_0%,#111111_54%,#050505_100%)]"
  >
  </div>
  <div class="absolute inset-x-0 bottom-0 h-px bg-neutral-200 dark:bg-white/10"></div>

  <div
    class="mx-auto flex w-full max-w-[85rem] flex-col justify-center px-4 py-12 sm:px-6 lg:px-8 lg:py-16"
  >
    <div
      class="grid min-w-0 gap-8 lg:grid-cols-[minmax(0,1fr)_18rem] lg:items-end"
    >
      <div class="min-w-0 max-w-4xl">
        <p class="text-sm font-bold uppercase tracking-normal text-blue-600 dark:text-blue-300">
          {eyebrow}
        </p>
        <h1
          class="mt-3 break-words text-balance text-4xl font-bold tracking-tight text-neutral-900 dark:text-neutral-50 md:text-6xl"
        >
          {title}
        </h1>
        <p
          class="mt-5 max-w-3xl break-words text-pretty text-lg leading-8 text-neutral-600 dark:text-neutral-300"
        >
          {subTitle}
        </p>
      </div>
      <div class="min-w-0 shrink-0 lg:justify-self-end">
        <PrimaryCTA title={ctaLabel} url={ctaUrl} />
      </div>
    </div>

    <div
      class="mt-12 grid min-w-0 gap-5 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 lg:gap-6"
    >
      {
        products.map((product) => (
          <ProductShowcaseCard
            product={product}
            productLocale={locale}
            viewLabel={viewLabel}
          />
        ))
      }
    </div>
  </div>
</section>
