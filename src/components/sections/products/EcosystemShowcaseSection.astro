---
import EcosystemShowcaseCard from "./EcosystemShowcaseCard.astro";
import type { CollectionEntry } from "astro:content";
import type { Locale } from "@utils/locale";

const {
  products,
  locale,
  eyebrow,
  title,
  description,
  supportingLine,
  builtByLabel,
} = Astro.props;

interface Props {
  products: CollectionEntry<"products">[];
  locale: Locale;
  eyebrow: string;
  title: string;
  description: string;
  supportingLine?: string;
  builtByLabel: string;
}
---

{
  products.length > 0 && (
    <section class="bg-[#0c1322] px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
      <div class="mx-auto max-w-[85rem]">
        <div class="border-t border-white/10 pt-16">
          <div class="grid gap-6 lg:grid-cols-[minmax(0,0.75fr)_minmax(0,1fr)] lg:items-end">
            <div>
              <p class="text-sm font-bold uppercase tracking-widest text-blue-400">
                {eyebrow}
              </p>
              <h2 class="mt-3 text-balance text-3xl font-bold tracking-tight text-white md:text-5xl">
                {title}
              </h2>
            </div>
            <div>
              <p class="text-pretty text-lg leading-8 text-neutral-300">
                {description}
              </p>
              {supportingLine && (
                <p class="mt-3 text-sm leading-6 text-neutral-400">
                  {supportingLine}
                </p>
              )}
            </div>
          </div>

          <div class="mt-16 grid gap-6 md:grid-cols-2 xl:grid-cols-5">
            {products.map((product) => (
              <EcosystemShowcaseCard
                product={product}
                productLocale={locale}
                builtByLabel={builtByLabel}
              />
            ))}
          </div>
        </div>
      </div>
    </section>
  )
}
