---
import EcosystemShowcaseCard from "./EcosystemShowcaseCard.astro";
import type { CollectionEntry } from "astro:content";
import type { Locale } from "@utils/locale";

const {
  products,
  locale,
  eyebrow,
  title,
  description,
  supportingLine,
  builtByLabel,
} = Astro.props;

interface Props {
  products: CollectionEntry<"products">[];
  locale: Locale;
  eyebrow: string;
  title: string;
  description: string;
  supportingLine?: string;
  builtByLabel?: string;
}
---

{
  products.length > 0 && (
    <section class="relative isolate overflow-hidden bg-neutral-50 px-4 py-20 text-neutral-900 dark:bg-neutral-950 dark:text-white sm:px-6 lg:px-8 lg:py-28">
      <div class="absolute inset-0 -z-10 bg-[linear-gradient(180deg,#f8fafc_0%,#f1f5f9_50%,#f8fafc_100%)] dark:bg-[linear-gradient(180deg,#050505_0%,#0a0f1a_50%,#050505_100%)]" />
      <div class="absolute inset-0 -z-10 bg-[linear-gradient(115deg,rgba(59,130,246,0.04)_0%,rgba(248,250,252,0)_40%,rgba(241,245,249,0.6)_100%)] dark:bg-[linear-gradient(115deg,rgba(59,130,246,0.08)_0%,rgba(5,5,5,0)_40%,rgba(15,23,42,0.15)_100%)]" />

      <div class="mx-auto flex w-full max-w-[85rem] flex-col">
        <div class="text-center">
          <p class="text-sm font-bold uppercase tracking-widest text-blue-600/80 dark:text-blue-300/80">
            {eyebrow}
          </p>
          <h2 class="mt-4 text-balance text-4xl font-bold tracking-tight text-neutral-900 dark:text-white md:text-6xl">
            {title}
          </h2>
          <p class="mx-auto mt-6 max-w-2xl text-pretty text-lg leading-8 text-neutral-500 dark:text-neutral-400">
            {description}
          </p>
          {supportingLine && (
            <p class="mx-auto mt-3 max-w-xl text-sm leading-6 text-neutral-400 dark:text-neutral-500">
              {supportingLine}
            </p>
          )}
        </div>

        <div class="mt-16 grid min-w-0 gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
          {products.map((product) => (
            <EcosystemShowcaseCard
              product={product}
              productLocale={locale}
            />
          ))}
        </div>
      </div>
    </section>
  )
}
