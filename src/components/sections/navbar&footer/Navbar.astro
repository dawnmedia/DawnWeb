---
//Import relevant dependencies
import ThemeIcon from "@components/ThemeIcon.astro";
import NavLink from "@components/ui/links/NavLink.astro";
import { getNavigation } from "@utils/navigation.ts";
import { getLocaleFromPath, localizePath } from "@utils/locale";
import BrandLogo from "@components/BrandLogo.astro";
import LanguagePicker from "@components/ui/LanguagePicker.astro";

// Select the correct translation based on the page's lang prop:
const currentLocale = getLocaleFromPath(Astro.url.pathname);
const strings = getNavigation(currentLocale);
const homeUrl = localizePath("/", currentLocale);
const navToggleLabel =
  currentLocale === "ko"
    ? "내비게이션 열기"
    : currentLocale === "ja"
      ? "ナビゲーションを切り替える"
      : currentLocale === "es"
        ? "Abrir navegación"
        : currentLocale === "fr"
          ? "Ouvrir la navigation"
          : currentLocale === "br"
            ? "Alternar navegação"
            : "Toggle navigation";

// Ensure anchors use the configured base (useful for GitHub Pages subpaths)
const BASE = import.meta.env.BASE_URL || "/";
---

<!-- Main header component -->
<header
  class="sticky inset-x-0 top-4 z-50 w-full px-4 pt-3 text-sm sm:px-6 lg:px-8"
>
  <nav
    class="relative mx-auto max-w-[85rem] overflow-visible rounded-[36px] border border-white/70 bg-white/95 px-5 py-4 backdrop-blur-md dark:border-neutral-700/50 dark:bg-neutral-800/95 dark:backdrop-blur-md md:flex md:items-center md:justify-between md:px-8 md:py-2 lg:px-10"
    aria-label="Global"
  >
    <div class="flex w-full min-w-0 items-center justify-between md:w-auto">
      <!-- Brand logo -->
      <a
        class="ms-2 flex min-w-0 flex-shrink-0 items-center md:ms-3"
        href={`${BASE}${homeUrl.replace(/^\//, "")}`}
        aria-label="Brand"
      >
        <BrandLogo className="h-12 w-auto sm:h-14 lg:h-16" />
      </a>

      <!-- Mobile Right Icons: Hamburger + Theme -->
      <div class="flex items-center gap-3 md:hidden">
        <button
          type="button"
          class="flex h-9 w-9 items-center justify-center rounded-full text-neutral-600 transition hover:bg-neutral-200 dark:text-neutral-400 dark:hover:bg-neutral-700"
          data-nav-toggle
          aria-controls="navbar-collapse-with-animation"
          aria-expanded="false"
          aria-label={navToggleLabel}
        >
          <svg
            class="h-5 w-5"
            data-nav-open-icon
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="3" x2="21" y1="6" y2="6"></line>
            <line x1="3" x2="21" y1="12" y2="12"></line>
            <line x1="3" x2="21" y1="18" y2="18"></line>
          </svg>
          <svg
            class="hidden h-5 w-5"
            data-nav-close-icon
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M18 6 6 18"></path>
            <path d="m6 6 12 12"></path>
          </svg>
        </button>

        <ThemeIcon />
      </div>
    </div>

    <!-- Collapsible navigation -->
    <div
      id="navbar-collapse-with-animation"
      class="hidden grow basis-full transition-all duration-300 md:block"
      data-nav-menu
    >
      <div
        class="mt-4 flex flex-col gap-y-1 border-t border-neutral-200/60 pt-4 dark:border-neutral-700/60 md:mt-0 md:flex-row md:items-center md:justify-end md:gap-x-4 md:gap-y-0 md:border-0 md:pt-0 md:ps-7 lg:gap-x-7"
      >
        {
          strings.navBarLinks.map((link) => (
            <NavLink url={link.url} name={link.name} />
          ))
        }

        <div class="px-3 py-2 md:px-0 md:py-0">
          <LanguagePicker />
        </div>

        <!-- Desktop Theme Toggle -->
        <span class="hidden md:inline-block">
          <ThemeIcon />
        </span>
      </div>
    </div>
  </nav>
</header>

<!-- Theme and navigation script -->
<script is:inline>
  const DawnTheme = {
    init() {
      const defaultTheme = "default";
      let theme = localStorage.getItem("hs_theme") || defaultTheme;
      if (document.querySelector("html").classList.contains("dark")) return;
      this.setAppearance(theme);
    },
    _resetStylesOnLoad() {
      const $resetStyles = document.createElement("style");
      $resetStyles.innerText = `*{transition: unset !important;}`;
      $resetStyles.setAttribute("data-hs-appearance-onload-styles", "");
      document.head.appendChild($resetStyles);
      return $resetStyles;
    },
    setAppearance(theme, saveInStore = true, dispatchEvent = true) {
      const $resetStylesEl = this._resetStylesOnLoad();
      if (saveInStore) localStorage.setItem("hs_theme", theme);
      if (theme === "auto") {
        theme = window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "default";
      }
      document.documentElement.classList.remove("dark", "default", "auto");
      document.documentElement.classList.add(theme);
      setTimeout(() => $resetStylesEl.remove());
      if (dispatchEvent) {
        window.dispatchEvent(
          new CustomEvent("on-dawn-theme-change", { detail: theme }),
        );
      }
    },
    getAppearance() {
      let theme = this.getOriginalAppearance();
      if (theme === "auto") {
        theme = window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "default";
      }
      return theme;
    },
    getOriginalAppearance() {
      return localStorage.getItem("hs_theme") || "default";
    },
  };
  DawnTheme.init();

  window
    .matchMedia("(prefers-color-scheme: dark)")
    .addEventListener("change", () => {
      if (DawnTheme.getOriginalAppearance() === "auto") {
        DawnTheme.setAppearance("auto", false);
      }
    });

  document.addEventListener("DOMContentLoaded", () => {
    const $clickableThemes = document.querySelectorAll("[data-theme-toggle]");
    const $switchableThemes = document.querySelectorAll("[data-theme-switch]");

    $clickableThemes.forEach(($item) => {
      $item.addEventListener("click", () =>
        DawnTheme.setAppearance($item.getAttribute("data-theme-toggle")),
      );
    });

    $switchableThemes.forEach(($item) => {
      $item.addEventListener("change", (e) =>
        DawnTheme.setAppearance(e.target.checked ? "dark" : "default"),
      );
      $item.checked = DawnTheme.getAppearance() === "dark";
    });

    window.addEventListener("on-dawn-theme-change", (e) => {
      $switchableThemes.forEach(($item) => {
        $item.checked = e.detail === "dark";
      });
    });

    const navToggle = document.querySelector("[data-nav-toggle]");
    const navMenu = document.querySelector("[data-nav-menu]");
    const openIcon = document.querySelector("[data-nav-open-icon]");
    const closeIcon = document.querySelector("[data-nav-close-icon]");

    navToggle?.addEventListener("click", () => {
      const isOpen = navToggle.getAttribute("aria-expanded") === "true";
      navToggle.setAttribute("aria-expanded", String(!isOpen));
      navMenu?.classList.toggle("hidden", isOpen);
      openIcon?.classList.toggle("hidden", !isOpen);
      closeIcon?.classList.toggle("hidden", isOpen);
    });

    const normalizePath = (path) => {
      if (!path) return "/";
      try {
        path = new URL(path, window.location.origin).pathname;
      } catch {}
      if (!path.startsWith("/")) path = `/${path}`;
      return path.length > 1 && path.endsWith("/") ? path.slice(0, -1) : path;
    };
    const currentPath = normalizePath(window.location.pathname || "/");

    for (const anchor of document.querySelectorAll("a[data-astro-prefetch]")) {
      if (
        normalizePath(anchor.getAttribute("href") || anchor.href || "") ===
        currentPath
      ) {
        anchor.classList.remove(
          "text-neutral-600",
          "dark:text-neutral-400",
          "hover:text-neutral-500",
          "dark:hover:text-neutral-500",
        );
        anchor.classList.add("text-blue-400", "dark:text-[#c7d7ff]");
        anchor.setAttribute("aria-current", "page");
        break;
      }
    }
  });
</script>
