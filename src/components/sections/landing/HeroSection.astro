---
// Import the necessary dependencies
import { Image } from "astro:assets";
import ReviewComponent from "@components/ui/blocks/ReviewComponent.astro";
import type { ImageMetadata } from "astro";

// Define props from Astro
const {
  title,
  subTitle,
  primaryBtn,
  primaryBtnURL,
  secondaryBtn,
  secondaryBtnURL,
  withReview,
  avatars,
  starCount,
  rating,
  reviews,
  src,
  alt,
  badgeLabel = "Strategic web partner",
  trustItems = ["Founder-led", "No handoffs", "SEO-ready"],
  containedByHeroBand = false,
} = Astro.props;

// Define TypeScript interface for props
interface Props {
  title: string;
  subTitle?: string;
  primaryBtn?: string;
  primaryBtnURL?: string;
  secondaryBtn?: string;
  secondaryBtnURL?: string;
  withReview?: boolean;
  avatars?: Array<string>;
  starCount?: number;
  rating?: string;
  reviews?: string;
  src?: ImageMetadata;
  alt?: string;
  badgeLabel?: string;
  trustItems?: string[];
  containedByHeroBand?: boolean;
}

const sectionClass = containedByHeroBand
  ? "relative flex flex-1 items-start pb-32 pt-8 sm:pb-36 sm:pt-10 md:items-center lg:pb-28 lg:pt-8"
  : "relative py-16 sm:py-24 lg:py-28";

const contentClass = containedByHeroBand
  ? "relative mx-auto grid w-full max-w-screen-2xl items-center gap-8 px-4 sm:px-6 md:grid-cols-[minmax(0,1.02fr)_minmax(320px,0.98fr)] md:gap-10 lg:gap-12 lg:px-8 xl:gap-14"
  : "relative mx-auto grid max-w-screen-2xl items-center gap-8 px-4 sm:px-6 md:grid-cols-2 md:gap-12 lg:gap-16 lg:px-8";

const copyClass = containedByHeroBand
  ? "relative z-10 flex w-full min-w-0 max-w-full flex-col sm:max-w-3xl md:max-w-none lg:max-w-3xl"
  : "relative z-10";

const badgeClass = containedByHeroBand
  ? "mb-5 inline-flex max-w-full items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 backdrop-blur-sm"
  : "mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 backdrop-blur-sm";

const titleClass = containedByHeroBand
  ? "block max-w-full text-pretty break-words text-3xl font-bold leading-tight tracking-tight text-white sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl lg:leading-[1.05]"
  : "block text-balance text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl xl:text-6xl lg:leading-[1.15]";

const subtitleClass = containedByHeroBand
  ? "order-3 mt-5 max-w-full text-pretty text-base leading-relaxed text-blue-100/80 sm:max-w-3xl sm:text-lg md:order-none lg:text-xl"
  : "mt-5 text-pretty text-base leading-relaxed text-blue-100/80 lg:w-[90%] lg:text-lg";

const ctaClass = containedByHeroBand
  ? "order-2 mt-7 grid w-full max-w-full gap-3 sm:inline-flex sm:w-auto sm:max-w-none md:order-none"
  : "mt-8 grid w-full gap-3 sm:inline-flex";

const trustClass = containedByHeroBand
  ? "order-4 mt-7 flex flex-wrap items-center gap-x-5 gap-y-3 sm:gap-x-6 md:order-none"
  : "mt-8 flex flex-wrap items-center gap-x-6 gap-y-3";

const imageWrapClass = containedByHeroBand
  ? "relative flex min-w-0 w-full justify-center md:justify-end"
  : "relative flex w-full justify-center";

const imageShellClass = containedByHeroBand
  ? "relative w-full max-w-sm animate-float sm:max-w-md md:max-w-lg lg:max-w-xl xl:max-w-[40rem]"
  : "relative animate-float";

const imageClass = containedByHeroBand
  ? "relative h-full w-full object-contain object-center drop-shadow-2xl"
  : "relative h-full w-full max-w-lg scale-110 object-cover object-center drop-shadow-2xl";
---

<!-- Hero Section with animated gradient background -->
<section data-hero class={sectionClass}>
  <!-- Animated gradient mesh background -->
  {
    !containedByHeroBand && (
      <div class="absolute inset-0 -z-10 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-900 via-blue-800 to-blue-700 dark:from-blue-900 dark:via-[#0a1a3c] dark:to-[#08162f]" />
        <div class="absolute -left-32 -top-32 h-96 w-96 animate-orb-1 rounded-full bg-blue-500/20 blur-3xl" />
        <div class="absolute -bottom-32 -right-32 h-96 w-96 animate-orb-2 rounded-full bg-yellow-400/10 blur-3xl" />
        <div
          class="absolute left-1/2 top-1/2 h-64 w-64 -translate-x-1/2 -translate-y-1/2 animate-orb-1 rounded-full bg-blue-400/10 blur-3xl"
          style="animation-delay: -5s;"
        />
        <div
          class="absolute inset-0 opacity-[0.03]"
          style="background-image: radial-gradient(circle, rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 32px 32px;"
        />
      </div>
    )
  }

  <!-- Content grid -->
  <div class={contentClass}>
    <!-- Title and description -->
    <div class={copyClass}>
      <!-- Badge -->
      <div
        data-hero-badge
        class={badgeClass}
      >
        <span class="h-2 w-2 rounded-full bg-yellow-400 animate-pulse"></span>
        <span
          class="min-w-0 break-words text-left text-xs font-semibold uppercase leading-snug tracking-wider text-blue-100"
          >{badgeLabel}</span
        >
      </div>

      <h1
        data-hero-title
        class={titleClass}
      >
        <Fragment set:html={title} />
      </h1>

      {
        subTitle && (
          <p
            data-hero-subtitle
            class={subtitleClass}
          >
            {subTitle}
          </p>
        )
      }

      <!-- Action buttons -->
      <div data-hero-cta class={ctaClass}>
        {
          primaryBtn && (
            <a
              href={primaryBtnURL}
              class="group relative inline-flex min-w-0 items-center justify-center gap-x-2 overflow-hidden rounded-lg bg-yellow-400 px-6 py-3.5 text-sm font-bold text-blue-900 transition-all duration-300 hover:bg-yellow-300 hover:shadow-lg hover:shadow-yellow-400/25 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-yellow-400 focus-visible:ring-offset-2 focus-visible:ring-offset-blue-900"
            >
              <span class="relative z-10 min-w-0 break-words text-center leading-snug">
                {primaryBtn}
              </span>
              <svg
                class="relative z-10 size-4 transition-transform duration-300 group-hover:translate-x-1"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="m9 18 6-6-6-6" />
              </svg>
            </a>
          )
        }
        {
          secondaryBtn && (
            <a
              href={secondaryBtnURL}
              class="inline-flex items-center justify-center gap-x-2 rounded-lg border border-white/20 bg-white/5 px-6 py-3.5 text-sm font-bold text-white backdrop-blur-sm transition-all duration-300 hover:bg-white/10 hover:border-white/30"
            >
              {secondaryBtn}
            </a>
          )
        }
      </div>

      <!-- Trust indicators -->
      <div
        data-hero-trust
        class={trustClass}
      >
        {
          trustItems.map((item) => (
            <div class="flex items-center gap-2 text-sm text-blue-200/70">
              <svg
                class="size-4 text-yellow-400"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z"
                  clip-rule="evenodd"
                />
              </svg>
              {item}
            </div>
          ))
        }
      </div>

      <!-- Review Section -->
      {
        withReview ? (
          <div class="mt-8">
            <ReviewComponent
              avatars={avatars}
              starCount={starCount}
              rating={rating}
              reviews={reviews}
            />
          </div>
        ) : (
          ""
        )
      }
    </div>

    <!-- Hero Image Section -->
    <div data-hero-image class={imageWrapClass}>
      <!-- Glow effect behind image -->
      <div
        class="absolute inset-0 m-auto h-3/4 w-3/4 rounded-full bg-blue-400/20 blur-3xl"
      >
      </div>

      <div class={imageShellClass}>
        {
          src && alt && (
            <Image
              src={src}
              alt={alt}
              class={imageClass}
              draggable={"false"}
              loading={"eager"}
              format={"png"}
            />
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  /* Override the blue accent color in the title for the hero context */
  [data-hero-title] :global(.text-blue-600),
  [data-hero-title] :global(.dark\:text-blue-300) {
    color: #facc15 !important; /* yellow-400 for better contrast on dark hero bg */
  }

  @media (prefers-reduced-motion: reduce) {
    [data-hero] :global(.animate-float),
    [data-hero] :global(.animate-orb-1),
    [data-hero] :global(.animate-orb-2),
    [data-hero] :global(.animate-pulse) {
      animation: none !important;
    }
  }
</style>
