---
import MainLayout from "@/layouts/MainLayout.astro";
import ServiceLanding from "@components/sections/services/ServiceLanding.astro";
import { SITE } from "@data/constants";
import codeImage from "@images/code.jpg";
import { buildServiceSchema, buildWebPageSchema } from "@utils/seo";

const title = "SEO-Ready Websites Built With Technical Foundations";
const description =
  "Dawn Web builds SEO-ready websites with clear page structure, crawlable links, metadata, schema, sitemap hygiene, and fast responsive pages from launch.";
const pathname = "/services/seo-ready-websites";
const relatedServices = [
  {
    title: "Business Website Design",
    href: "/services/business-website-design",
    description: "Design a business website that explains your value and drives inquiries.",
  },
  {
    title: "Website Redesign",
    href: "/services/website-redesign",
    description: "Modernize an existing site while protecting search visibility.",
  },
  {
    title: "Custom Web Apps",
    href: "/services/custom-web-apps",
    description: "Build business tools and web applications with clean technical architecture.",
  },
];
---

<MainLayout
  title={`${title} | Dawn Web`}
  meta={description}
  structuredData={[
    buildWebPageSchema({
      title: `${title} | Dawn Web`,
      description,
      pathname,
      locale: "en",
      siteUrl: SITE.url,
    }),
    buildServiceSchema({
      name: title,
      description,
      pathname,
      serviceType: "SEO-ready website development",
      siteUrl: SITE.url,
    }),
  ]}
>
  <ServiceLanding
    eyebrow="SEO-ready websites"
    title={title}
    description={description}
    image={codeImage}
    imageAlt="Code editor showing a website build"
    benefits={[
      "Descriptive titles, meta descriptions, canonical URLs, Open Graph tags, and structured data.",
      "Crawlable navigation, clean internal links, semantic headings, and image alt text.",
      "Sitemap and robots setup plus launch checks for the pages Google should index.",
    ]}
    process={[
      "Define target pages, search intent, and the technical SEO checklist before build.",
      "Implement metadata, schemas, internal links, and responsive performance improvements.",
      "Validate generated HTML, sitemap, and structured data before deployment.",
    ]}
    relatedServices={relatedServices}
  />
</MainLayout>
