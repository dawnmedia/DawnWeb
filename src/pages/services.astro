---
import MainLayout from "@/layouts/MainLayout.astro";
import ServicesIndexShowcase from "@components/sections/services/ServicesIndexShowcase.astro";
import { SITE } from "@data/constants";
import webdev from "@images/web-dev.jpg";
import webdesign from "@images/web-design.jpg";
import software from "@images/software.jpg";
import code from "@images/code.jpg";
import motoViagens from "@images/motoviagens3.jpg";
import verbo from "@images/verbo_app_card.jpg";
import triplut from "@images/triplut6.jpg";
import {
  SEO_DESCRIPTIONS,
  SEO_TITLES,
  buildServiceSchema,
  buildWebPageSchema,
} from "@utils/seo";

const contactUrl = "/contact";
const pageTitle = SEO_TITLES.services;

const services = [
  {
    title: "Business Website Design",
    href: "/services/business-website-design",
    description:
      "A custom website that explains your offer clearly, builds trust quickly, and gives visitors an obvious next step.",
    outcome: "Turn confused visitors into qualified inquiries.",
    bestFor: "Best for new or unclear websites",
    deliverables: [
      "Homepage and service-page structure",
      "Conversion-focused messaging",
      "Responsive design and launch setup",
    ],
    image: webdesign,
    imageAlt: "Designer planning a business website interface",
  },
  {
    title: "Website Redesign",
    href: "/services/website-redesign",
    description:
      "A rebuild for outdated, quiet, or hard-to-use sites that need clearer messaging, faster pages, and better paths to contact.",
    outcome: "Make an existing site feel credible and easier to act on.",
    bestFor: "Best for underperforming sites",
    deliverables: [
      "UX and content audit",
      "Modern responsive layouts",
      "Migration-aware launch checks",
    ],
    image: webdev,
    imageAlt: "Team collaborating around a website redesign",
  },
  {
    title: "SEO-Ready Websites",
    href: "/services/seo-ready-websites",
    description:
      "A technical foundation for crawlable pages, clean metadata, structured data, semantic content, and launch hygiene.",
    outcome: "Launch with search basics handled from day one.",
    bestFor: "Best for visibility-focused builds",
    deliverables: [
      "Metadata and schema",
      "Crawlable page structure",
      "Sitemap and robots setup",
    ],
    image: code,
    imageAlt: "Code editor showing a website build",
  },
  {
    title: "Custom Web Apps",
    href: "/services/custom-web-apps",
    description:
      "Purpose-built portals, dashboards, booking tools, and integrations for teams that have outgrown static pages and spreadsheets.",
    outcome: "Replace manual workflows with focused software.",
    bestFor: "Best for operational tools",
    deliverables: [
      "Workflow and data planning",
      "Custom app interface",
      "Deployment and maintenance path",
    ],
    image: software,
    imageAlt: "Business software interface and workflow planning",
  },
];

const processSteps = [
  {
    title: "Discovery",
    description:
      "We clarify your audience, offer, current blockers, business goals, and what would make the project worth doing.",
  },
  {
    title: "Proposal",
    description:
      "You get a practical scope, recommended path, timeline, and cost before design or development begins.",
  },
  {
    title: "Development",
    description:
      "The website or app is designed, written, built, and reviewed with direct communication and clear decisions.",
  },
  {
    title: "Delivery",
    description:
      "Your project is launched, checked, and handed over with the foundations in place for support and future improvements.",
  },
];

const portfolioItems = [
  {
    title: "Moto Viagens",
    href: "/products/motoviagens",
    description:
      "A live motorcycle travel platform with booking-oriented flows, route content, multilingual support, and AI-assisted discovery.",
    image: motoViagens,
    imageAlt: "Moto Viagens Brazilian motorcycle routes and tours",
  },
  {
    title: "Verbo",
    href: "/products/verboai",
    description:
      "An AI language-learning product built around coaching, adaptive flashcards, subscriptions, and mobile support.",
    image: verbo,
    imageAlt: "Verbo AI language learning platform interface",
  },
  {
    title: "Triplut",
    href: "/products/triplut",
    description:
      "A travel-planning concept that brings routes, budgets, experiences, and AI guidance into a clearer planning flow.",
    image: triplut,
    imageAlt: "Illustration of Triplut AI travel platform",
  },
];
---

<MainLayout
  title={pageTitle}
  meta={SEO_DESCRIPTIONS.services}
  structuredData={[
    buildWebPageSchema({
      title: pageTitle,
      description: SEO_DESCRIPTIONS.services,
      pathname: "/services",
      locale: "en",
      siteUrl: SITE.url,
    }),
    buildServiceSchema({
      name: "Business Website Design Services",
      description: SEO_DESCRIPTIONS.services,
      pathname: "/services",
      serviceType: "Web design and web development",
      siteUrl: SITE.url,
    }),
  ]}
>
  <ServicesIndexShowcase
    eyebrow="Services"
    title="Websites and software that make the next step obvious"
    subTitle="Dawn Web helps service businesses explain their offer, earn trust, and turn more qualified visitors into inquiries through focused websites, redesigns, SEO-ready builds, and custom web apps."
    primaryCta="Book a free consultation"
    primaryCtaUrl={contactUrl}
    secondaryCta="See product work"
    secondaryCtaUrl="/products"
    proofPoints={[
      "You talk directly with the builder",
      "Clear scope before money is wasted",
      "Built to explain, load fast, and convert",
    ]}
    services={services}
    processEyebrow="Process"
    processTitle="A simple process that removes the guesswork"
    processSubTitle="Every service follows the same calm path: understand the problem, agree on the right scope, build with visible progress, and launch with the essentials handled."
    processSteps={processSteps}
    portfolioEyebrow="Proof"
    portfolioTitle="Proof from real digital products"
    portfolioSubTitle="The same product thinking behind our portfolio goes into service work: clear user paths, useful interfaces, and practical technical foundations."
    portfolioItems={portfolioItems}
    faqTitle="Questions before you book"
    faqs={[
      {
        question: "Do I need a full rebuild?",
        answer:
          "Not always. The first conversation is about finding the smallest useful path: a new site, a focused redesign, a technical cleanup, or a custom feature.",
      },
      {
        question: "Can SEO be included from the start?",
        answer:
          "Yes. SEO-ready builds include clean page structure, metadata, schema where useful, sitemap hygiene, and launch checks for crawlable pages.",
      },
      {
        question: "Do you build more than marketing websites?",
        answer:
          "Yes. Dawn Web also builds portals, dashboards, booking tools, and workflow apps when a business needs software instead of another static page.",
      },
      {
        question: "What happens after launch?",
        answer:
          "We can support maintenance, small improvements, security updates, and future product work so the site or app keeps improving after launch.",
      },
    ]}
    finalTitle="Ready to make your website easier to trust?"
    finalText="Bring the current site, idea, or workflow. We will help you clarify what should change and what is worth building first."
    finalCta="Book a free consultation"
    finalCtaUrl={contactUrl}
  />
</MainLayout>
