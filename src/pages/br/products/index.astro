---
import MainLayout from "@/layouts/MainLayout.astro";
import FeaturesStatsAlt from "@components/sections/features/FeaturesStatsAlt.astro";
import EcosystemShowcaseSection from "@components/sections/products/EcosystemShowcaseSection.astro";
import ProductShowcaseIndex from "@components/sections/products/ProductShowcaseIndex.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { SITE } from "@data/constants";
import { collectionIdStartsWithLocale, type Locale } from "@utils/locale";
import {
  isEcosystemProduct,
  sortProductsByMainId,
} from "@utils/products";
import { buildWebPageSchema } from "@utils/seo";

const locale: Locale = "br";

const allProducts: CollectionEntry<"products">[] = await getCollection(
  "products",
  ({ id }) =>
    collectionIdStartsWithLocale(id, locale),
);

const products = allProducts
  .filter((product) => !isEcosystemProduct(product, locale))
  .sort(sortProductsByMainId);

const ecosystemProducts = allProducts
  .filter((product) => isEcosystemProduct(product, locale))
  .sort(sortProductsByMainId);

const pageTitle = "Produtos de software & projetos digitais | Dawn Web";
const pageDescription =
  "Conheca produtos de software, plataformas web e conceitos de IA da Dawn Web com capturas, status, publico-alvo e escolhas tecnicas.";
---

<MainLayout
  title={pageTitle}
  meta={pageDescription}
  lang="pt-BR"
  structuredData={buildWebPageSchema({
    title: pageTitle,
    description: pageDescription,
    pathname: "/br/products",
    locale,
    siteUrl: SITE.url,
  })}
>
  <ProductShowcaseIndex
    products={products}
    locale={locale}
    eyebrow="Portfolio de produtos"
    title="Produtos de software claros desde o primeiro olhar"
    subTitle="Explore os apps web, conceitos de IA e plataformas digitais da Dawn Web por posicionamento, status, capturas de tela e escolhas tecnicas."
    ctaLabel="Planejar um produto"
    ctaUrl="/br/contact"
    viewLabel="Ver produto"
  />

  <EcosystemShowcaseSection
    products={ecosystemProducts}
    locale={locale}
    eyebrow="ECOSSISTEMA DAWN LABS"
    title="Criado dentro da Dawn Labs"
    description="Uma colecao de marcas internas, divisoes experimentais e futuros empreendimentos projetados e desenvolvidos pela Dawn Web."
    supportingLine="Esses projetos mostram como a Dawn Web cria nao apenas sites para clientes, mas identidades digitais completas, conceitos de produto e sistemas de marca de longo prazo."
    builtByLabel="Criado pela Dawn Web"
  />

  <div class="opacity-95">
    <FeaturesStatsAlt
      title="Por que escolher a Dawn Web?"
      subTitle="Transforme suas ideias em uma presenca online poderosa com a Dawn Web. Seja voce uma startup ou uma empresa estabelecida, oferecemos solucoes sob medida para alcancar seus objetivos."
      benefits={[
        "Sites de alta performance: projetamos e desenvolvemos sites personalizados, rapidos, confiaveis e otimizados para converter visitantes em clientes fieis.",
        "Solucoes escalaveis: nossa abordagem abrange desde landing pages simples ate plataformas integradas, com tecnologias modernas e faceis de manter.",
        "Acompanhamento duradouro: do lancamento ao sucesso a longo prazo, garantimos manutencao, seguranca e suporte especializado.",
      ]}
    />
  </div>
</MainLayout>
