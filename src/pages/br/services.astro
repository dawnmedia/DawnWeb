---
// Import necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import MainSection from "@components/ui/blocks/MainSection.astro";
import LeftSection from "@components/ui/blocks/LeftSection.astro";
import RightSection from "@components/ui/blocks/RightSection.astro";
import FeaturesStats from "@components/sections/features/FeaturesStats.astro";
// import { getRelativeLocaleUrl } from 'astro:i18n';

// Import necessary images
import webdev from "@images/web-dev.jpg";
import webdesign from "@images/web-design.jpg";
import webuild from "@images/webuild.jpg";
import payments from "@images/payments.jpg";
import software from "@images/software.jpg";
import code from "@images/code.jpg";
import business from "@images/business.jpg";
import graph from "@images/graph.jpg";
import type { ImageMetadata } from "astro";

interface BaseArticle {
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
}

interface RightArticle extends BaseArticle {
  isRightSection: true;
  single?: boolean;
  imgOne: ImageMetadata;
  imgOneAlt: string;
  imgTwo?: ImageMetadata;
  imgTwoAlt?: string;
}

interface LeftArticle extends BaseArticle {
  isRightSection: false;
  img: ImageMetadata;
  imgAlt: string;
}

type Article = RightArticle | LeftArticle;

const articles: Article[] = [
  {
    isRightSection: true,
    title: "Consultoria digital clara e confiável",
    subTitle:
      "Criar um site, produto digital ou sistema sob medida envolve muitas decisões. A Dawn Web ajuda você a definir escopo, tecnologia, experiência do usuário e prioridades para avançar com segurança.",
    single: false,
    imgOne: webdesign,
    imgOneAlt: "Pessoa planejando a interface de um site em um notebook",
    imgTwo: webdev,
    imgTwoAlt: "Pessoa desenvolvendo código em um computador",
  },
  {
    isRightSection: false,
    title: "Ideias transformadas em soluções reais",
    subTitle:
      "Nossa equipe combina estratégia, design e desenvolvimento para entregar landing pages, sites institucionais, aplicações e integrações que resolvem necessidades reais do negócio.",
    img: webuild,
    imgAlt: "Tela com código de desenvolvimento web",
    btnExists: true,
    btnTitle: "Ver ideias no blog",
    btnURL: "/br/blog",
  },
  {
    isRightSection: true,
    title: "Projetos conduzidos com organização",
    subTitle:
      "Da primeira conversa ao lançamento, organizamos etapas, alinhamentos e entregas para que você saiba o que está acontecendo, o que vem depois e como cada decisão impacta o resultado.",
    single: false,
    imgOne: payments,
    imgOneAlt: "Pessoa usando uma solução de pagamento digital",
    imgTwo: software,
    imgTwoAlt: "Profissional usando um sistema de atendimento",
  },
  {
    isRightSection: false,
    title: "Performance e suporte no longo prazo",
    subTitle:
      "A entrega não termina no lançamento. Mantemos seu projeto seguro, rápido e atualizado com suporte contínuo, melhorias planejadas e atenção à estabilidade.",
    img: code,
    imgAlt: "Tela exibindo código",
  },
  {
    isRightSection: true,
    title: "Estratégias sob medida para cada desafio",
    subTitle:
      "Quando a empresa precisa ir além de um site padrão, desenhamos soluções personalizadas para integrar processos, automatizar tarefas e apoiar o crescimento.",
    single: false,
    imgOne: business,
    imgOneAlt: "Espaço de planejamento de negócios",
    imgTwo: graph,
    imgTwoAlt: "Gráfico de crescimento digital",
    btnExists: true,
    btnTitle: "Ler mais",
    btnURL: "/br/blog",
  },
];
---
<MainLayout
  title="Serviços | Dawn Web"
  meta="Serviços de desenvolvimento web, consultoria digital, automações e soluções sob medida para empresas no Brasil."
  lang="pt-BR"
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://dawnwebs.com/br/services",
    url: "https://dawnwebs.com/br/services",
    name: "Serviços | Dawn Web",
    description:
      "Serviços de desenvolvimento web, consultoria digital, automações e soluções sob medida para empresas no Brasil.",
    isPartOf: {
      "@type": "WebSite",
      url: "https://dawnwebs.com/br",
      name: "Dawn Web",
      description:
        "A Dawn Web cria sites, produtos digitais e soluções personalizadas para empresas que querem crescer online.",
    },
    inLanguage: "pt-BR",
  }}
>
  <!--MainSection is the introductory section of the page, it also contains a CTA button-->
    <!-- getRelativeLocaleUrl("fr", "/contact") -->
  <MainSection
    title="Una estratégia, design e tecnologia"
    subTitle="A Dawn Web cria sites, produtos digitais e soluções de software para transformar ideias em experiências rápidas, claras e prontas para crescer. Acompanhamos cada etapa, da descoberta ao lançamento."
    btnExists={true}
    btnTitle="Agendar uma consulta"
    btnURL="https://calendly.com/contact-dawnwebs/30min"
  
  />
  <!-- RightSection and LeftSection contain details about various services along with pertinent imagery.
  They alternate for variety in design.
  The 'btnExists' property is used to toggle the display of a button in these sections.
  When btnExists={true}, a button is displayed.
  This can be used to link to more detailed information or related resources.
  RightSection can also conditionally render one or two images based on the 'single' property.
  If 'single' is true, it displays one image, otherwise it displays two.
  -->
  {
    articles.map((article) => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      );
    })
  }
  <!--FeaturesStats section showcases essential stats valuable to users-->
  <FeaturesStats
    title="Em números"
    subTitle="A Dawn Web trabalha para entregar projetos claros, confiáveis e fáceis de evoluir. Estes números mostram o cuidado que colocamos em cada parceria."
    mainStatTitle="98 %"
    mainStatSubTitle="dos clientes consideram a experiência com a Dawn Web excelente"
    stats={[
      {
        stat: "99 %",
        description: "dos projetos conduzidos até a entrega",
      },
      {
        stat: "1 000+",
        description: "horas dedicadas a criação, suporte e melhoria",
      },
      {
        stat: "85 %",
        description: "de crescimento anual observado em canais digitais de clientes",
      },
    ]}
  />
</MainLayout>
