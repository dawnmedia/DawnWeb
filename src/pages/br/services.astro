---
import MainLayout from "@/layouts/MainLayout.astro";
import ServicesIndexShowcase from "@components/sections/services/ServicesIndexShowcase.astro";
import { SITE } from "@data/constants";
import webdev from "@images/web-dev.jpg";
import webdesign from "@images/web-design.jpg";
import software from "@images/software.jpg";
import code from "@images/code.jpg";
import motoViagens from "@images/motoviagens3.jpg";
import verbo from "@images/verbo_app_card.jpg";
import triplut from "@images/triplut6.jpg";
import { buildServiceSchema, buildWebPageSchema } from "@utils/seo";

const contactUrl = "/br/contact";
const pageTitle = "Servicos de sites e software | Dawn Web";
const pageDescription =
  "A Dawn Web cria sites, redesigns, bases SEO e aplicativos web sob medida para empresas que querem mais contatos qualificados.";

const services = [
  {
    title: "Design de site profissional",
    href: "/br/contact",
    description:
      "Um site sob medida que explica sua oferta, aumenta a confianca e guia visitantes para o proximo passo.",
    outcome: "Transformar visitantes confusos em contatos qualificados.",
    bestFor: "Ideal para sites novos ou pouco claros",
    deliverables: [
      "Estrutura de paginas clara",
      "Mensagem focada em conversao",
      "Design responsivo e lancamento",
    ],
    image: webdesign,
    imageAlt: "Designer planejando uma interface de site profissional",
  },
  {
    title: "Redesign de site",
    href: "/br/contact",
    description:
      "Uma reconstrução para sites antigos, lentos ou dificeis de usar, com mensagem mais clara e melhor caminho ate o contato.",
    outcome: "Deixar seu site mais confiavel e facil de agir.",
    bestFor: "Ideal para sites com baixo desempenho",
    deliverables: [
      "Auditoria de UX e conteudo",
      "Layouts modernos e responsivos",
      "Checagens antes do lancamento",
    ],
    image: webdev,
    imageAlt: "Equipe colaborando em um redesign de site",
  },
  {
    title: "Sites prontos para SEO",
    href: "/br/contact",
    description:
      "Fundacoes tecnicas para paginas rastreaveis, metadados limpos, dados estruturados e arquitetura clara.",
    outcome: "Lancar com as bases de busca ja tratadas.",
    bestFor: "Ideal para projetos focados em visibilidade",
    deliverables: [
      "Metadados e schema",
      "Estrutura rastreavel",
      "Sitemap e robots",
    ],
    image: code,
    imageAlt: "Editor de codigo mostrando a construcao de um site",
  },
  {
    title: "Apps web sob medida",
    href: "/br/contact",
    description:
      "Portais, paineis, reservas e integracoes criados para substituir processos manuais e ferramentas desconectadas.",
    outcome: "Transformar fluxos manuais em software focado.",
    bestFor: "Ideal para ferramentas operacionais",
    deliverables: [
      "Planejamento de fluxo e dados",
      "Interface de aplicativo sob medida",
      "Deploy e caminho de manutencao",
    ],
    image: software,
    imageAlt: "Interface de software empresarial e planejamento de fluxo",
  },
];

const processSteps = [
  {
    title: "Descoberta",
    description:
      "Entendemos publico, oferta, bloqueios atuais, metas do negocio e o que faria o projeto valer a pena.",
  },
  {
    title: "Proposta",
    description:
      "Voce recebe escopo, caminho recomendado, prazo e custo antes de comecar design ou desenvolvimento.",
  },
  {
    title: "Desenvolvimento",
    description:
      "O site ou app e planejado, escrito, construido e revisado com comunicacao direta.",
  },
  {
    title: "Entrega",
    description:
      "O projeto e lancado, verificado e entregue com as bases prontas para suporte e melhorias futuras.",
  },
];

const portfolioItems = [
  {
    title: "Moto Viagens",
    href: "/br/products/motoviagens",
    description:
      "Uma plataforma de mototurismo com fluxos de reserva, conteudo de rotas, suporte multilingue e descoberta com IA.",
    image: motoViagens,
    imageAlt: "Moto Viagens rotas e passeios de moto no Brasil",
  },
  {
    title: "Verbo",
    href: "/br/products/verboai",
    description:
      "Um produto de aprendizado de idiomas com IA, coaching, flashcards adaptativos, assinaturas e suporte mobile.",
    image: verbo,
    imageAlt: "Interface da plataforma de aprendizado Verbo AI",
  },
  {
    title: "Triplut",
    href: "/br/products/triplut",
    description:
      "Um conceito de planejamento de viagens que conecta rotas, orcamentos, experiencias e orientacao por IA.",
    image: triplut,
    imageAlt: "Ilustracao da plataforma de viagens com IA Triplut",
  },
];
---

<MainLayout
  title={pageTitle}
  meta={pageDescription}
  lang="pt-BR"
  structuredData={[
    buildWebPageSchema({
      title: pageTitle,
      description: pageDescription,
      pathname: "/br/services",
      locale: "br",
      siteUrl: SITE.url,
    }),
    buildServiceSchema({
      name: "Servicos de sites e software",
      description: pageDescription,
      pathname: "/br/services",
      serviceType: "Web design and web development",
      siteUrl: SITE.url,
    }),
  ]}
>
  <ServicesIndexShowcase
    eyebrow="Servicos"
    title="Sites e softwares que deixam o proximo passo claro"
    subTitle="A Dawn Web ajuda empresas a explicar sua oferta, gerar confianca e transformar mais visitantes qualificados em contatos com sites, redesigns, bases SEO e apps web."
    primaryCta="Agendar uma consulta"
    primaryCtaUrl={contactUrl}
    secondaryCta="Ver produtos"
    secondaryCtaUrl="/br/products"
    proofPoints={[
      "Voce fala direto com quem constroi",
      "Escopo claro antes de investir",
      "Feito para explicar, carregar rapido e converter",
    ]}
    services={services}
    processEyebrow="Processo"
    processTitle="Um processo simples que remove a duvida"
    processSubTitle="Todo servico segue o mesmo caminho: entender o problema, definir o escopo certo, construir com visibilidade e lancar com as bases prontas."
    processSteps={processSteps}
    portfolioEyebrow="Provas"
    portfolioTitle="Provas em produtos digitais reais"
    portfolioSubTitle="A mesma logica de produto guia nossos servicos: caminhos claros, interfaces uteis e fundacoes tecnicas praticas."
    portfolioItems={portfolioItems}
    faqTitle="Perguntas antes de agendar"
    faqs={[
      {
        question: "Preciso reconstruir tudo?",
        answer:
          "Nem sempre. A primeira conversa serve para encontrar o menor caminho util: novo site, redesign focado, limpeza tecnica ou recurso sob medida.",
      },
      {
        question: "SEO pode entrar desde o comeco?",
        answer:
          "Sim. Builds prontos para SEO incluem estrutura clara, metadados, schema quando util, sitemap e checagens de lancamento.",
      },
      {
        question: "Voces fazem mais que sites institucionais?",
        answer:
          "Sim. A Dawn Web tambem cria portais, paineis, ferramentas de reserva e apps para fluxos de trabalho.",
      },
      {
        question: "O que acontece depois do lancamento?",
        answer:
          "Podemos apoiar manutencao, melhorias, atualizacoes de seguranca e evolucoes de produto.",
      },
    ]}
    finalTitle="Pronto para deixar seu site mais claro e confiavel?"
    finalText="Traga seu site atual, ideia ou fluxo de trabalho. Vamos ajudar a decidir o que mudar primeiro."
    finalCta="Agendar uma consulta"
    finalCtaUrl={contactUrl}
  />
</MainLayout>
