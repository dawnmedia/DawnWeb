---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import ContactSectionBR from "@components/sections/misc/ContactSectionBR.astro";
---

<!--Utilizing MainLayout for the outer layout of the page, and defining meta for SEO purposes-->
<MainLayout
  title="Contato | Dawn Web"
  meta="Fale com a Dawn Web para planejar seu site, produto digital, automação ou solução personalizada."
  lang="pt-BR"
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://dawnwebs.com/br/contact",
    url: "https://dawnwebs.com/br/contact",
    name: "Contato | Dawn Web",
    description:
      "Fale com a Dawn Web para planejar seu site, produto digital, automação ou solução personalizada.",
    isPartOf: {
      "@type": "WebSite",
      url: "https://dawnwebs.com/br/",
      name: "Dawn Web",
      description:
        "A Dawn Web cria sites, produtos digitais e soluções personalizadas para empresas que querem crescer online.",
    },
    inLanguage: "pt-BR",
  }}
>
  <ContactSectionBR />
</MainLayout>
