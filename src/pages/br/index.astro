---
import { Image } from "astro:assets";
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import FAQ from "@components/sections/misc/FAQ.astro";
import AnnouncementBanner from "@components/ui/banners/AnnouncementBanner.astro";
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import heroImage from "@images/hero.png";
import motoViagens from "@images/motoviagens3.jpg";
import verbo from "@images/verbo_app_card.jpg";
import triplut from "@images/triplut6.jpg";
import luna from "@images/lunaai.png";
import faqs from "@data/br/faqs.json";
import { SITE } from "@data/constants";
import {
  buildFaqSchema,
  buildWebPageSchema,
  buildWebSiteSchema,
} from "@utils/seo";

const contactUrl = "/br/contact";
const primaryCta = "Agendar uma consulta gratuita";
const pageTitle = "Sites que param de desperdiçar bons leads | Dawn Web";
const pageDescription =
  "A Dawn Web corrige sites confusos, redesenha páginas que não convertem e desenvolve aplicações web sob medida para empresas de serviços que precisam de mais contatos qualificados.";

const proofPoints = [
  { text: "Você fala direto com quem constrói", icon: "💬" },
  { text: "Escopo claro antes de gastar sem direção", icon: "🎯" },
  { text: "Criado para explicar, carregar rápido e converter", icon: "⚡" },
];

const services = [
  {
    title: "Um novo site que explica sua oferta",
    href: "/br/services",
    description:
      "Quando o prospect não entende seu valor em poucos segundos, ele vai embora. Tenha um site claro que mostra sua oferta e leva ao contato.",
    accent: "from-blue-400 to-blue-600",
  },
  {
    title: "Corrigir um site antigo ou que não converte",
    href: "/br/services",
    description:
      "Se seu site parece datado, confuso ou parado, refaça a mensagem e o caminho para que visitantes saibam por que confiar e qual é o próximo passo.",
    accent: "from-yellow-400 to-orange-500",
  },
  {
    title: "Base de SEO antes de publicar",
    href: "/br/services",
    description:
      "Um bom site não deveria ir ao ar com o básico de busca faltando. Estrutura, metadados, schema, sitemap e conteúdo rastreável entram desde o início.",
    accent: "from-blue-300 to-blue-500",
  },
  {
    title: "Aplicações web para substituir trabalho manual",
    href: "/br/services",
    description:
      "Quando planilhas, formulários e ferramentas soltas atrasam a operação, crie um portal, dashboard, sistema de reservas ou ferramenta interna do jeito que sua equipe trabalha.",
    accent: "from-orange-400 to-yellow-400",
  },
];

const founderAdvantages = [
  "Seu feedback chega direto a quem decide",
  "Mensagem, estrutura e código ficam alinhados",
  "Menos reuniões para explicar a mesma coisa de novo",
  "Decisões práticas antes do design e do desenvolvimento",
];

const projects = [
  {
    title: "Moto Viagens",
    href: "/br/products/motoviagens",
    image: motoViagens,
    imageAlt: "Rotas e viagens de moto no Brasil com Moto Viagens",
    description:
      "Uma plataforma online de viagem de moto para quem planeja rotas, passeios e estadias pelo Brasil.",
    context:
      "A Dawn Web desenvolveu a experiência voltada para reserva com páginas de passeios, busca de hospedagens, conteúdo de eventos, navegação por rotas, suporte multilíngue e exploração assistida por IA.",
  },
  {
    title: "Verbo",
    href: "/br/products/verboai",
    image: verbo,
    imageAlt: "Interface da plataforma de aprendizado de idiomas Verbo",
    description:
      "Um produto de aprendizado de idiomas com IA, pensado para prática, retenção e hábito diário de estudo.",
    context:
      "A plataforma reúne conversação, flashcards adaptativos, jornadas de aprendizado, assinaturas e suporte mobile em uma experiência focada.",
  },
  {
    title: "Triplut",
    href: "/br/products/triplut",
    image: triplut,
    imageAlt: "Ilustração da plataforma de viagens com IA Triplut",
    description:
      "Um conceito de produto para planejar viagens, organizar rotas, orçamento e detalhes práticos em um só lugar.",
    context:
      "O trabalho explora como transporte, hospedagem, experiências, orçamento e ajuda por IA podem virar um fluxo de planejamento mais claro.",
  },
  {
    title: "Luna AI",
    href: "/br/products/luna",
    image: luna,
    imageAlt: "Mascote e assistente digital Luna AI da Dawn Web",
    description:
      "O conceito de assistente interno da Dawn Web, criado para orientar melhor usuários dentro de produtos digitais.",
    context:
      "A Luna está sendo moldada como uma camada prática de ajuda para navegação em produtos, suporte contextual e fluxos mais personalizados.",
  },
];

const processSteps = [
  {
    title: "Descoberta",
    description:
      "Identificamos onde os visitantes se perdem, o que seu negócio precisa do site e o que faria o projeto realmente valer a pena.",
  },
  {
    title: "Proposta",
    description:
      "Você recebe escopo claro, caminho recomendado, prazo e investimento antes de qualquer design ou desenvolvimento começar.",
  },
  {
    title: "Desenvolvimento",
    description:
      "O site ou aplicação é escrito, desenhado e desenvolvido com atualizações frequentes e decisões diretas, sem repasses lentos.",
  },
  {
    title: "Entrega",
    description:
      "Seu projeto é lançado, revisado e entregue com as bases necessárias para você entender o que mudou e o que vem depois.",
  },
];
---

<MainLayout
  title={pageTitle}
  meta={pageDescription}
  lang="pt-BR"
  structuredData={[
    buildWebSiteSchema(SITE.url),
    buildWebPageSchema({
      title: pageTitle,
      description: pageDescription,
      pathname: "/br",
      locale: "br",
      siteUrl: SITE.url,
    }),
    buildFaqSchema({ faqs: faqs.faqs }),
  ]}
>
  <AnnouncementBanner
    btnId="dismiss-button"
    badge="Auditoria gratuita de clareza"
    title="Encontre os vazamentos que podem estar custando leads"
    description="Receba uma análise rápida do que confunde seus visitantes antes de refazer o site, fazer redesign ou gastar mais com tráfego."
    btnTitle={primaryCta}
    url={contactUrl}
  />

  <HeroSection
    slot="hero"
    title={`Seu site deveria gerar <span class="text-blue-600 dark:text-blue-300">leads qualificados</span>, não deixar bons visitantes confusos`}
    subTitle="Se seu site parece bom, mas não explica sua oferta, não gera confiança ou não deixa o próximo passo óbvio, você provavelmente está perdendo contatos. A Dawn Web corrige mensagem, estrutura e desenvolvimento para os clientes certos entenderem por que falar com você."
    primaryBtn={primaryCta}
    primaryBtnURL={contactUrl}
    withReview={false}
    src={heroImage}
    alt="Ambiente de trabalho da Dawn Web para criação de sites e desenvolvimento web"
    badgeLabel="Estúdio web liderado pelo fundador"
    trustItems={["Liderado pelo fundador", "Sem repasses", "Pronto para SEO"]}
    containedByHeroBand={true}
  />

  <section
    class="mx-auto max-w-[85rem] px-4 py-8 sm:px-6 lg:px-8 lg:py-10 2xl:max-w-full"
    aria-label="Pontos de confiança da Dawn Web"
  >
    <div class="grid gap-4 md:grid-cols-3">
      {
        proofPoints.map((point) => (
          <div class="group flex items-center gap-4 rounded-xl border border-neutral-200/60 bg-white/60 px-5 py-4 shadow-sm backdrop-blur-sm transition-all duration-300 hover:border-blue-300/50 hover:shadow-md dark:border-neutral-700/60 dark:bg-neutral-800/60 dark:hover:border-blue-500/30">
            <span class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-blue-50 text-lg dark:bg-blue-900/30">
              {point.icon}
            </span>
            <span class="text-sm font-bold text-neutral-800 dark:text-neutral-200">
              {point.text}
            </span>
          </div>
        ))
      }
    </div>
  </section>

  <section
    class="mx-auto max-w-[85rem] px-4 pb-16 pt-10 sm:px-6 lg:px-8 lg:pb-20 lg:pt-14 2xl:max-w-full"
    data-reveal
  >
    <div class="max-w-3xl">
      <div
        class="mb-2 inline-flex items-center gap-2 rounded-full border border-blue-200/50 bg-blue-50 px-3 py-1 dark:border-blue-800/50 dark:bg-blue-900/20"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
        <span
          class="text-xs font-bold uppercase tracking-wider text-blue-700 dark:text-blue-300"
          >Serviços</span
        >
      </div>
      <h2
        class="mt-2 text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight"
      >
        Corrija as partes do site que fazem você perder leads
      </h2>
      <p class="mt-3 text-pretty text-neutral-700 dark:text-neutral-400">
        Cada serviço começa pelo problema real: visitantes em dúvida, páginas
        com cara de antigas, base de SEO fraca ou trabalho manual travando a
        operação.
      </p>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {
        services.map((service, i) => (
          <a
            href={service.href}
            class="group relative flex h-full flex-col overflow-hidden rounded-xl border border-neutral-200/60 bg-white/70 p-6 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-blue-300/50 hover:shadow-xl dark:border-neutral-700/60 dark:bg-neutral-800/70 dark:hover:border-blue-500/30"
          >
            <div
              class={`absolute inset-x-0 top-0 h-1 bg-gradient-to-r ${service.accent} opacity-70 transition-opacity duration-300 group-hover:opacity-100`}
            />
            <span class="mb-4 text-xs font-bold text-neutral-400 dark:text-neutral-500">
              0{i + 1}
            </span>
            <h3 class="text-lg font-bold text-neutral-800 dark:text-neutral-200">
              {service.title}
            </h3>
            <p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">
              {service.description}
            </p>
            <p class="mt-auto flex items-center gap-1 pt-5 text-sm font-bold text-blue-600 transition-transform duration-300 group-hover:translate-x-1 dark:text-blue-300">
              Saiba mais
              <svg
                class="size-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m9 18 6-6-6-6"
                />
              </svg>
            </p>
          </a>
        ))
      }
    </div>

    <div class="mt-10">
      <PrimaryCTA title={primaryCta} url={contactUrl} />
    </div>
  </section>

  <section
    class="relative overflow-hidden bg-gradient-to-br from-blue-800 via-blue-900 to-[#0a1a3c] py-12 lg:py-16"
    data-reveal
  >
    <div
      class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-yellow-400/5 blur-3xl"
    >
    </div>
    <div
      class="absolute -bottom-20 -left-20 h-64 w-64 rounded-full bg-blue-400/10 blur-3xl"
    >
    </div>
    <div
      class="relative mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8 2xl:max-w-full"
    >
      <div class="relative grid gap-10 md:grid-cols-2 lg:gap-16">
        <div>
          <div
            class="mb-3 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 backdrop-blur-sm"
          >
            <span class="h-1.5 w-1.5 rounded-full bg-yellow-400"></span>
            <span
              class="text-xs font-bold uppercase tracking-wider text-blue-100"
              >Liderado pelo fundador, sem ruído de agência</span
            >
          </div>
          <h2
            class="mt-3 text-balance text-2xl font-bold tracking-tight text-white md:text-4xl md:leading-tight"
          >
            Sem repasses inúteis. Sem filtro comercial. Só decisões claras.
          </h2>
        </div>
        <div>
          <p class="text-pretty text-blue-100/80">
            Muitos projetos de agência ficam lentos porque quem ouve seus
            objetivos não é quem molda o trabalho. Na Dawn Web, você trabalha
            diretamente com Andrew Henrice, o desenvolvedor full-stack que
            lidera estratégia, arquitetura e entrega.
          </p>
          <p class="mt-4 text-pretty text-blue-100/80">
            Isso reduz perda de informação, acelera decisões e cria um site ou
            aplicativo em torno do resultado que você precisa, não de um pacote
            genérico.
          </p>
          <div
            class="mt-8 grid gap-x-6 gap-y-4 sm:grid-cols-2"
            data-stagger-parent
          >
            {
              founderAdvantages.map((advantage) => (
                <div
                  data-stagger-child
                  class="flex items-start gap-3 border-t border-white/10 pt-4"
                >
                  <svg
                    class="mt-0.5 size-5 shrink-0 text-yellow-400"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span class="text-sm font-semibold text-white/90">
                    {advantage}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <section
    class="mx-auto max-w-[85rem] px-4 py-12 sm:px-6 lg:px-8 lg:py-16 2xl:max-w-full"
    data-reveal
  >
    <div
      class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between"
    >
      <div class="max-w-3xl">
        <div
          class="mb-2 inline-flex items-center gap-2 rounded-full border border-blue-200/50 bg-blue-50 px-3 py-1 dark:border-blue-800/50 dark:bg-blue-900/20"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
          <span
            class="text-xs font-bold uppercase tracking-wider text-blue-700 dark:text-blue-300"
            >Portfólio</span
          >
        </div>
        <h2
          class="mt-2 text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight"
        >
          Produtos reais com usos claros
        </h2>
        <p class="mt-3 text-pretty text-neutral-700 dark:text-neutral-400">
          Um olhar direto para o que foi construído, quem usa e qual problema o
          produto precisava resolver.
        </p>
      </div>
      <PrimaryCTA title={primaryCta} url={contactUrl} />
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-2">
      {
        projects.map((project) => (
          <a
            href={project.href}
            class="group relative overflow-hidden rounded-xl border border-neutral-200/60 bg-white/70 shadow-sm backdrop-blur-sm transition-all duration-500 hover:-translate-y-1 hover:shadow-xl dark:border-neutral-700/60 dark:bg-neutral-800/70"
          >
            <div class="aspect-[16/9] overflow-hidden bg-neutral-200 dark:bg-neutral-900">
              <Image
                src={project.image}
                alt={project.imageAlt}
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
            </div>
            <div class="relative p-6">
              <h3 class="text-xl font-bold text-neutral-800 dark:text-neutral-200">
                {project.title}
              </h3>
              <p class="mt-2 text-sm font-semibold leading-6 text-neutral-700 dark:text-neutral-300">
                {project.description}
              </p>
              <p class="mt-2 text-sm leading-6 text-neutral-500 dark:text-neutral-400">
                {project.context}
              </p>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-bold text-blue-600 transition-transform duration-300 group-hover:translate-x-1 dark:text-blue-300">
                Ver projeto
                <svg
                  class="size-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m9 18 6-6-6-6"
                  />
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section
    class="mx-auto max-w-[85rem] px-4 py-12 sm:px-6 lg:px-8 lg:py-16 2xl:max-w-full"
    data-reveal
  >
    <div class="max-w-3xl">
      <div
        class="mb-2 inline-flex items-center gap-2 rounded-full border border-blue-200/50 bg-blue-50 px-3 py-1 dark:border-blue-800/50 dark:bg-blue-900/20"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
        <span
          class="text-xs font-bold uppercase tracking-wider text-blue-700 dark:text-blue-300"
          >Processo</span
        >
      </div>
      <h2
        class="mt-2 text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight"
      >
        Um processo simples que tira a dúvida do caminho
      </h2>
    </div>

    <div class="relative mt-12">
      <div
        class="absolute left-0 right-0 top-8 hidden h-0.5 bg-gradient-to-r from-blue-400 via-yellow-400 to-blue-400 opacity-20 md:block"
        data-process-line
      >
      </div>
      <div class="grid gap-6 md:grid-cols-4" data-stagger-parent>
        {
          processSteps.map((step, index) => (
            <div data-stagger-child class="relative">
              <div class="relative z-10 mb-6 hidden md:block">
                <div
                  data-process-dot
                  class="mx-auto flex size-16 items-center justify-center rounded-full border-2 border-blue-400/30 bg-white shadow-lg dark:border-blue-500/30 dark:bg-neutral-800"
                >
                  <span class="bg-gradient-to-br from-blue-500 to-blue-700 bg-clip-text text-xl font-black text-transparent">
                    0{index + 1}
                  </span>
                </div>
              </div>
              <div class="rounded-xl border border-neutral-200/60 bg-white/70 p-6 shadow-sm backdrop-blur-sm transition-all duration-300 hover:shadow-md dark:border-neutral-700/60 dark:bg-neutral-800/70">
                <span class="mb-3 inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-bold text-blue-600 dark:bg-blue-900/30 dark:text-blue-300 md:hidden">
                  0{index + 1}
                </span>
                <h3 class="text-lg font-bold text-neutral-800 dark:text-neutral-200">
                  {step.title}
                </h3>
                <p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">
                  {step.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section
    class="relative overflow-hidden bg-white/50 py-12 dark:bg-neutral-900/20 lg:py-16"
    data-reveal
  >
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.03]"
      style="background-image: url('/banner-pattern.svg'); background-size: cover;"
    >
    </div>
    <div
      class="absolute -left-20 -top-20 h-40 w-40 rounded-full bg-blue-400/10 blur-3xl"
    >
    </div>
    <div
      class="absolute -bottom-20 -right-20 h-40 w-40 rounded-full bg-yellow-400/10 blur-3xl"
    >
    </div>
    <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <div
        class="mb-4 inline-flex items-center gap-2 rounded-full border border-blue-200/50 bg-blue-50 px-3 py-1 dark:border-blue-800/50 dark:bg-blue-900/20"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
        <span
          class="text-xs font-bold uppercase tracking-wider text-blue-700 dark:text-blue-300"
          >Confiança</span
        >
      </div>
      <h2
        class="mt-2 text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight"
      >
        Muitos sites parecem bons. O problema é o que eles deixam de dizer.
      </h2>
      <p
        class="mt-6 text-pretty text-lg leading-8 text-neutral-600 dark:text-neutral-400"
      >
        Um site pode parecer profissional e ainda assim perder leads. Isso
        acontece quando a oferta é vaga, a prova é fraca, o CTA fica escondido
        ou a página responde perguntas que o comprador nem está fazendo.
      </p>
      <p
        class="mt-4 text-pretty text-lg leading-8 text-neutral-600 dark:text-neutral-400"
      >
        A Dawn Web constrói primeiro em torno da clareza para o comprador. Copy,
        UX, SEO, performance e funcionalidades sob medida têm o mesmo papel:
        fazer o visitante certo se sentir entendido e pronto para conversar.
      </p>
    </div>
  </section>

  <FAQ title="Perguntas<br />frequentes" faqs={faqs} />

  <section
    class="relative overflow-hidden bg-gradient-to-br from-blue-800 via-blue-900 to-[#08162f] px-4 py-14 text-center sm:px-6 lg:px-8 lg:py-20"
    data-reveal
  >
    <div
      class="absolute -left-32 -top-32 h-64 w-64 rounded-full bg-blue-400/10 blur-3xl"
    >
    </div>
    <div
      class="absolute -bottom-32 -right-32 h-64 w-64 rounded-full bg-yellow-400/5 blur-3xl"
    >
    </div>
    <div
      class="absolute inset-0 opacity-[0.02]"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 24px 24px;"
    >
    </div>
    <div class="relative mx-auto max-w-[85rem] 2xl:max-w-full">
      <h2
        class="mx-auto max-w-3xl text-balance text-3xl font-bold tracking-tight text-white md:text-5xl"
      >
        Pare de deixar páginas confusas afastarem bons visitantes.
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-pretty text-blue-100/70">
        Agende uma consulta gratuita e saia com um próximo passo prático para
        seu site, redesign, projeto pronto para SEO ou aplicação web sob medida.
      </p>
      <div class="mt-10">
        <a
          href={contactUrl}
          class="group inline-flex items-center justify-center gap-x-2 rounded-lg bg-yellow-400 px-8 py-4 text-sm font-bold text-blue-900 transition-all duration-300 hover:bg-yellow-300 hover:shadow-lg hover:shadow-yellow-400/25"
        >
          {primaryCta}
          <svg
            class="size-4 transition-transform duration-300 group-hover:translate-x-1"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="m9 18 6-6-6-6"></path></svg
          >
