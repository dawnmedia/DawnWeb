---
import { Image } from "astro:assets";
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import FAQ from "@components/sections/misc/FAQ.astro";
import AnnouncementBanner from "@components/ui/banners/AnnouncementBanner.astro";
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import heroImage from "@images/hero.png";
import motoViagens from "@images/motoviagens3.jpg";
import verbo from "@images/verbo_app_card.jpg";
import triplut from "@images/triplut6.jpg";
import luna from "@images/lunaai.png";
import faqs from "@data/faqs.json";
import { SITE } from "@data/constants";
import {
  SEO_DESCRIPTIONS,
  SEO_TITLES,
  buildFaqSchema,
  buildWebPageSchema,
  buildWebSiteSchema,
} from "@utils/seo";

const contactUrl = "/contact";
const primaryCta = "Book a free consultation";

const proofPoints = [
  { text: "You talk directly with the builder", icon: "💬" },
  { text: "Clear scope before money is wasted", icon: "🎯" },
  { text: "Built to explain, load fast, and convert", icon: "⚡" },
];

const services = [
  {
    title: "New Website That Explains Your Offer",
    href: "/services/business-website-design",
    description:
      "When prospects cannot understand what you do in seconds, they leave. Get a focused site that makes your value obvious and guides them toward an inquiry.",
    accent: "from-blue-400 to-blue-600",
  },
  {
    title: "Fix an Outdated or Underperforming Site",
    href: "/services/website-redesign",
    description:
      "If your current site feels old, unclear, or quiet, redesign the message and flow so visitors know why to trust you and what to do next.",
    accent: "from-yellow-400 to-orange-500",
  },
  {
    title: "SEO Foundations Before You Publish",
    href: "/services/seo-ready-websites",
    description:
      "A good site should not launch with search basics missing. Build pages with clean structure, metadata, schema, sitemap setup, and crawlable content from day one.",
    accent: "from-blue-300 to-blue-500",
  },
  {
    title: "Custom Web Apps for Manual Workflows",
    href: "/services/custom-web-apps",
    description:
      "When spreadsheets, forms, and disconnected tools slow the business down, build a portal, dashboard, booking flow, or internal tool around how your team actually works.",
    accent: "from-orange-400 to-yellow-400",
  },
];

const founderAdvantages = [
  "Your feedback reaches the person making the decisions",
  "Copy, structure, and code stay connected",
  "Fewer meetings to explain the same thing twice",
  "Practical tradeoffs before design and development start",
];

const projects = [
  {
    title: "Moto Viagens",
    href: "/products/motoviagens",
    image: motoViagens,
    imageAlt: "Moto Viagens Brazilian motorcycle routes and tours",
    description:
      "A live motorcycle travel platform for riders planning routes, tours, and stays across Brazil.",
    context:
      "Dawn Web developed the booking-oriented experience with tour pages, accommodation discovery, event content, route-focused browsing, multilingual support, and AI-assisted exploration.",
  },
  {
    title: "Verbo",
    href: "/products/verboai",
    image: verbo,
    imageAlt: "Verbo AI language learning platform interface",
    description:
      "An AI language-learning product built around practice, retention, and daily study habits.",
    context:
      "The platform brings together conversation practice, adaptive flashcards, learning journeys, subscriptions, and mobile support in a focused product experience.",
  },
  {
    title: "Triplut",
    href: "/products/triplut",
    image: triplut,
    imageAlt: "Illustration of Triplut AI travel platform",
    description:
      "A travel-planning product concept for organizing routes, budgets, and trip details in one place.",
    context:
      "The work explores how transport, lodging, experiences, budget planning, and AI guidance can fit into a clearer planning flow.",
  },
  {
    title: "Luna AI",
    href: "/products/luna",
    image: luna,
    imageAlt: "Luna AI mascot and digital assistant for Dawn Web",
    description:
      "Dawn Web's in-house assistant concept for clearer guidance inside digital products.",
    context:
      "Luna is being shaped as a practical assistant layer for product navigation, contextual help, and more personalized user flows.",
  },
];

const processSteps = [
  {
    title: "Discovery",
    description:
      "We find out where visitors get confused, what your business needs from the site, and what would make the project worth doing.",
  },
  {
    title: "Proposal",
    description:
      "You get a clear scope, recommended path, timeline, and cost before design or development starts.",
  },
  {
    title: "Development",
    description:
      "The site or app is written, designed, and built with regular updates and direct decisions instead of slow handoffs.",
  },
  {
    title: "Delivery",
    description:
      "Your project is launched, checked, and handed over with the essentials in place so you know what changed and what comes next.",
  },
];
---

<MainLayout
  title={SEO_TITLES.home}
  meta={SEO_DESCRIPTIONS.home}
  structuredData={[
    buildWebSiteSchema(SITE.url),
    buildWebPageSchema({
      title: SEO_TITLES.home,
      description: SEO_DESCRIPTIONS.home,
      pathname: "/",
      locale: "en",
      siteUrl: SITE.url,
    }),
    buildFaqSchema({ faqs: faqs.faqs }),
  ]}
>
  <AnnouncementBanner
    btnId="dismiss-button"
    badge="Free clarity audit"
    title="Find the leaks that may be costing your website leads"
    description="Get a quick review of what is confusing visitors before you rebuild, redesign, or spend more on traffic."
    btnTitle={primaryCta}
    url={contactUrl}
  />

  <HeroSection
    slot="hero"
    title={`Your website should bring qualified <span class="text-blue-600 dark:text-blue-300">leads</span>, not leave good visitors confused`}
    subTitle="If your site looks fine but does not explain your offer, earn trust, or make the next step obvious, you are likely losing inquiries. Dawn Web fixes the message, structure, and build so the right clients know why to contact you."
    primaryBtn={primaryCta}
    primaryBtnURL={contactUrl}
    withReview={false}
    src={heroImage}
    alt="Dawn Web website design and web development workspace"
    badgeLabel="Strategic web partner"
    trustItems={["Founder-led", "No handoffs", "SEO-ready"]}
    containedByHeroBand={true}
  />

  <!-- Proof Points -->
  <section
    class="mx-auto max-w-[85rem] px-4 py-8 sm:px-6 lg:px-8 lg:py-10 2xl:max-w-full"
    aria-label="Dawn Web proof points"
  >
    <div class="grid gap-4 md:grid-cols-3">
      {
        proofPoints.map((point) => (
          <div class="group flex items-center gap-4 rounded-xl border border-neutral-200/60 bg-white/60 px-5 py-4 shadow-sm backdrop-blur-sm transition-all duration-300 hover:border-blue-300/50 hover:shadow-md dark:border-neutral-700/60 dark:bg-neutral-800/60 dark:hover:border-blue-500/30">
            <span class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-blue-50 text-lg dark:bg-blue-900/30">
              {point.icon}
            </span>
            <span class="text-sm font-bold text-neutral-800 dark:text-neutral-200">
              {point.text}
            </span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Services -->
  <section
    class="mx-auto max-w-[85rem] px-4 pb-16 pt-10 sm:px-6 lg:px-8 lg:pb-20 lg:pt-14 2xl:max-w-full"
    data-reveal
  >
    <div class="max-w-3xl">
      <div
        class="mb-2 inline-flex items-center gap-2 rounded-full border border-blue-200/50 bg-blue-50 px-3 py-1 dark:border-blue-800/50 dark:bg-blue-900/20"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
        <span
          class="text-xs font-bold uppercase tracking-wider text-blue-700 dark:text-blue-300"
          >Services</span
        >
      </div>
      <h2
        class="mt-3 text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight"
      >
        Fix the parts of your website that lose leads
      </h2>
      <p class="mt-3 text-pretty text-neutral-600 dark:text-neutral-400">
        Each service starts with the real problem: visitors are unsure, pages
        feel outdated, search foundations are weak, or manual work is slowing
        you down.
      </p>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {
        services.map((service, i) => (
          <a
            href={service.href}
            class="group relative flex h-full flex-col overflow-hidden rounded-xl border border-neutral-200/60 bg-white/70 p-6 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-blue-300/50 hover:shadow-xl dark:border-neutral-700/60 dark:bg-neutral-800/70 dark:hover:border-blue-500/30"
          >
            <div
              class={`absolute inset-x-0 top-0 h-1 bg-gradient-to-r ${service.accent} opacity-70 transition-opacity duration-300 group-hover:opacity-100`}
            />
            <span class="mb-4 text-xs font-bold text-neutral-400 dark:text-neutral-500">
              0{i + 1}
            </span>
            <h3 class="text-lg font-bold text-neutral-800 dark:text-neutral-200">
              {service.title}
            </h3>
            <p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">
              {service.description}
            </p>
            <p class="mt-auto flex items-center gap-1 pt-5 text-sm font-bold text-blue-600 transition-transform duration-300 group-hover:translate-x-1 dark:text-blue-300">
              Learn more
              <svg
                class="size-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m9 18 6-6-6-6"
                />
              </svg>
            </p>
          </a>
        ))
      }
    </div>

    <div class="mt-10">
      <PrimaryCTA title={primaryCta} url={contactUrl} />
    </div>
  </section>

  <!-- Founder-Led Section -->
  <section
    class="relative overflow-hidden bg-gradient-to-br from-blue-800 via-blue-900 to-[#0a1a3c] py-12 lg:py-16"
    data-reveal
  >
    <!-- Decorative elements -->
    <div
      class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-yellow-400/5 blur-3xl"
    >
    </div>
    <div
      class="absolute -bottom-20 -left-20 h-64 w-64 rounded-full bg-blue-400/10 blur-3xl"
    >
    </div>
    <div
      class="absolute right-8 top-8 text-[120px] font-bold leading-none text-white/[0.03] select-none"
      aria-hidden="true"
    >
      "
    </div>

    <div
      class="relative mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8 2xl:max-w-full"
    >
      <div class="relative grid gap-10 md:grid-cols-2 lg:gap-16">
        <div>
          <div
            class="mb-3 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 backdrop-blur-sm"
          >
            <span class="h-1.5 w-1.5 rounded-full bg-yellow-400"></span>
            <span
              class="text-xs font-bold uppercase tracking-wider text-blue-100"
              >Founder-led, without the agency fog</span
            >
          </div>
          <h2
            class="mt-3 text-balance text-2xl font-bold tracking-tight text-white md:text-4xl md:leading-tight"
          >
            No handoffs. No account-manager filter. Just clear decisions.
          </h2>
        </div>
        <div>
          <p class="text-pretty text-blue-100/80">
            Most agency projects slow down because the person hearing your goals
            is not the person shaping the work. With Dawn Web, you work directly
            with Andrew Henrice, the full-stack developer leading strategy,
            architecture, and delivery.
          </p>
          <p class="mt-4 text-pretty text-blue-100/80">
            That means fewer translation gaps, faster decisions, and a website
            or app built around the outcome you actually need, not a generic
            package.
          </p>
          <div
            class="mt-8 grid gap-x-6 gap-y-4 sm:grid-cols-2"
            data-stagger-parent
          >
            {
              founderAdvantages.map((advantage) => (
                <div
                  data-stagger-child
                  class="flex items-start gap-3 border-t border-white/10 pt-4"
                >
                  <svg
                    class="mt-0.5 size-5 shrink-0 text-yellow-400"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span class="text-sm font-semibold text-white/90">
                    {advantage}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio -->
  <section
    class="mx-auto max-w-[85rem] px-4 py-12 sm:px-6 lg:px-8 lg:py-16 2xl:max-w-full"
    data-reveal
  >
    <div
      class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between"
    >
      <div class="max-w-3xl">
        <div
          class="mb-2 inline-flex items-center gap-2 rounded-full border border-blue-200/50 bg-blue-50 px-3 py-1 dark:border-blue-800/50 dark:bg-blue-900/20"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
          <span
            class="text-xs font-bold uppercase tracking-wider text-blue-700 dark:text-blue-300"
            >Portfolio</span
          >
        </div>
        <h2
          class="mt-3 text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight"
        >
          Real products with clear use cases
        </h2>
        <p class="mt-3 text-pretty text-neutral-600 dark:text-neutral-400">
          A grounded look at what was built, who it serves, and the problem it
          was designed to solve.
        </p>
      </div>
      <PrimaryCTA title={primaryCta} url={contactUrl} />
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-2">
      {
        projects.map((project) => (
          <a
            href={project.href}
            class="group relative overflow-hidden rounded-xl border border-neutral-200/60 bg-white/70 shadow-sm backdrop-blur-sm transition-all duration-500 hover:-translate-y-1 hover:shadow-xl dark:border-neutral-700/60 dark:bg-neutral-800/70"
          >
            <div class="aspect-[16/9] overflow-hidden bg-neutral-200 dark:bg-neutral-900">
              <Image
                src={project.image}
                alt={project.imageAlt}
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
                format="avif"
                width={760}
                sizes="(min-width: 768px) 50vw, 100vw"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
            </div>
            <div class="relative p-6">
              <h3 class="text-xl font-bold text-neutral-800 dark:text-neutral-200">
                {project.title}
              </h3>
              <p class="mt-2 text-sm font-semibold leading-6 text-neutral-700 dark:text-neutral-300">
                {project.description}
              </p>
              <p class="mt-2 text-sm leading-6 text-neutral-500 dark:text-neutral-400">
                {project.context}
              </p>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-bold text-blue-600 transition-transform duration-300 group-hover:translate-x-1 dark:text-blue-300">
                View project
                <svg
                  class="size-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m9 18 6-6-6-6"
                  />
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Process -->
  <section
    class="mx-auto max-w-[85rem] px-4 py-12 sm:px-6 lg:px-8 lg:py-16 2xl:max-w-full"
    data-reveal
  >
    <div class="max-w-3xl">
      <div
        class="mb-2 inline-flex items-center gap-2 rounded-full border border-blue-200/50 bg-blue-50 px-3 py-1 dark:border-blue-800/50 dark:bg-blue-900/20"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
        <span
          class="text-xs font-bold uppercase tracking-wider text-blue-700 dark:text-blue-300"
          >Process</span
        >
      </div>
      <h2
        class="mt-3 text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight"
      >
        A simple process that removes the guesswork
      </h2>
    </div>

    <!-- Timeline -->
    <div class="relative mt-12">
      <!-- Connecting line (desktop) -->
      <div
        class="absolute left-0 right-0 top-8 hidden h-0.5 bg-gradient-to-r from-blue-400 via-yellow-400 to-blue-400 opacity-20 md:block"
        data-process-line
      >
      </div>

      <div class="grid gap-6 md:grid-cols-4" data-stagger-parent>
        {
          processSteps.map((step, index) => (
            <div data-stagger-child class="relative">
              <div class="relative z-10 mb-6 hidden md:block">
                <div
                  data-process-dot
                  class="mx-auto flex size-16 items-center justify-center rounded-full border-2 border-blue-400/30 bg-white shadow-lg dark:border-blue-500/30 dark:bg-neutral-800"
                >
                  <span class="bg-gradient-to-br from-blue-500 to-blue-700 bg-clip-text text-xl font-black text-transparent">
                    0{index + 1}
                  </span>
                </div>
              </div>
              <div class="rounded-xl border border-neutral-200/60 bg-white/70 p-6 shadow-sm backdrop-blur-sm transition-all duration-300 hover:shadow-md dark:border-neutral-700/60 dark:bg-neutral-800/70">
                <span class="mb-3 inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-bold text-blue-600 dark:bg-blue-900/30 dark:text-blue-300 md:hidden">
                  0{index + 1}
                </span>
                <h3 class="text-lg font-bold text-neutral-800 dark:text-neutral-200">
                  {step.title}
                </h3>
                <p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">
                  {step.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Trust -->
  <section
    class="relative overflow-hidden bg-white/50 py-12 dark:bg-neutral-900/20 lg:py-16"
    data-reveal
  >
    <!-- Decorative background -->
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.03]"
      style="background-image: url('/banner-pattern.svg'); background-size: cover;"
    >
    </div>
    <div
      class="absolute -left-20 -top-20 h-40 w-40 rounded-full bg-blue-400/10 blur-3xl"
    >
    </div>
    <div
      class="absolute -bottom-20 -right-20 h-40 w-40 rounded-full bg-yellow-400/10 blur-3xl"
    >
    </div>

    <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <div
        class="mb-4 inline-flex items-center gap-2 rounded-full border border-blue-200/50 bg-blue-50 px-3 py-1 dark:border-blue-800/50 dark:bg-blue-900/20"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
        <span
          class="text-xs font-bold uppercase tracking-wider text-blue-700 dark:text-blue-300"
          >Trust</span
        >
      </div>
      <h2
        class="mt-3 text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight"
      >
        Most websites look fine. The problem is what they <span
          class="bg-gradient-to-r from-blue-600 to-blue-400 bg-clip-text text-transparent dark:from-blue-300 dark:to-yellow-300"
          >fail to say</span
        >.
      </h2>
      <p
        class="mt-6 text-pretty text-lg leading-8 text-neutral-600 dark:text-neutral-400"
      >
        A website can look polished and still lose leads. It happens when the
        offer is vague, the proof is weak, the CTA is buried, or the page
        answers questions your buyers are not asking.
      </p>
      <p
        class="mt-4 text-pretty text-lg leading-8 text-neutral-600 dark:text-neutral-400"
      >
        Dawn Web builds around buyer clarity first. Copy, UX, SEO, performance,
        and custom functionality all support the same job: making the right
        visitor feel understood and ready to start a conversation.
      </p>
    </div>
  </section>

  <FAQ title="Common<br />questions" faqs={faqs} />

  <!-- Final CTA -->
  <section
    class="relative overflow-hidden bg-gradient-to-br from-blue-800 via-blue-900 to-[#08162f] px-4 py-14 text-center sm:px-6 lg:px-8 lg:py-20"
    data-reveal
  >
    <!-- Decorative elements -->
    <div
      class="absolute -left-32 -top-32 h-64 w-64 rounded-full bg-blue-400/10 blur-3xl"
    >
    </div>
    <div
      class="absolute -bottom-32 -right-32 h-64 w-64 rounded-full bg-yellow-400/5 blur-3xl"
    >
    </div>
    <div
      class="absolute inset-0 opacity-[0.02]"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 24px 24px;"
    >
    </div>

    <div class="relative mx-auto max-w-[85rem] 2xl:max-w-full">
      <h2
        class="mx-auto max-w-3xl text-balance text-3xl font-bold tracking-tight text-white md:text-5xl"
      >
        Stop letting unclear pages turn good visitors away.
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-pretty text-blue-100/70">
        Book a free consultation and leave with a practical next step for your
        website, redesign, SEO-ready build, or custom web app.
      </p>
      <div class="mt-10">
        <a
          href={contactUrl}
          class="group inline-flex items-center justify-center gap-x-2 rounded-lg bg-yellow-400 px-8 py-4 text-sm font-bold text-blue-900 transition-all duration-300 hover:bg-yellow-300 hover:shadow-lg hover:shadow-yellow-400/25"
        >
          {primaryCta}
          <svg
            class="size-4 transition-transform duration-300 group-hover:translate-x-1"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="m9 18 6-6-6-6"></path></svg
          >
        </a>
      </div>
    </div>
  </section>
</MainLayout>
