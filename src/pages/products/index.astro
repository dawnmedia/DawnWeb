---
import MainLayout from "@/layouts/MainLayout.astro";
import EcosystemShowcaseSection from "@components/sections/products/EcosystemShowcaseSection.astro";
import ProductShowcaseIndex from "@components/sections/products/ProductShowcaseIndex.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { SITE } from "@data/constants";
import { collectionIdStartsWithLocale, type Locale } from "@utils/locale";
import { isEcosystemProduct, sortProductsByMainId } from "@utils/products";
import { SEO_DESCRIPTIONS, SEO_TITLES, buildWebPageSchema } from "@utils/seo";

const locale: Locale = "en";

const allProducts: CollectionEntry<"products">[] = await getCollection(
  "products",
  (entry: CollectionEntry<"products">) =>
    collectionIdStartsWithLocale(entry.id, locale),
);

const products = allProducts
  .filter((product) => !isEcosystemProduct(product, locale))
  .sort(sortProductsByMainId);

const ecosystemProducts = allProducts
  .filter((product) => isEcosystemProduct(product, locale))
  .sort(sortProductsByMainId);

const pageTitle = SEO_TITLES.products;
---

<MainLayout
  title={pageTitle}
  meta={SEO_DESCRIPTIONS.products}
  structuredData={buildWebPageSchema({
    title: pageTitle,
    description: SEO_DESCRIPTIONS.products,
    pathname: "/products",
    locale,
    siteUrl: SITE.url,
  })}
>
  <ProductShowcaseIndex
    products={products}
    locale={locale}
    eyebrow="Product portfolio"
    title="Software products built to be understood at a glance"
    subTitle="Explore Dawn Web's web apps, AI concepts, and digital platforms through clear product positioning, live status, screenshots, and the technical choices behind each build."
    ctaLabel="Plan a Product"
    ctaUrl="/contact"
    viewLabel="View product"
  />

  <EcosystemShowcaseSection
    products={ecosystemProducts}
    locale={locale}
    eyebrow="DAWN LABS ECOSYSTEM"
    title="Built Inside Dawn Labs"
    description="A collection of internal brands, experimental divisions, and future ventures designed and developed by Dawn Web."
    supportingLine="These projects show how Dawn Web builds not only client websites, but complete digital identities, product concepts, and long-term brand systems."
  />

  <section
    class="relative isolate overflow-hidden bg-neutral-50 py-20 dark:bg-neutral-950 sm:py-28"
  >
    <div
      class="absolute inset-0 -z-10 bg-[linear-gradient(135deg,#f1f5f9_0%,#f8fafc_58%,#e2e8f0_100%)] dark:bg-[linear-gradient(135deg,#111827_0%,#111111_58%,#050505_100%)]"
    >
    </div>
    <div class="mx-auto max-w-7xl px-6 text-center lg:px-8">
      <h2
        class="mx-auto max-w-2xl text-4xl font-bold tracking-tight text-neutral-900 dark:text-white sm:text-5xl"
      >
        Ready to build your next digital product?
      </h2>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-neutral-600 dark:text-neutral-300">
        Whether you need a custom web app, an AI integration, or a complete
        digital platform, we design and develop solutions tailored to your
        business goals.
      </p>
      <div class="mt-10 flex items-center justify-center gap-x-6">
        <a
          href="/contact"
          class="group relative inline-flex items-center justify-center overflow-hidden rounded-lg border border-blue-600/20 bg-blue-500 px-8 py-4 font-bold text-white shadow-lg shadow-blue-500/20 transition hover:-translate-y-0.5 hover:bg-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-white dark:border-white/10 dark:shadow-2xl dark:shadow-blue-950/30 dark:focus:ring-offset-neutral-950"
        >
          Start a project
          <svg
            class="ml-2 h-5 w-5 transition-transform group-hover:translate-x-1"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</MainLayout>
