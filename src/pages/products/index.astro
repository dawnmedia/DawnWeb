---
import MainLayout from "@/layouts/MainLayout.astro";
import FeaturesStatsAlt from "@components/sections/features/FeaturesStatsAlt.astro";
import ProductShowcaseIndex from "@components/sections/products/ProductShowcaseIndex.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { SITE } from "@data/constants";
import { collectionIdStartsWithLocale, type Locale } from "@utils/locale";
import {
  SEO_DESCRIPTIONS,
  SEO_TITLES,
  buildWebPageSchema,
} from "@utils/seo";

const locale: Locale = "en";

const products: CollectionEntry<"products">[] = (
  await getCollection("products", (entry: CollectionEntry<"products">) =>
    collectionIdStartsWithLocale(entry.id, locale),
  )
).sort(
  (a: CollectionEntry<"products">, b: CollectionEntry<"products">) =>
    a.data.main.id - b.data.main.id,
);

const pageTitle = SEO_TITLES.products;
---

<MainLayout
  title={pageTitle}
  meta={SEO_DESCRIPTIONS.products}
  structuredData={buildWebPageSchema({
    title: pageTitle,
    description: SEO_DESCRIPTIONS.products,
    pathname: "/products",
    locale,
    siteUrl: SITE.url,
  })}
>
  <ProductShowcaseIndex
    products={products}
    locale={locale}
    eyebrow="Product portfolio"
    title="Software products built to be understood at a glance"
    subTitle="Explore Dawn Web's web apps, AI concepts, and digital platforms through clear product positioning, live status, screenshots, and the technical choices behind each build."
    ctaLabel="Plan a Product"
    ctaUrl="/contact"
    viewLabel="View product"
  />

  <div class="opacity-95">
    <FeaturesStatsAlt
      title="Why Choose Dawn Web?"
      subTitle="Transform your ideas into a powerful online presence with Dawn Web. Whether you're a startup launching your first website or an established business looking to upgrade your digital foundation, we deliver expert solutions tailored to your goals."
      benefits={[
        "High-performance websites: We design and develop custom websites that are fast, reliable, and optimized to convert visitors into loyal customers.",
        "Scalable development solutions: Our approach covers everything from simple landing pages to fully integrated platforms, built with modern frameworks, optimized for growth, and easy to maintain.",
        "Reliable ongoing support: From launch to long-term success, we provide continuous maintenance, security updates, and expert assistance to ensure your website performs flawlessly every day.",
      ]}
    />
  </div>
</MainLayout>
