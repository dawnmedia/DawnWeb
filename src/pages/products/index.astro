---
import MainLayout from "@/layouts/MainLayout.astro";
import EcosystemShowcaseSection from "@components/sections/products/EcosystemShowcaseSection.astro";
import ProductShowcaseIndex from "@components/sections/products/ProductShowcaseIndex.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { SITE } from "@data/constants";
import { collectionIdStartsWithLocale, type Locale } from "@utils/locale";
import {
  isEcosystemProduct,
  sortProductsByMainId,
} from "@utils/products";
import {
  SEO_DESCRIPTIONS,
  SEO_TITLES,
  buildWebPageSchema,
} from "@utils/seo";

const locale: Locale = "en";

const allProducts: CollectionEntry<"products">[] = await getCollection(
  "products",
  (entry: CollectionEntry<"products">) =>
    collectionIdStartsWithLocale(entry.id, locale),
);

const products = allProducts
  .filter((product) => !isEcosystemProduct(product, locale))
  .sort(sortProductsByMainId);

const ecosystemProducts = allProducts
  .filter((product) => isEcosystemProduct(product, locale))
  .sort(sortProductsByMainId);

const pageTitle = SEO_TITLES.products;
---

<MainLayout
  title={pageTitle}
  meta={SEO_DESCRIPTIONS.products}
  structuredData={buildWebPageSchema({
    title: pageTitle,
    description: SEO_DESCRIPTIONS.products,
    pathname: "/products",
    locale,
    siteUrl: SITE.url,
  })}
>
  <ProductShowcaseIndex
    products={products}
    locale={locale}
    eyebrow="Product portfolio"
    title="Software products built to be understood at a glance"
    subTitle="Explore Dawn Web's web apps, AI concepts, and digital platforms through clear product positioning, live status, screenshots, and the technical choices behind each build."
    ctaLabel="Plan a Product"
    ctaUrl="/contact"
    viewLabel="View product"
  />

  <EcosystemShowcaseSection
    products={ecosystemProducts}
    locale={locale}
    eyebrow="DAWN LABS ECOSYSTEM"
    title="Built Inside Dawn Labs"
    description="A collection of internal brands, experimental divisions, and future ventures designed and developed by Dawn Web."
    supportingLine="These projects show how Dawn Web builds not only client websites, but complete digital identities, product concepts, and long-term brand systems."
    builtByLabel="Built by Dawn Web"
  />

  <!-- Custom Final CTA -->
  <section class="relative isolate overflow-hidden bg-neutral-900 py-24 sm:py-32">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-blue-900/40 via-neutral-900 to-neutral-900"></div>
    <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
      <h2 class="mx-auto max-w-2xl text-4xl font-bold tracking-tight text-white sm:text-5xl">
        Ready to build your next digital product?
      </h2>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-neutral-300">
        Whether you need a custom web app, an AI integration, or a complete digital platform, we design and develop solutions tailored to your business goals.
      </p>
      <div class="mt-10 flex items-center justify-center gap-x-6">
        <a href="/contact" class="group relative inline-flex items-center justify-center overflow-hidden rounded-full bg-blue-600 px-8 py-4 font-bold text-white transition-all hover:bg-blue-500 hover:scale-105 hover:shadow-[0_0_40px_-10px_rgba(59,130,246,0.8)] focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-neutral-900">
          <span class="absolute inset-0 rounded-full border border-white/20"></span>
          Start a project
          <svg class="ml-2 h-5 w-5 transition-transform group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</MainLayout>
