---
import { Image } from "astro:assets";
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import FAQ from "@components/sections/misc/FAQ.astro";
import AnnouncementBanner from "@components/ui/banners/AnnouncementBanner.astro";
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import heroImage from "@images/hero.png";
import motoViagens from "@images/motoviagens3.jpg";
import verbo from "@images/verbo_app_card.jpg";
import triplut from "@images/triplut6.jpg";
import luna from "@images/lunaai.png";
import faqs from "@data/es/faqs.json";
import { SITE } from "@data/constants";
import { buildFaqSchema, buildWebPageSchema, buildWebSiteSchema } from "@utils/seo";

const contactUrl = "/es/contact";
const primaryCta = "Reservar una consulta gratuita";
const pageTitle = "Sitios web que dejan de perder buenos leads | Dawn Web";
const pageDescription =
  "Dawn Web mejora sitios web poco claros, rediseña páginas de bajo rendimiento y crea aplicaciones web a medida para empresas de servicios que necesitan más consultas calificadas.";

const proofPoints = [
  { text: "Hablas directamente con quien construye", icon: "💬" },
  { text: "Alcance claro antes de gastar de más", icon: "🎯" },
  { text: "Creado para explicar, cargar rápido y convertir", icon: "⚡" },
];

const services = [
  {
    title: "Un nuevo sitio web que explica tu oferta",
    href: "/es/services/business-website-design",
    description:
      "Si un prospecto no entiende lo que haces en segundos, se va. Crea un sitio enfocado que haga evidente tu valor y lo guíe hacia una consulta.",
    accent: "from-blue-400 to-blue-600",
  },
  {
    title: "Mejora un sitio desactualizado o de bajo rendimiento",
    href: "/es/services/website-redesign",
    description:
      "Si tu sitio se siente viejo, confuso o silencioso, rediseñamos el mensaje y el recorrido para que los visitantes sepan por qué confiar y qué hacer después.",
    accent: "from-yellow-400 to-orange-500",
  },
  {
    title: "Bases SEO antes de publicar",
    href: "/es/services/seo-ready-websites",
    description:
      "Un buen sitio no debería lanzarse con lo básico de búsqueda pendiente. Estructura, metadatos, schema, sitemap y contenido rastreable desde el primer día.",
    accent: "from-blue-300 to-blue-500",
  },
  {
    title: "Aplicaciones web para flujos manuales",
    href: "/es/services/custom-web-apps",
    description:
      "Cuando hojas de cálculo, formularios y herramientas desconectadas frenan al negocio, construimos portales, dashboards, reservas o herramientas internas según cómo trabaja tu equipo.",
    accent: "from-orange-400 to-yellow-400",
  },
];

const founderAdvantages = [
  "Tus comentarios llegan a quien toma las decisiones",
  "Copy, estructura y código se mantienen conectados",
  "Menos reuniones para explicar lo mismo dos veces",
  "Decisiones prácticas antes de diseñar y desarrollar",
];

const projects = [
  {
    title: "Moto Viagens",
    href: "/es/products/motoviagens",
    image: motoViagens,
    imageAlt: "Rutas y tours en moto por Brasil con Moto Viagens",
    description: "Una plataforma real de viajes en moto para planificar rutas, tours y estadías en Brasil.",
    context:
      "Dawn Web desarrolló una experiencia orientada a reservas con páginas de tours, búsqueda de alojamientos, eventos, navegación por rutas, soporte multilingüe y exploración asistida por IA.",
  },
  {
    title: "Verbo",
    href: "/es/products/verboai",
    image: verbo,
    imageAlt: "Interfaz de la plataforma de aprendizaje de idiomas Verbo AI",
    description: "Un producto de aprendizaje de idiomas con IA, diseñado alrededor de práctica, retención y hábito diario.",
    context:
      "La plataforma une práctica conversacional, flashcards adaptativas, rutas de aprendizaje, suscripciones y soporte móvil en una experiencia enfocada.",
  },
  {
    title: "Triplut",
    href: "/es/products/triplut",
    image: triplut,
    imageAlt: "Ilustración de la plataforma de viajes con IA Triplut",
    description: "Un concepto de planificación de viajes para organizar rutas, presupuestos y detalles en un solo lugar.",
    context:
      "El trabajo explora cómo transporte, alojamiento, experiencias, presupuesto y guía de IA pueden encajar en un flujo de planificación más claro.",
  },
  {
    title: "Luna AI",
    href: "/es/products/luna",
    image: luna,
    imageAlt: "Mascota y asistente digital Luna AI de Dawn Web",
    description: "El concepto de asistente interno de Dawn Web para ofrecer guía más clara dentro de productos digitales.",
    context:
      "Luna se está desarrollando como una capa práctica de asistencia para navegación de producto, ayuda contextual y flujos más personalizados.",
  },
];

const processSteps = [
  { title: "Descubrimiento", description: "Identificamos dónde se confunden los visitantes, qué necesita el negocio del sitio y qué haría que el proyecto valga la pena." },
  { title: "Propuesta", description: "Recibes alcance claro, camino recomendado, calendario y costo antes de iniciar diseño o desarrollo." },
  { title: "Desarrollo", description: "El sitio o app se escribe, diseña y construye con avances regulares y decisiones directas." },
  { title: "Entrega", description: "El proyecto se lanza, se revisa y se entrega con lo esencial para saber qué cambió y qué sigue." },
];
---

<MainLayout
  title={pageTitle}
  meta={pageDescription}
  lang="es"
  structuredData={[
    buildWebSiteSchema(SITE.url),
    buildWebPageSchema({ title: pageTitle, description: pageDescription, pathname: "/es", locale: "es", siteUrl: SITE.url }),
    buildFaqSchema({ faqs: faqs.faqs }),
  ]}
>
  <AnnouncementBanner
    btnId="dismiss-button"
    badge="Auditoría gratuita de claridad"
    title="Encuentra las fugas que pueden estar costándole leads a tu sitio"
    description="Recibe una revisión rápida de lo que confunde a tus visitantes antes de reconstruir, rediseñar o invertir más en tráfico."
    btnTitle={primaryCta}
    url={contactUrl}
  />

  <HeroSection
    slot="hero"
    title={`Tu sitio web debería generar <span class="text-blue-600 dark:text-blue-300">leads calificados</span>, no dejar confundidos a buenos visitantes`}
    subTitle="Si tu sitio se ve bien pero no explica tu oferta, no genera confianza o no deja claro el siguiente paso, probablemente estás perdiendo consultas. Dawn Web corrige el mensaje, la estructura y la construcción para que los clientes adecuados sepan por qué contactarte."
    primaryBtn={primaryCta}
    primaryBtnURL={contactUrl}
    withReview={false}
    src={heroImage}
    alt="Espacio de trabajo de Dawn Web para diseño y desarrollo web"
    badgeLabel="Socio web estratégico"
    trustItems={["Dirigido por el fundador", "Sin traspasos innecesarios", "Preparado para SEO"]}
    containedByHeroBand={true}
  />

  <section class="mx-auto max-w-[85rem] px-4 py-8 sm:px-6 lg:px-8 lg:py-10 2xl:max-w-full" aria-label="Puntos de confianza de Dawn Web">
    <div class="grid gap-4 md:grid-cols-3">
      {proofPoints.map((point) => (
        <div class="group flex items-center gap-4 rounded-xl border border-neutral-200/60 bg-white/60 px-5 py-4 shadow-sm backdrop-blur-sm transition-all duration-300 hover:border-blue-300/50 hover:shadow-md dark:border-neutral-700/60 dark:bg-neutral-800/60 dark:hover:border-blue-500/30">
          <span class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-blue-50 text-lg dark:bg-blue-900/30">{point.icon}</span>
          <span class="text-sm font-bold text-neutral-800 dark:text-neutral-200">{point.text}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-[85rem] px-4 pb-16 pt-10 sm:px-6 lg:px-8 lg:pb-20 lg:pt-14 2xl:max-w-full" data-reveal>
    <div class="max-w-3xl">
      <div class="mb-2 inline-flex items-center gap-2 rounded-full border border-blue-200/50 bg-blue-50 px-3 py-1 dark:border-blue-800/50 dark:bg-blue-900/20">
        <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
        <span class="text-xs font-bold uppercase tracking-wider text-blue-700 dark:text-blue-300">Servicios</span>
      </div>
      <h2 class="mt-3 text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight">
        Arregla las partes de tu sitio que pierden leads
      </h2>
      <p class="mt-3 text-pretty text-neutral-600 dark:text-neutral-400">
        Cada servicio parte del problema real: visitantes inseguros, páginas desactualizadas, bases SEO débiles o trabajo manual que frena al equipo.
      </p>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {services.map((service, i) => (
        <a href={service.href} class="group relative flex h-full flex-col overflow-hidden rounded-xl border border-neutral-200/60 bg-white/70 p-6 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-blue-300/50 hover:shadow-xl dark:border-neutral-700/60 dark:bg-neutral-800/70 dark:hover:border-blue-500/30">
          <div class={`absolute inset-x-0 top-0 h-1 bg-gradient-to-r ${service.accent} opacity-70 transition-opacity duration-300 group-hover:opacity-100`} />
          <span class="mb-4 text-xs font-bold text-neutral-400 dark:text-neutral-500">0{i + 1}</span>
          <h3 class="text-lg font-bold text-neutral-800 dark:text-neutral-200">{service.title}</h3>
          <p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">{service.description}</p>
          <p class="mt-auto flex items-center gap-1 pt-5 text-sm font-bold text-blue-600 transition-transform duration-300 group-hover:translate-x-1 dark:text-blue-300">Saber más</p>
        </a>
      ))}
    </div>
    <div class="mt-10"><PrimaryCTA title={primaryCta} url={contactUrl} /></div>
  </section>

  <section class="relative overflow-hidden bg-gradient-to-br from-blue-800 via-blue-900 to-[#0a1a3c] py-12 lg:py-16" data-reveal>
    <div class="relative mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8 2xl:max-w-full">
      <div class="relative grid gap-10 md:grid-cols-2 lg:gap-16">
        <div>
          <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-yellow-400"></span>
            <span class="text-xs font-bold uppercase tracking-wider text-blue-100">Dirigido por el fundador, sin niebla de agencia</span>
          </div>
          <h2 class="mt-3 text-balance text-2xl font-bold tracking-tight text-white md:text-4xl md:leading-tight">
            Sin traspasos. Sin filtro de account manager. Solo decisiones claras.
          </h2>
        </div>
        <div>
          <p class="text-pretty text-blue-100/80">
            Muchos proyectos de agencia se vuelven lentos porque quien escucha tus objetivos no es quien da forma al trabajo. Con Dawn Web, trabajas directamente con Andrew Henrice, el desarrollador full stack que lidera estrategia, arquitectura y entrega.
          </p>
          <p class="mt-4 text-pretty text-blue-100/80">
            Eso significa menos pérdidas de contexto, decisiones más rápidas y un sitio o app creado alrededor del resultado que realmente necesitas.
          </p>
          <div class="mt-8 grid gap-x-6 gap-y-4 sm:grid-cols-2">
            {founderAdvantages.map((advantage) => (
              <div class="flex items-start gap-3 border-t border-white/10 pt-4">
                <span class="mt-0.5 text-yellow-400">✓</span>
                <span class="text-sm font-semibold text-white/90">{advantage}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[85rem] px-4 py-12 sm:px-6 lg:px-8 lg:py-16 2xl:max-w-full" data-reveal>
    <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
      <div class="max-w-3xl">
        <div class="mb-2 inline-flex items-center gap-2 rounded-full border border-blue-200/50 bg-blue-50 px-3 py-1 dark:border-blue-800/50 dark:bg-blue-900/20">
          <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
          <span class="text-xs font-bold uppercase tracking-wider text-blue-700 dark:text-blue-300">Portafolio</span>
        </div>
        <h2 class="mt-3 text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight">Productos reales con casos de uso claros</h2>
        <p class="mt-3 text-pretty text-neutral-600 dark:text-neutral-400">Una mirada concreta a lo que se construyó, a quién sirve y qué problema resuelve.</p>
      </div>
      <PrimaryCTA title={primaryCta} url={contactUrl} />
    </div>
    <div class="mt-8 grid gap-6 md:grid-cols-2">
      {projects.map((project) => (
        <a href={project.href} class="group relative overflow-hidden rounded-xl border border-neutral-200/60 bg-white/70 shadow-sm backdrop-blur-sm transition-all duration-500 hover:-translate-y-1 hover:shadow-xl dark:border-neutral-700/60 dark:bg-neutral-800/70">
          <div class="aspect-[16/9] overflow-hidden bg-neutral-200 dark:bg-neutral-900">
            <Image src={project.image} alt={project.imageAlt} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" format="avif" width={760} sizes="(min-width: 768px) 50vw, 100vw" />
          </div>
          <div class="relative p-6">
            <h3 class="text-xl font-bold text-neutral-800 dark:text-neutral-200">{project.title}</h3>
            <p class="mt-2 text-sm font-semibold leading-6 text-neutral-700 dark:text-neutral-300">{project.description}</p>
            <p class="mt-2 text-sm leading-6 text-neutral-500 dark:text-neutral-400">{project.context}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-bold text-blue-600 transition-transform duration-300 group-hover:translate-x-1 dark:text-blue-300">Ver proyecto</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-[85rem] px-4 py-12 sm:px-6 lg:px-8 lg:py-16 2xl:max-w-full" data-reveal>
    <div class="max-w-3xl">
      <div class="mb-2 inline-flex items-center gap-2 rounded-full border border-blue-200/50 bg-blue-50 px-3 py-1 dark:border-blue-800/50 dark:bg-blue-900/20">
        <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
        <span class="text-xs font-bold uppercase tracking-wider text-blue-700 dark:text-blue-300">Proceso</span>
      </div>
      <h2 class="mt-3 text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight">Un proceso simple que elimina las suposiciones</h2>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-4">
      {processSteps.map((step, index) => (
        <div class="rounded-xl border border-neutral-200/60 bg-white/70 p-6 shadow-sm backdrop-blur-sm dark:border-neutral-700/60 dark:bg-neutral-800/70">
          <span class="mb-3 inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-bold text-blue-600 dark:bg-blue-900/30 dark:text-blue-300">0{index + 1}</span>
          <h3 class="text-lg font-bold text-neutral-800 dark:text-neutral-200">{step.title}</h3>
          <p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">{step.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="relative overflow-hidden bg-white/50 py-12 dark:bg-neutral-900/20 lg:py-16" data-reveal>
    <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-blue-200/50 bg-blue-50 px-3 py-1 dark:border-blue-800/50 dark:bg-blue-900/20">
        <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
        <span class="text-xs font-bold uppercase tracking-wider text-blue-700 dark:text-blue-300">Confianza</span>
      </div>
      <h2 class="mt-3 text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight">
        La mayoría de los sitios se ven bien. El problema es lo que <span class="bg-gradient-to-r from-blue-600 to-blue-400 bg-clip-text text-transparent dark:from-blue-300 dark:to-yellow-300">no logran decir</span>.
      </h2>
      <p class="mt-6 text-pretty text-lg leading-8 text-neutral-600 dark:text-neutral-400">
        Un sitio puede verse pulido y aun así perder leads cuando la oferta es vaga, la prueba es débil, el CTA está escondido o la página responde preguntas que tus compradores no se hacen.
      </p>
      <p class="mt-4 text-pretty text-lg leading-8 text-neutral-600 dark:text-neutral-400">
        Dawn Web construye primero alrededor de la claridad del comprador. Copy, UX, SEO, rendimiento y funciones a medida apoyan el mismo objetivo: que el visitante correcto se sienta entendido y listo para iniciar una conversación.
      </p>
    </div>
  </section>

  <FAQ title="Preguntas<br />frecuentes" faqs={faqs} />

  <section class="relative overflow-hidden bg-gradient-to-br from-blue-800 via-blue-900 to-[#08162f] px-4 py-14 text-center sm:px-6 lg:px-8 lg:py-20" data-reveal>
    <div class="relative mx-auto max-w-[85rem] 2xl:max-w-full">
      <h2 class="mx-auto max-w-3xl text-balance text-3xl font-bold tracking-tight text-white md:text-5xl">
        Deja de permitir que páginas poco claras alejen a buenos visitantes.
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-pretty text-blue-100/70">
        Reserva una consulta gratuita y sal con un siguiente paso práctico para tu sitio web, rediseño, base SEO o aplicación web a medida.
      </p>
      <div class="mt-10">
        <a href={contactUrl} class="group inline-flex items-center justify-center gap-x-2 rounded-lg bg-yellow-400 px-8 py-4 text-sm font-bold text-blue-900 transition-all duration-300 hover:bg-yellow-300 hover:shadow-lg hover:shadow-yellow-400/25">{primaryCta}</a>
      </div>
    </div>
  </section>
</MainLayout>
