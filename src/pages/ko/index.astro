---
import { Image } from "astro:assets";
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import FAQ from "@components/sections/misc/FAQ.astro";
import AnnouncementBanner from "@components/ui/banners/AnnouncementBanner.astro";
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import heroImage from "@images/hero.png";
import motoViagens from "@images/motoviagens3.jpg";
import verbo from "@images/verbo_app_card.jpg";
import triplut from "@images/triplut6.jpg";
import luna from "@images/lunaai.png";
import faqs from "@data/ko/faqs.json";
import { SITE } from "@data/constants";
import {
  buildFaqSchema,
  buildWebPageSchema,
  buildWebSiteSchema,
} from "@utils/seo";

const contactUrl = "/ko/contact";
const primaryCta = "무료 상담 예약";
const pageTitle = "좋은 문의를 놓치지 않는 웹사이트 | Dawn Web";
const pageDescription =
  "Dawn Web은 제안이 명확하지 않은 웹사이트를 개선하고, 성과가 낮은 페이지를 리디자인하며, 성장하는 서비스 비즈니스를 위한 맞춤형 웹 앱을 구축합니다.";

const proofPoints = [
  { text: "실제 제작자와 직접 소통합니다", icon: "💬" },
  { text: "비용이 낭비되기 전에 범위를 명확히 합니다", icon: "🎯" },
  { text: "설명력, 속도, 전환을 기준으로 구축합니다", icon: "⚡" },
];

const services = [
  {
    title: "제안을 명확히 설명하는 새 웹사이트",
    href: "/ko/services/business-website-design",
    description:
      "잠재 고객이 몇 초 안에 무엇을 하는지 이해하지 못하면 떠납니다. 가치가 분명하게 보이고 문의로 이어지는 집중도 높은 사이트를 만듭니다.",
    accent: "from-blue-400 to-blue-600",
  },
  {
    title: "낡았거나 성과가 낮은 사이트 개선",
    href: "/ko/services/website-redesign",
    description:
      "현재 사이트가 오래되어 보이거나, 메시지가 흐리거나, 조용하다면 신뢰와 다음 행동이 분명해지도록 메시지와 흐름을 다시 설계합니다.",
    accent: "from-yellow-400 to-orange-500",
  },
  {
    title: "출시 전부터 갖추는 SEO 기반",
    href: "/ko/services/seo-ready-websites",
    description:
      "좋은 사이트는 검색 기본기를 빠뜨린 채 출시되어서는 안 됩니다. 구조, 메타데이터, 스키마, 사이트맵, 크롤링 가능한 콘텐츠를 처음부터 반영합니다.",
    accent: "from-blue-300 to-blue-500",
  },
  {
    title: "수작업을 줄이는 맞춤형 웹 앱",
    href: "/ko/services/custom-web-apps",
    description:
      "스프레드시트, 양식, 분리된 도구가 팀의 속도를 늦춘다면 실제 업무 방식에 맞춘 포털, 대시보드, 예약 흐름, 내부 도구를 구축합니다.",
    accent: "from-orange-400 to-yellow-400",
  },
];

const founderAdvantages = [
  "피드백이 결정을 내리는 사람에게 바로 전달됩니다",
  "카피, 구조, 코드가 하나의 방향으로 연결됩니다",
  "같은 내용을 반복 설명하는 회의가 줄어듭니다",
  "디자인과 개발 전에 현실적인 선택지를 먼저 정리합니다",
];

const projects = [
  {
    title: "Moto Viagens",
    href: "/ko/products/motoviagens",
    image: motoViagens,
    imageAlt: "브라질 오토바이 여행 경로와 투어를 제공하는 Moto Viagens",
    description:
      "브라질 전역의 경로, 투어, 숙소를 계획하는 라이더를 위한 실제 오토바이 여행 플랫폼입니다.",
    context:
      "Dawn Web은 투어 페이지, 숙소 탐색, 이벤트 콘텐츠, 경로 중심 탐색, 다국어 지원, AI 기반 탐색을 포함한 예약 중심 경험을 구축했습니다.",
  },
  {
    title: "Verbo",
    href: "/ko/products/verboai",
    image: verbo,
    imageAlt: "Verbo AI 언어 학습 플랫폼 인터페이스",
    description:
      "연습, 기억 유지, 매일의 학습 습관을 중심으로 설계한 AI 언어 학습 제품입니다.",
    context:
      "대화 연습, 적응형 플래시카드, 학습 여정, 구독, 모바일 지원을 하나의 집중된 제품 경험으로 연결합니다.",
  },
  {
    title: "Triplut",
    href: "/ko/products/triplut",
    image: triplut,
    imageAlt: "Triplut AI 여행 플랫폼 일러스트레이션",
    description:
      "경로, 예산, 여행 세부 정보를 한곳에서 정리하는 여행 계획 제품 콘셉트입니다.",
    context:
      "교통, 숙소, 경험, 예산 계획, AI 안내가 더 명확한 계획 흐름 안에 어떻게 맞물릴 수 있는지 탐색했습니다.",
  },
  {
    title: "Luna AI",
    href: "/ko/products/luna",
    image: luna,
    imageAlt: "Dawn Web의 Luna AI 마스코트와 디지털 어시스턴트",
    description:
      "디지털 제품 안에서 더 명확한 안내를 제공하기 위한 Dawn Web의 내부 어시스턴트 콘셉트입니다.",
    context:
      "Luna는 제품 탐색, 맥락형 도움말, 더 개인화된 사용자 흐름을 위한 실용적인 어시스턴트 레이어로 발전하고 있습니다.",
  },
];

const processSteps = [
  {
    title: "진단",
    description:
      "방문자가 어디서 혼란을 느끼는지, 비즈니스가 사이트에서 무엇을 필요로 하는지, 프로젝트가 가치 있으려면 무엇이 필요한지 확인합니다.",
  },
  {
    title: "제안",
    description:
      "디자인이나 개발을 시작하기 전에 명확한 범위, 추천 방향, 일정, 비용을 전달합니다.",
  },
  {
    title: "개발",
    description:
      "느린 전달 과정 대신 정기적인 업데이트와 직접적인 결정을 통해 사이트나 앱을 작성, 설계, 구축합니다.",
  },
  {
    title: "출시",
    description:
      "프로젝트를 출시하고 점검한 뒤, 무엇이 바뀌었고 다음 단계가 무엇인지 이해할 수 있도록 핵심 내용을 인수인계합니다.",
  },
];
---

<MainLayout
  title={pageTitle}
  meta={pageDescription}
  lang="ko"
  structuredData={[
    buildWebSiteSchema(SITE.url),
    buildWebPageSchema({
      title: pageTitle,
      description: pageDescription,
      pathname: "/ko",
      locale: "ko",
      siteUrl: SITE.url,
    }),
    buildFaqSchema({ faqs: faqs.faqs }),
  ]}
>
  <AnnouncementBanner
    btnId="dismiss-button"
    badge="무료 명확성 점검"
    title="웹사이트 문의를 놓치게 만드는 지점을 찾아보세요"
    description="재구축, 리디자인, 광고비 추가 지출 전에 방문자를 혼란스럽게 만드는 부분을 빠르게 점검합니다."
    btnTitle={primaryCta}
    url={contactUrl}
  />

  <HeroSection
    slot="hero"
    title={`웹사이트는 좋은 방문자를 혼란스럽게 두는 대신 <span class="text-blue-600 dark:text-blue-300">검증된 문의</span>를 만들어야 합니다`}
    subTitle="사이트가 보기에는 괜찮아도 제안을 설명하지 못하고, 신뢰를 만들지 못하고, 다음 행동을 분명히 보여주지 못한다면 문의를 놓치고 있을 가능성이 큽니다. Dawn Web은 메시지, 구조, 구현을 정리해 적합한 고객이 왜 연락해야 하는지 알게 만듭니다."
    primaryBtn={primaryCta}
    primaryBtnURL={contactUrl}
    withReview={false}
    src={heroImage}
    alt="Dawn Web 웹사이트 디자인 및 웹 개발 작업 공간"
    badgeLabel="전략적 웹 파트너"
    trustItems={["창업자 주도", "불필요한 전달 없음", "SEO 준비"]}
    containedByHeroBand={true}
  />

  <section class="mx-auto max-w-[85rem] px-4 py-8 sm:px-6 lg:px-8 lg:py-10 2xl:max-w-full" aria-label="Dawn Web 신뢰 포인트">
    <div class="grid gap-4 md:grid-cols-3">
      {
        proofPoints.map((point) => (
          <div class="group flex items-center gap-4 rounded-xl border border-neutral-200/60 bg-white/60 px-5 py-4 shadow-sm backdrop-blur-sm transition-all duration-300 hover:border-blue-300/50 hover:shadow-md dark:border-neutral-700/60 dark:bg-neutral-800/60 dark:hover:border-blue-500/30">
            <span class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-blue-50 text-lg dark:bg-blue-900/30">{point.icon}</span>
            <span class="text-sm font-bold text-neutral-800 dark:text-neutral-200">{point.text}</span>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-[85rem] px-4 pb-16 pt-10 sm:px-6 lg:px-8 lg:pb-20 lg:pt-14 2xl:max-w-full" data-reveal>
    <div class="max-w-3xl">
      <div class="mb-2 inline-flex items-center gap-2 rounded-full border border-blue-200/50 bg-blue-50 px-3 py-1 dark:border-blue-800/50 dark:bg-blue-900/20">
        <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
        <span class="text-xs font-bold uppercase tracking-wider text-blue-700 dark:text-blue-300">서비스</span>
      </div>
      <h2 class="mt-3 text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight">
        문의를 잃게 만드는 웹사이트의 부분을 고치세요
      </h2>
      <p class="mt-3 text-pretty text-neutral-600 dark:text-neutral-400">
        모든 서비스는 실제 문제에서 시작합니다. 방문자가 망설이고, 페이지가 낡아 보이며, 검색 기반이 약하거나, 수작업이 비즈니스 속도를 늦추는 문제입니다.
      </p>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {
        services.map((service, i) => (
          <a href={service.href} class="group relative flex h-full flex-col overflow-hidden rounded-xl border border-neutral-200/60 bg-white/70 p-6 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-blue-300/50 hover:shadow-xl dark:border-neutral-700/60 dark:bg-neutral-800/70 dark:hover:border-blue-500/30">
            <div class={`absolute inset-x-0 top-0 h-1 bg-gradient-to-r ${service.accent} opacity-70 transition-opacity duration-300 group-hover:opacity-100`} />
            <span class="mb-4 text-xs font-bold text-neutral-400 dark:text-neutral-500">0{i + 1}</span>
            <h3 class="text-lg font-bold text-neutral-800 dark:text-neutral-200">{service.title}</h3>
            <p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">{service.description}</p>
            <p class="mt-auto flex items-center gap-1 pt-5 text-sm font-bold text-blue-600 transition-transform duration-300 group-hover:translate-x-1 dark:text-blue-300">자세히 보기</p>
          </a>
        ))
      }
    </div>

    <div class="mt-10">
      <PrimaryCTA title={primaryCta} url={contactUrl} />
    </div>
  </section>

  <section class="relative overflow-hidden bg-gradient-to-br from-blue-800 via-blue-900 to-[#0a1a3c] py-12 lg:py-16" data-reveal>
    <div class="relative mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8 2xl:max-w-full">
      <div class="relative grid gap-10 md:grid-cols-2 lg:gap-16">
        <div>
          <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-yellow-400"></span>
            <span class="text-xs font-bold uppercase tracking-wider text-blue-100">창업자 주도, 불필요한 대행사식 흐림 없음</span>
          </div>
          <h2 class="mt-3 text-balance text-2xl font-bold tracking-tight text-white md:text-4xl md:leading-tight">
            전달 과정도, 계정 관리자 필터도 없습니다. 명확한 결정만 있습니다.
          </h2>
        </div>
        <div>
          <p class="text-pretty text-blue-100/80">
            많은 에이전시 프로젝트는 목표를 듣는 사람과 실제 작업을 설계하는 사람이 달라지며 느려집니다. Dawn Web에서는 전략, 아키텍처, 실행을 이끄는 풀스택 개발자 Andrew Henrice와 직접 일합니다.
          </p>
          <p class="mt-4 text-pretty text-blue-100/80">
            그 결과 전달 과정에서의 오해가 줄고, 결정이 빨라지며, 일반 패키지가 아니라 실제로 필요한 결과를 중심으로 사이트나 앱이 구축됩니다.
          </p>
          <div class="mt-8 grid gap-x-6 gap-y-4 sm:grid-cols-2">
            {
              founderAdvantages.map((advantage) => (
                <div class="flex items-start gap-3 border-t border-white/10 pt-4">
                  <span class="mt-0.5 text-yellow-400">✓</span>
                  <span class="text-sm font-semibold text-white/90">{advantage}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[85rem] px-4 py-12 sm:px-6 lg:px-8 lg:py-16 2xl:max-w-full" data-reveal>
    <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
      <div class="max-w-3xl">
        <div class="mb-2 inline-flex items-center gap-2 rounded-full border border-blue-200/50 bg-blue-50 px-3 py-1 dark:border-blue-800/50 dark:bg-blue-900/20">
          <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
          <span class="text-xs font-bold uppercase tracking-wider text-blue-700 dark:text-blue-300">포트폴리오</span>
        </div>
        <h2 class="mt-3 text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight">
          용도가 분명한 실제 제품들
        </h2>
        <p class="mt-3 text-pretty text-neutral-600 dark:text-neutral-400">
          무엇을 만들었고, 누구를 위한 것이며, 어떤 문제를 해결하도록 설계했는지 현실적으로 보여드립니다.
        </p>
      </div>
      <PrimaryCTA title={primaryCta} url={contactUrl} />
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-2">
      {
        projects.map((project) => (
          <a href={project.href} class="group relative overflow-hidden rounded-xl border border-neutral-200/60 bg-white/70 shadow-sm backdrop-blur-sm transition-all duration-500 hover:-translate-y-1 hover:shadow-xl dark:border-neutral-700/60 dark:bg-neutral-800/70">
            <div class="aspect-[16/9] overflow-hidden bg-neutral-200 dark:bg-neutral-900">
              <Image src={project.image} alt={project.imageAlt} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" format="avif" width={760} sizes="(min-width: 768px) 50vw, 100vw" />
            </div>
            <div class="relative p-6">
              <h3 class="text-xl font-bold text-neutral-800 dark:text-neutral-200">{project.title}</h3>
              <p class="mt-2 text-sm font-semibold leading-6 text-neutral-700 dark:text-neutral-300">{project.description}</p>
              <p class="mt-2 text-sm leading-6 text-neutral-500 dark:text-neutral-400">{project.context}</p>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-bold text-blue-600 transition-transform duration-300 group-hover:translate-x-1 dark:text-blue-300">프로젝트 보기</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-[85rem] px-4 py-12 sm:px-6 lg:px-8 lg:py-16 2xl:max-w-full" data-reveal>
    <div class="max-w-3xl">
      <div class="mb-2 inline-flex items-center gap-2 rounded-full border border-blue-200/50 bg-blue-50 px-3 py-1 dark:border-blue-800/50 dark:bg-blue-900/20">
        <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
        <span class="text-xs font-bold uppercase tracking-wider text-blue-700 dark:text-blue-300">프로세스</span>
      </div>
      <h2 class="mt-3 text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight">
        추측을 줄이는 단순한 진행 방식
      </h2>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-4">
      {
        processSteps.map((step, index) => (
          <div class="rounded-xl border border-neutral-200/60 bg-white/70 p-6 shadow-sm backdrop-blur-sm dark:border-neutral-700/60 dark:bg-neutral-800/70">
            <span class="mb-3 inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-bold text-blue-600 dark:bg-blue-900/30 dark:text-blue-300">0{index + 1}</span>
            <h3 class="text-lg font-bold text-neutral-800 dark:text-neutral-200">{step.title}</h3>
            <p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">{step.description}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="relative overflow-hidden bg-white/50 py-12 dark:bg-neutral-900/20 lg:py-16" data-reveal>
    <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-blue-200/50 bg-blue-50 px-3 py-1 dark:border-blue-800/50 dark:bg-blue-900/20">
        <span class="h-1.5 w-1.5 rounded-full bg-blue-500"></span>
        <span class="text-xs font-bold uppercase tracking-wider text-blue-700 dark:text-blue-300">신뢰</span>
      </div>
      <h2 class="mt-3 text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight">
        대부분의 웹사이트는 보기에는 괜찮습니다. 문제는 <span class="bg-gradient-to-r from-blue-600 to-blue-400 bg-clip-text text-transparent dark:from-blue-300 dark:to-yellow-300">말하지 못하는 것</span>입니다.
      </h2>
      <p class="mt-6 text-pretty text-lg leading-8 text-neutral-600 dark:text-neutral-400">
