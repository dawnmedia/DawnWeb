---
import MainLayout from "@/layouts/MainLayout.astro";
import ServicesIndexShowcase from "@components/sections/services/ServicesIndexShowcase.astro";
import { SITE } from "@data/constants";
import webdev from "@images/web-dev.jpg";
import webdesign from "@images/web-design.jpg";
import software from "@images/software.jpg";
import code from "@images/code.jpg";
import motoViagens from "@images/motoviagens3.jpg";
import verbo from "@images/verbo_app_card.jpg";
import triplut from "@images/triplut6.jpg";
import { buildServiceSchema, buildWebPageSchema } from "@utils/seo";

const contactUrl = "/ko/contact";
const pageTitle = "웹사이트 제작 및 소프트웨어 서비스 | Dawn Web";
const pageDescription =
  "Dawn Web은 성장하는 기업이 더 많은 검증된 문의를 얻을 수 있도록 웹사이트, 리디자인, SEO 기반 구축, 맞춤형 웹 앱을 제작합니다.";

const services = [
  {
    title: "비즈니스 웹사이트 제작",
    href: "/ko/services/business-website-design",
    description:
      "제안을 명확히 설명하고 신뢰를 빠르게 만들며 방문자가 자연스럽게 다음 단계로 이동하도록 설계한 맞춤형 웹사이트입니다.",
    outcome: "혼란스러운 방문자를 검증된 문의로 전환합니다.",
    bestFor: "새롭거나 메시지가 불명확한 웹사이트에 적합",
    deliverables: ["명확한 페이지 구조", "전환 중심 메시지", "반응형 디자인 및 출시 설정"],
    image: webdesign,
    imageAlt: "비즈니스 웹사이트 인터페이스를 기획하는 디자이너",
  },
  {
    title: "웹사이트 리디자인",
    href: "/ko/services/website-redesign",
    description:
      "낡았거나 사용하기 어렵거나 문의로 이어지지 않는 사이트를 더 명확한 메시지와 빠른 페이지, 나은 연락 흐름으로 다시 구축합니다.",
    outcome: "기존 사이트를 더 신뢰할 수 있고 행동하기 쉬운 경험으로 바꿉니다.",
    bestFor: "성과가 낮은 기존 사이트에 적합",
    deliverables: ["UX 및 콘텐츠 진단", "현대적인 반응형 레이아웃", "마이그레이션을 고려한 출시 점검"],
    image: webdev,
    imageAlt: "웹사이트 리디자인을 함께 검토하는 팀",
  },
  {
    title: "SEO 기반 웹사이트",
    href: "/ko/services/seo-ready-websites",
    description:
      "크롤링 가능한 페이지, 깔끔한 메타데이터, 구조화 데이터, 의미 있는 콘텐츠, 출시 위생을 위한 기술 기반을 구축합니다.",
    outcome: "출시 첫날부터 검색 기본기를 갖춥니다.",
    bestFor: "검색 가시성을 중요하게 보는 프로젝트에 적합",
    deliverables: ["메타데이터와 스키마", "크롤링 가능한 페이지 구조", "사이트맵 및 robots 설정"],
    image: code,
    imageAlt: "웹사이트 구축 코드가 표시된 코드 편집기",
  },
  {
    title: "맞춤형 웹 앱",
    href: "/ko/services/custom-web-apps",
    description:
      "정적인 페이지와 스프레드시트를 넘어선 팀을 위한 포털, 대시보드, 예약 도구, 통합 기능을 목적에 맞게 구축합니다.",
    outcome: "수작업 흐름을 집중된 소프트웨어로 대체합니다.",
    bestFor: "운영 도구가 필요한 팀에 적합",
    deliverables: ["업무 흐름 및 데이터 계획", "맞춤형 앱 인터페이스", "배포 및 유지보수 방향"],
    image: software,
    imageAlt: "비즈니스 소프트웨어 인터페이스와 업무 흐름 계획",
  },
];

const processSteps = [
  { title: "진단", description: "대상 고객, 제안, 현재 막히는 지점, 비즈니스 목표, 프로젝트가 가치 있으려면 필요한 조건을 명확히 합니다." },
  { title: "제안", description: "디자인이나 개발 전에 현실적인 범위, 추천 방향, 일정, 비용을 제공합니다." },
  { title: "개발", description: "웹사이트나 앱을 직접적인 소통과 명확한 결정으로 설계, 작성, 구축, 검토합니다." },
  { title: "출시", description: "프로젝트를 출시하고 점검한 뒤 지원과 향후 개선을 위한 기반을 갖춰 전달합니다." },
];

const portfolioItems = [
  {
    title: "Moto Viagens",
    href: "/ko/products/motoviagens",
    description: "예약 중심 흐름, 경로 콘텐츠, 다국어 지원, AI 탐색을 갖춘 실제 오토바이 여행 플랫폼입니다.",
    image: motoViagens,
    imageAlt: "Moto Viagens 브라질 오토바이 경로와 투어",
  },
  {
    title: "Verbo",
    href: "/ko/products/verboai",
    description: "AI 코칭, 적응형 플래시카드, 구독, 모바일 지원을 중심으로 구축한 언어 학습 제품입니다.",
    image: verbo,
    imageAlt: "Verbo AI 언어 학습 플랫폼 인터페이스",
  },
  {
    title: "Triplut",
    href: "/ko/products/triplut",
    description: "경로, 예산, 경험, AI 안내를 더 명확한 계획 흐름으로 연결하는 여행 계획 콘셉트입니다.",
    image: triplut,
    imageAlt: "Triplut AI 여행 플랫폼 일러스트레이션",
  },
];
---

<MainLayout
  title={pageTitle}
  meta={pageDescription}
  lang="ko"
  structuredData={[
    buildWebPageSchema({ title: pageTitle, description: pageDescription, pathname: "/ko/services", locale: "ko", siteUrl: SITE.url }),
    buildServiceSchema({ name: "웹사이트 제작 및 소프트웨어 서비스", description: pageDescription, pathname: "/ko/services", serviceType: "Web design and web development", siteUrl: SITE.url }),
  ]}
>
  <ServicesIndexShowcase
    eyebrow="서비스"
    title="다음 행동을 명확하게 만드는 웹사이트와 소프트웨어"
    subTitle="Dawn Web은 서비스 비즈니스가 제안을 명확히 설명하고 신뢰를 만들며 더 많은 검증된 방문자를 문의로 전환하도록 돕습니다."
    primaryCta="무료 상담 예약"
    primaryCtaUrl={contactUrl}
    secondaryCta="제품 작업 보기"
    secondaryCtaUrl="/ko/products"
    proofPoints={["실제 제작자와 직접 소통합니다", "투자 전에 범위를 명확히 합니다", "설명력, 속도, 전환을 기준으로 구축합니다"]}
    services={services}
    processEyebrow="프로세스"
    processTitle="추측을 줄이는 단순한 진행 방식"
    processSubTitle="모든 서비스는 문제를 이해하고, 적절한 범위에 합의하고, 진행 상황을 보이며 구축하고, 기본기를 갖춰 출시하는 흐름을 따릅니다."
    processSteps={processSteps}
    portfolioEyebrow="증거"
    portfolioTitle="실제 디지털 제품에서 나온 증거"
    portfolioSubTitle="포트폴리오에 담긴 제품적 사고는 서비스 작업에도 그대로 적용됩니다. 명확한 사용자 흐름, 유용한 인터페이스, 실용적인 기술 기반입니다."
    portfolioItems={portfolioItems}
    faqTitle="예약 전 자주 묻는 질문"
    faqs={[
      { question: "전체 재구축이 꼭 필요한가요?", answer: "항상 그렇지는 않습니다. 첫 대화는 새 사이트, 집중 리디자인, 기술 정리, 맞춤 기능 중 가장 작고 유용한 방향을 찾는 데 집중합니다." },
      { question: "SEO를 처음부터 포함할 수 있나요?", answer: "네. SEO 기반 구축에는 명확한 페이지 구조, 메타데이터, 필요한 스키마, 사이트맵 관리, 크롤링 가능한 페이지 출시 점검이 포함됩니다." },
      { question: "마케팅 웹사이트 외에도 제작하나요?", answer: "네. 비즈니스에 정적 페이지가 아니라 소프트웨어가 필요할 때 포털, 대시보드, 예약 도구, 업무 앱도 제작합니다." },
      { question: "출시 후에는 어떻게 되나요?", answer: "사이트나 앱이 계속 개선될 수 있도록 유지보수, 작은 개선, 보안 업데이트, 향후 제품 작업을 지원할 수 있습니다." },
    ]}
    finalTitle="웹사이트를 더 신뢰하기 쉽게 만들 준비가 되셨나요?"
    finalText="현재 사이트, 아이디어, 업무 흐름을 가져오세요. 무엇을 바꿔야 하고 무엇을 먼저 만들 가치가 있는지 함께 명확히 하겠습니다."
    finalCta="무료 상담 예약"
    finalCtaUrl={contactUrl}
  />
</MainLayout>
