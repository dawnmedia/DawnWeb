---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import ContactSection from "@components/sections/misc/ContactSection.astro";
import { SITE } from "@data/constants";
import {
  SEO_DESCRIPTIONS,
  SEO_TITLES,
  buildWebPageSchema,
} from "@utils/seo";

const pageTitle: string = SEO_TITLES.contact;
---

<!--Utilizing MainLayout for the outer layout of the page, and defining meta for SEO purposes-->
<MainLayout
  title={pageTitle}
  meta={SEO_DESCRIPTIONS.contact}
  structuredData={buildWebPageSchema({
    title: pageTitle,
    description: SEO_DESCRIPTIONS.contact,
    pathname: "/contact",
    locale: "en",
    siteUrl: SITE.url,
  })}
>
  <ContactSection />
</MainLayout>
