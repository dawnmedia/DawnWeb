---
import MainLayout from "@/layouts/MainLayout.astro";
import TeamPage from "@components/sections/team/TeamPage.astro";
import { SITE } from "@data/constants";
import { teamMembersByLocale, teamPageContent } from "@data/team";
import { LOCALE_LANGUAGE_TAGS } from "@utils/locale";
import { buildWebPageSchema } from "@utils/seo";

const locale = "fr";
const content = teamPageContent[locale];
---

<MainLayout
  title={content.seoTitle}
  meta={content.seoDescription}
  lang={LOCALE_LANGUAGE_TAGS[locale]}
  structuredData={buildWebPageSchema({
    title: content.seoTitle,
    description: content.seoDescription,
    pathname: "/fr/team",
    locale,
    siteUrl: SITE.url,
  })}
>
  <TeamPage
    locale={locale}
    content={content}
    members={teamMembersByLocale[locale]}
  />
</MainLayout>
