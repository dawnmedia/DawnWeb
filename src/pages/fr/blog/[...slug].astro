---
import BlogArticlePage from "@components/sections/blog/BlogArticlePage.astro";
import { getBlogStaticPaths, getRelatedBlogPosts } from "@utils/blog";
import type { Locale } from "@utils/locale";

const locale: Locale = "fr";

export async function getStaticPaths() {
  const routeLocale: Locale = "fr";
  return getBlogStaticPaths(routeLocale);
}

const { post } = Astro.props;
const relatedPosts = await getRelatedBlogPosts(post, locale);
---

<BlogArticlePage locale={locale} post={post} relatedPosts={relatedPosts} />
