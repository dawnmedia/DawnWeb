---
import MainLayout from "@/layouts/MainLayout.astro";
import FeaturesStatsAlt from "@components/sections/features/FeaturesStatsAlt.astro";
import ProductShowcaseIndex from "@components/sections/products/ProductShowcaseIndex.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { SITE } from "@data/constants";
import { collectionIdStartsWithLocale, type Locale } from "@utils/locale";
import { buildWebPageSchema } from "@utils/seo";

const locale: Locale = "fr";

const products: CollectionEntry<"products">[] = (
  await getCollection("products", ({ id }) =>
    collectionIdStartsWithLocale(id, locale),
  )
).sort(
  (a: CollectionEntry<"products">, b: CollectionEntry<"products">) =>
    a.data.main.id - b.data.main.id,
);

const pageTitle = "Produits logiciels & projets digitaux | Dawn Web";
const pageDescription =
  "Explorez les produits logiciels, plateformes web et concepts IA de Dawn Web avec captures, statut, public cible et choix techniques.";
---

<MainLayout
  title={pageTitle}
  meta={pageDescription}
  lang="fr"
  structuredData={buildWebPageSchema({
    title: pageTitle,
    description: pageDescription,
    pathname: "/fr/products",
    locale,
    siteUrl: SITE.url,
  })}
>
  <ProductShowcaseIndex
    products={products}
    locale={locale}
    eyebrow="Portfolio produits"
    title="Des produits logiciels clairs des le premier regard"
    subTitle="Decouvrez les applications web, concepts IA et plateformes digitales de Dawn Web a travers leur positionnement, leur statut, leurs captures et leurs choix techniques."
    ctaLabel="Planifier un produit"
    ctaUrl="/fr/contact"
    viewLabel="Voir le produit"
  />

  <div class="opacity-95">
    <FeaturesStatsAlt
      title="Pourquoi choisir Dawn Web ?"
      subTitle="Transformez vos idees en une presence en ligne puissante avec Dawn Web. Que vous soyez une start-up ou une entreprise etablie, nous proposons des solutions sur mesure pour atteindre vos objectifs."
      benefits={[
        "Sites web performants : nous concevons et developpons des sites personnalises, rapides, fiables et optimises pour convertir vos visiteurs en clients fideles.",
        "Solutions evolutives : notre approche couvre tout, des pages d'atterrissage simples aux plateformes integrees, avec des technologies modernes, pretes a evoluer et faciles a maintenir.",
        "Accompagnement durable : de la mise en ligne a la reussite sur le long terme, nous assurons la maintenance, la securite et un support expert.",
      ]}
    />
  </div>
</MainLayout>
