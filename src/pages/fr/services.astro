---
import MainLayout from "@/layouts/MainLayout.astro";
import ServicesIndexShowcase from "@components/sections/services/ServicesIndexShowcase.astro";
import { SITE } from "@data/constants";
import webdev from "@images/web-dev.jpg";
import webdesign from "@images/web-design.jpg";
import software from "@images/software.jpg";
import code from "@images/code.jpg";
import motoViagens from "@images/motoviagens3.jpg";
import verbo from "@images/verbo_app_card.jpg";
import triplut from "@images/triplut6.jpg";
import { buildServiceSchema, buildWebPageSchema } from "@utils/seo";

const contactUrl = "/fr/contact";
const pageTitle = "Services de conception web et logiciels | Dawn Web";
const pageDescription =
  "Dawn Web cree des sites, refontes, fondations SEO et applications web sur mesure pour aider les entreprises a obtenir plus de demandes qualifiees.";

const services = [
  {
    title: "Conception de site professionnel",
    href: "/fr/contact",
    description:
      "Un site sur mesure qui explique votre offre, renforce la confiance et guide les visiteurs vers une prise de contact.",
    outcome: "Transformer les visiteurs hesitants en demandes qualifiees.",
    bestFor: "Ideal pour les sites nouveaux ou peu clairs",
    deliverables: [
      "Structure de pages claire",
      "Message oriente conversion",
      "Design responsive et lancement",
    ],
    image: webdesign,
    imageAlt: "Designer planifiant une interface de site professionnel",
  },
  {
    title: "Refonte de site web",
    href: "/fr/contact",
    description:
      "Une refonte pour les sites vieillissants ou difficiles a utiliser, avec un message plus clair et de meilleurs chemins vers le contact.",
    outcome: "Rendre votre site plus credible et plus facile a utiliser.",
    bestFor: "Ideal pour les sites sous-performants",
    deliverables: [
      "Audit UX et contenu",
      "Layouts modernes et responsive",
      "Verification avant lancement",
    ],
    image: webdev,
    imageAlt: "Equipe collaborant autour d'une refonte de site web",
  },
  {
    title: "Sites prets pour le SEO",
    href: "/fr/contact",
    description:
      "Des fondations techniques pour des pages explorables, des metadonnees propres, des donnees structurees et une architecture lisible.",
    outcome: "Lancer avec les bases SEO deja en place.",
    bestFor: "Ideal pour les projets axes visibilite",
    deliverables: [
      "Metadonnees et schema",
      "Structure de pages explorables",
      "Sitemap et robots",
    ],
    image: code,
    imageAlt: "Editeur de code montrant la construction d'un site web",
  },
  {
    title: "Applications web sur mesure",
    href: "/fr/contact",
    description:
      "Des portails, tableaux de bord, outils de reservation et integrations concus pour remplacer les flux manuels.",
    outcome: "Transformer les processus manuels en logiciel utile.",
    bestFor: "Ideal pour les outils operationnels",
    deliverables: [
      "Planification des flux et donnees",
      "Interface applicative sur mesure",
      "Deploiement et maintenance",
    ],
    image: software,
    imageAlt: "Interface logicielle professionnelle et planification de flux",
  },
];

const processSteps = [
  {
    title: "Decouverte",
    description:
      "Nous clarifions votre audience, votre offre, vos blocages actuels et le resultat attendu.",
  },
  {
    title: "Proposition",
    description:
      "Vous recevez un perimetre clair, une direction recommandee, un calendrier et une estimation avant le debut.",
  },
  {
    title: "Developpement",
    description:
      "Le site ou l'application est concu, redige, developpe et ajuste avec une communication directe.",
  },
  {
    title: "Livraison",
    description:
      "Le projet est lance, verifie et transmis avec les bases necessaires pour la suite.",
  },
];

const portfolioItems = [
  {
    title: "Moto Viagens",
    href: "/fr/products/motoviagens",
    description:
      "Une plateforme de voyage moto avec parcours de reservation, contenus de routes, multilingue et aide par IA.",
    image: motoViagens,
    imageAlt: "Moto Viagens itineraires et circuits a moto au Bresil",
  },
  {
    title: "Verbo",
    href: "/fr/products/verboai",
    description:
      "Un produit d'apprentissage des langues par IA avec coaching, flashcards adaptatives et support mobile.",
    image: verbo,
    imageAlt: "Interface de la plateforme d'apprentissage Verbo AI",
  },
  {
    title: "Triplut",
    href: "/fr/products/triplut",
    description:
      "Un concept de planification de voyage qui relie routes, budgets, experiences et guidance IA.",
    image: triplut,
    imageAlt: "Illustration de la plateforme de voyage IA Triplut",
  },
];
---

<MainLayout
  title={pageTitle}
  meta={pageDescription}
  lang="fr"
  structuredData={[
    buildWebPageSchema({
      title: pageTitle,
      description: pageDescription,
      pathname: "/fr/services",
      locale: "fr",
      siteUrl: SITE.url,
    }),
    buildServiceSchema({
      name: "Services de conception web et logiciels",
      description: pageDescription,
      pathname: "/fr/services",
      serviceType: "Web design and web development",
      siteUrl: SITE.url,
    }),
  ]}
>
  <ServicesIndexShowcase
    eyebrow="Services"
    title="Des sites et logiciels qui rendent l'action evidente"
    subTitle="Dawn Web aide les entreprises a clarifier leur offre, renforcer la confiance et obtenir plus de demandes qualifiees grace a des sites, refontes, bases SEO et applications web."
    primaryCta="Planifier une consultation"
    primaryCtaUrl={contactUrl}
    secondaryCta="Voir les produits"
    secondaryCtaUrl="/fr/products"
    proofPoints={[
      "Vous parlez directement avec le constructeur",
      "Un perimetre clair avant d'investir",
      "Concu pour expliquer, charger vite et convertir",
    ]}
    services={services}
    processEyebrow="Processus"
    processTitle="Un processus simple qui retire l'incertitude"
    processSubTitle="Chaque service suit le meme chemin : comprendre le probleme, cadrer la bonne solution, construire avec visibilite et lancer avec les bases en place."
    processSteps={processSteps}
    portfolioEyebrow="Preuves"
    portfolioTitle="Des preuves issues de vrais produits digitaux"
    portfolioSubTitle="La meme logique produit guide nos services : parcours clairs, interfaces utiles et fondations techniques pratiques."
    portfolioItems={portfolioItems}
    faqTitle="Questions avant de reserver"
    faqs={[
      {
        question: "Faut-il tout reconstruire ?",
        answer:
          "Pas toujours. La premiere conversation sert a trouver le chemin utile le plus simple : nouveau site, refonte ciblee, nettoyage technique ou fonctionnalite sur mesure.",
      },
      {
        question: "Le SEO peut-il etre inclus des le depart ?",
        answer:
          "Oui. Les builds prets pour le SEO incluent structure claire, metadonnees, schema si utile, sitemap et controles de lancement.",
      },
      {
        question: "Construisez-vous autre chose que des sites vitrine ?",
        answer:
          "Oui. Dawn Web cree aussi des portails, tableaux de bord, outils de reservation et applications de flux de travail.",
      },
      {
        question: "Que se passe-t-il apres le lancement ?",
        answer:
          "Nous pouvons accompagner la maintenance, les ameliorations, les mises a jour de securite et les evolutions produit.",
      },
    ]}
    finalTitle="Pret a rendre votre site plus clair et credible ?"
    finalText="Apportez votre site actuel, votre idee ou votre flux de travail. Nous vous aiderons a clarifier ce qui doit changer en premier."
    finalCta="Planifier une consultation"
    finalCtaUrl={contactUrl}
  />
</MainLayout>
